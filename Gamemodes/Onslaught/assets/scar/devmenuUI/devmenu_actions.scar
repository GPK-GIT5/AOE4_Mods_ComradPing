	if _devmenu_mp_net_action(player, "INSTANT_BUILD") then
		if type(Rule_AddOneShot) == "function" and type(DevMenu_RefreshToggleStates) == "function" then
			Rule_AddOneShot(DevMenu_RefreshToggleStates, 0.3)
		end
		return
	end
	_devmenu_safe_call("ChatCheatInstantBuildAndGather", player)
	if type(DevMenu_ShowToast) == "function" then
		local on = (type(DevMenu_GetInstantBuildEnabled) == "function") and DevMenu_GetInstantBuildEnabled() or false
		DevMenu_ShowToast({ prefix = "Instant Build: ", state_word = on and "ON" or "OFF", state_on = on })
	end
	-- SP: cheat globals update synchronously — refresh immediately so cards show the new state.
	if type(DevMenu_RefreshToggleStates) == "function" then
		DevMenu_RefreshToggleStates()
	end
end

-- Toggle state getter: reads gInstantBuildCheat[playerIndex] written by ChatCheatInstantBuildAndGather.
function DevMenu_GetInstantBuildEnabled()
	local p = _devmenu_local_player()
	if p == nil or type(Player_GetID) ~= "function" then return false end
	if type(gInstantBuildCheat) ~= "table" then return false end
	return gInstantBuildCheat[Player_GetID(p)] == true
end

