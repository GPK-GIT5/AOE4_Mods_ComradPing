-----------------------------------------------------------------------
-- Combat / Survivability
--
-- TOGGLE CONTRACT — applies to every stateful ON/OFF cheat action:
--
--   1. The action function (DevMenu_Do*) calls the engine cheat which
--      stores toggle state in a chatcheats.scar global (e.g. gInvulnerableCheat,
--      gFoWCheat, gInstantBuildCheat), keyed by Player_GetID.
--
--   2. A matching getter (DevMenu_Get*Enabled) reads that engine global and
--      returns true/false. This function MUST be a named public global so the
--      data entry's `toggle_state_fn` field can reference it by name.
--
--   3. The data entry in devmenu_data.scar MUST include:
--        toggle_state_fn = "DevMenu_Get<Name>Enabled"
--      Without this the card renders as a plain blue "RUN NOW" action,
--      indistinguishable from one-shot commands like Spawn Army or Age Up.
--
--   4. Entries whose state depends on live selection (e.g. DoInvulnSelectedUnits)
--      MUST NOT have toggle_state_fn — their state is not a persistent flag and
--      would be stale at panel build time. Document this explicitly in data.scar.
-----------------------------------------------------------------------

function DevMenu_DoInvulnerable()
	local player = _devmenu_local_player()
	if _devmenu_mp_net_action(player, "INVULNERABLE") then
		if type(Rule_AddOneShot) == "function" and type(DevMenu_RefreshToggleStates) == "function" then
			Rule_AddOneShot(DevMenu_RefreshToggleStates, 0.3)
		end
		return
	end
	if type(ChatCheatInvulnerable) == "function" then
		_devmenu_safe_call("ChatCheatInvulnerable", player)
	else
		_devmenu_safe_call("CheatInvulnerable", player)
	end
	if type(DevMenu_ShowToast) == "function" then
		local on = (type(DevMenu_GetInvulnerableEnabled) == "function") and DevMenu_GetInvulnerableEnabled() or false
		DevMenu_ShowToast({ prefix = "Invulnerability ", state_word = on and "ENABLED" or "DISABLED", state_on = on })
	end
	-- SP: cheat globals update synchronously — refresh immediately so cards show the new state.
	if type(DevMenu_RefreshToggleStates) == "function" then
		DevMenu_RefreshToggleStates()
	end
end

-- Toggle state getter: reads gInvulnerableCheat[playerIndex] written by ChatCheatInvulnerable / CheatInvulnerable.
function DevMenu_GetInvulnerableEnabled()
	local p = _devmenu_local_player()
	if p == nil or type(Player_GetID) ~= "function" then return false end
	if type(gInvulnerableCheat) ~= "table" then return false end
	return gInvulnerableCheat[Player_GetID(p)] == true
end

-----------------------------------------------------------------------
-- Block Actions toggle
--
-- Toggles _DEVMENU_BLOCK_ACTIONS_MAP[local_playerID] (declared in
-- devmenu_mp_gate.scar). When true for a player, DEVMENU_DESTROY,
-- DEVMENU_CONVERT, DEVMENU_BURN, DEVMENU_TELEPORT, and DEVMENU_INVULN_SEL
-- skip units/buildings owned by that player on all peers.
--
-- MP path: broadcasts DEVMENU_BLOCK_ACTIONS_SET via the lockstep bus;
--   the net handler shows the toast and refreshes toggle states on all peers.
-- SP path: modifies the map directly, then shows toast and refreshes.
-----------------------------------------------------------------------
function DevMenu_DoToggleBlockActions()
	local player = _devmenu_local_player()
	if player == nil then return end
	if type(Player_GetID) ~= "function" then return end
	local pid = Player_GetID(player)
	if pid == nil then return end
	-- Compute new state before dispatch so we send the correct target value.
	local cur     = (_DEVMENU_BLOCK_ACTIONS_MAP ~= nil) and (_DEVMENU_BLOCK_ACTIONS_MAP[pid] == true) or false
	local new_val = not cur
	-- MP path: broadcast to all peers; net handler shows toast + refreshes.
	if _devmenu_mp_net_action(player, "DEVMENU_BLOCK_ACTIONS_SET",
			tostring(pid) .. " " .. (new_val and "1" or "0")) then return end
	-- SP path: apply directly.
	if type(_DEVMENU_BLOCK_ACTIONS_MAP) ~= "table" then _DEVMENU_BLOCK_ACTIONS_MAP = {} end
	_DEVMENU_BLOCK_ACTIONS_MAP[pid] = new_val
	if type(DevMenu_ShowToast) == "function" then
		DevMenu_ShowToast({
			prefix     = "Block Actions ",
			state_word = new_val and "ENABLED" or "DISABLED",
			state_on   = new_val,
			suffix     = new_val and " - cheat actions targeting your units will be blocked"
			                      or  " - your units are no longer protected",
		})
	end
	if type(DevMenu_RefreshToggleStates) == "function" then
		DevMenu_RefreshToggleStates()
	end
end

-- Toggle state getter: reads _DEVMENU_BLOCK_ACTIONS_MAP[local_playerID] set by
-- DevMenu_DoToggleBlockActions (SP) or DEVMENU_BLOCK_ACTIONS_SET net handler (MP).
function DevMenu_GetBlockActionsEnabled()
	local player = _devmenu_local_player()
	if player == nil or type(Player_GetID) ~= "function" then return false end
	local pid = Player_GetID(player)
	return (_DEVMENU_BLOCK_ACTIONS_MAP ~= nil) and (_DEVMENU_BLOCK_ACTIONS_MAP[pid] == true) or false
end

-- Compute a world position offset `dist` units forward from the camera's
-- current focal point, projected onto the ground plane (XZ).
--
-- Direction strategy (two attempts, logged for diagnostics):
--
--   1. eye→focal: derive forward from Camera_GetCurrentPos (eye) minus
--      Camera_GetCurrentTargetPos (focal). Reliable when the two APIs
--      return genuinely different XZ positions.
--
--   2. orbit angle: Camera_GetOrbit() returns the camera yaw in degrees.
--      Used as fallback when the eye→focal XZ delta is near zero (which
--      happens when both Camera_Get* APIs return the same pivot point).
--      Convention tested in engine: orbit=0 → forward = (sin 0, cos 0) =
--      (0, 1) = +Z. Increase clockwise. Confirmed via cardinal_narrative
--      and salisbury orbit checks in the scar_dump.
--
-- All branch choices are logged under [DEVMENU-CAM] (always emitted).
function _devmenu_camera_forward_pos(dist)
	dist = dist or 0
	if type(Camera_GetCurrentTargetPos) ~= "function" then return nil end
	local target = Camera_GetCurrentTargetPos()
	if target == nil then return nil end
	if dist == 0 then return target end

	local ok_tx, tx = pcall(function() return target.x end)
	local ok_ty, ty = pcall(function() return target.y end)
	local ok_tz, tz = pcall(function() return target.z end)
	if not ok_tx or tx == nil then return target end
	local y = (ok_ty and ty) or 0

	local dx, dz = 0, 0
	local method = "fallback"

	-- Attempt 1: eye → focal XZ direction.
	if type(Camera_GetCurrentPos) == "function" then
		local cam = Camera_GetCurrentPos()
		if cam ~= nil then
			local ok_cx, cx = pcall(function() return cam.x end)
			local ok_cz, cz = pcall(function() return cam.z end)
			if ok_cx and ok_cz and cx ~= nil and cz ~= nil then
				local ddx = tx - cx
				local ddz = tz - cz
				local len = math.sqrt(ddx * ddx + ddz * ddz)
				print(string.format("[DEVMENU-CAM] eye=(%.2f,%.2f) focal=(%.2f,%.2f) delta_len=%.3f", cx, cz, tx, tz, len))
				if len >= 0.001 then
					dx = ddx / len
					dz = ddz / len
					method = "eye_to_focal"
				end
			end
		end
	end

	-- Attempt 2: orbit angle (degrees → forward XZ).
	if method == "fallback" and type(Camera_GetOrbit) == "function" then
		local ok_orbit, orbit = pcall(Camera_GetOrbit)
		if ok_orbit and orbit ~= nil then
			local rad = math.rad(orbit)
			dx = math.sin(rad)
			dz = math.cos(rad)
			method = "orbit"
			print(string.format("[DEVMENU-CAM] orbit=%.1f deg -> dx=%.3f dz=%.3f", orbit, dx, dz))
		end
	end

	local fx = tx + dx * dist
	local fz = tz + dz * dist
	print(string.format("[DEVMENU-CAM] forward_pos dist=%.1f method=%s result=(%.2f,%.2f,%.2f)", dist, method, fx, y, fz))

	if method == "fallback" then
		return target
	end
	return World_Pos(fx, y, fz)
end

-- Shared helper: resolve the spawn position for spawning.
-- Always uses the player's Keep (town centre) as the target.
local function _devmenu_resolve_spawn_pos(player)
	if type(GetTownCentrePosition) == "function" then
		local tc_pos = GetTownCentrePosition(player)
		if tc_pos ~= nil then return tc_pos, "town_centre" end
	end
	return nil, "none"
end

function DevMenu_DoSpawnArmy()
	local player = _devmenu_local_player()
	if player == nil then return end
	-- MP routing: DEVMENU_SPAWN_ARMY handler finds the player's Keep on each peer.
	if _devmenu_mp_net_action(player, "DEVMENU_SPAWN_ARMY") then
		if type(DevMenu_ShowToast) == "function" then DevMenu_ShowToast("Core army spawned at keep") end
		return
	end
	-- SP path.
	local pos, src = _devmenu_resolve_spawn_pos(player)
	if pos == nil then
		print("[DEVMENU] spawn army: no valid position (cursor off-map and no town centre found)")
		return
	end
	print("[DEVMENU] spawn army at " .. tostring(src))
	if type(CheatSpawnCoreUnits) == "function" then
		_devmenu_safe_call("CheatSpawnCoreUnits", player, pos)
	else
		_devmenu_safe_call("SpawnCheatArmy", player)
	end
	if type(DevMenu_ShowToast) == "function" then
		DevMenu_ShowToast("Core army spawned at " .. tostring(src))
	end
end

-- Quick Panel variant: spawns at the current camera-forward position —
-- the same position logic used by Teleport Selected — rather than the Keep.
-- Falls back to _devmenu_resolve_spawn_pos (Keep) if camera pos is unavailable.
function DevMenu_DoSpawnArmyAtCamera()
	local player = _devmenu_local_player()
	if player == nil then return end

	local pos, src
	if type(_devmenu_camera_forward_pos) == "function" then
		pos = _devmenu_camera_forward_pos(-40)
		src = "camera_forward"
	end

	if pos == nil then
		pos, src = _devmenu_resolve_spawn_pos(player)
	end
	if pos == nil then
		print("[DEVMENU] spawn army (quick): no valid position")
		return
	end

	-- MP routing: serialize camera position so all peers spawn at the same world position.
	if _devmenu_is_multiplayer() then
		local ok_px, px = pcall(function() return pos.x end)
		local ok_py, py = pcall(function() return pos.y end)
		local ok_pz, pz = pcall(function() return pos.z end)
		if ok_px and ok_py and ok_pz and type(px) == "number" then
			if _devmenu_mp_net_action(player, "DEVMENU_SPAWN_ARMY_CAM",
				string.format("%.4f %.4f %.4f", px, py, pz)) then
				if type(DevMenu_ShowToast) == "function" then DevMenu_ShowToast("Core army spawned at " .. tostring(src)) end
				return
			end
		else
			-- Position not serializable: fall back to Keep-based spawn.
			if _devmenu_mp_net_action(player, "DEVMENU_SPAWN_ARMY") then
				if type(DevMenu_ShowToast) == "function" then DevMenu_ShowToast("Core army spawned at keep") end
				return
			end
		end
	end
	-- SP path.
	print("[DEVMENU] spawn army (quick) at " .. tostring(src))
	if type(CheatSpawnCoreUnits) == "function" then
		_devmenu_safe_call("CheatSpawnCoreUnits", player, pos)
	else
		_devmenu_safe_call("SpawnCheatArmy", player)
	end
	if type(DevMenu_ShowToast) == "function" then
		DevMenu_ShowToast("Core army spawned at " .. tostring(src))
	end
end

function DevMenu_DoSpawnPhotonMan()
	local player = _devmenu_local_player()
	if player == nil then return end
	-- MP routing: DEVMENU_SPAWN_PHOTON handler calls SpawnCheatPhotonMan on all peers.
	if _devmenu_mp_net_action(player, "DEVMENU_SPAWN_PHOTON") then
		if type(DevMenu_ShowToast) == "function" then DevMenu_ShowToast("Photon Man spawned at Keep") end
		return
	end
	-- SP path: direct call.
	-- Delegate to the official SpawnCheatPhotonMan: it handles first-spawn
	-- precaching via Squad_SlowLoadResources (tracked by hasLoadedPhoton flag)
	-- AND uses GetTownCentrePosition for position - both correct behaviors.
	-- Previously we called SpawnUnitBPForPlayer with needsLoad=false which
	-- skipped precaching and caused missing/placeholder assets on first spawn.
	if type(SpawnCheatPhotonMan) == "function" then
		_devmenu_safe_call("SpawnCheatPhotonMan", player)
		if type(DevMenu_ShowToast) == "function" then DevMenu_ShowToast("Photon Man spawned at Keep") end
		return
	end
	-- Last-resort fallback (SpawnCheatPhotonMan unavailable): manual call without precaching.
	local pos, src = _devmenu_resolve_spawn_pos(player)
	if pos == nil then
		print("[DEVMENU] spawn photon man: no valid position (fallback)")
		return
	end
	print("[DEVMENU] spawn photon man fallback at " .. tostring(src))
	if type(SpawnUnitBPForPlayer) == "function" then
		_devmenu_safe_call("SpawnUnitBPForPlayer", "unit_photon_man", player, pos, false)
		if type(DevMenu_ShowToast) == "function" then DevMenu_ShowToast("Photon Man spawned") end
	end
end

-----------------------------------------------------------------------
-- World
-----------------------------------------------------------------------

function DevMenu_DoFoW()
	local player = _devmenu_local_player()
	-- MP path: route through net dispatch so ChatCheatFOW fires on ALL peers at
	-- the same sim tick (same lockstep-safe pattern as INVULNERABLE/INSTANT_BUILD).
	if _devmenu_mp_net_action(player, "FOW_TOGGLE") then
		if type(Rule_AddOneShot) == "function" and type(DevMenu_RefreshToggleStates) == "function" then
			Rule_AddOneShot(DevMenu_RefreshToggleStates, 0.3)
		end
		return
	end
	-- SP path: call ChatCheatFOW directly; manages gFoWCheat toggle state.
	if type(ChatCheatFOW) == "function" then
		_devmenu_safe_call("ChatCheatFOW", player)
	elseif type(CheatFoW) == "function" then
		_devmenu_safe_call("CheatFoW", player, nil)
	end
	if type(DevMenu_ShowToast) == "function" then
		local on = (type(DevMenu_GetFoWEnabled) == "function") and DevMenu_GetFoWEnabled() or false
		DevMenu_ShowToast({ prefix = "Fog of War: ", state_word = on and "ENABLED" or "REVEALED", state_on = on })
	end
	-- SP: cheat globals update synchronously — refresh immediately so cards show the new state.
	if type(DevMenu_RefreshToggleStates) == "function" then
		DevMenu_RefreshToggleStates()
	end
end

-- Toggle state getter: reads gFoWCheat[playerIndex] managed by ChatCheatFOW / CheatFoW.
-- Returns true when FoW is active (fog visible), false when map is fully revealed.
function DevMenu_GetFoWEnabled()
	local p = _devmenu_local_player()
	if p == nil or type(Player_GetID) ~= "function" then return true end  -- unknown: assume fog on
	if type(gFoWCheat) ~= "table" then return true end  -- never toggled yet: fog is on
	local idx = Player_GetID(p)
	-- gFoWCheat[idx] == true means the cheat is "on" (fog was removed by ChatCheatFOW)
	-- FoW is "enabled" (fog visible) when gFoWCheat entry is false/nil.
	return not (gFoWCheat[idx] == true)
end

