-----------------------------------------------------------------------
-- DevMenu Actions
--
-- Thin named global wrappers around already-public cheat functions
-- defined in scar gameplay/gameplay/cheat.scar and chatcheats.scar.
-- Each handler resolves the local player and invokes the engine cheat
-- with no additional context. Speed handlers manipulate Misc_SetSimRate
-- directly (non-toggling step controls).
--
-- These are intentionally globals so UI_CreateCommand can bind to them
-- by name. They never import from or modify any other module.
-----------------------------------------------------------------------

local function _devmenu_local_player()
	if type(Game_GetLocalPlayer) == "function" then
		local ok, p = pcall(Game_GetLocalPlayer)
		if ok then return p end
	end
	return nil
end

local function _devmenu_safe_call(fn_name, ...)
	local fn = _G[fn_name]
	if type(fn) ~= "function" then
		print("[DEVMENU] missing handler: " .. tostring(fn_name))
		return
	end
	local ok, err = pcall(fn, ...)
	if not ok then
		print("[DEVMENU] " .. tostring(fn_name) .. " ERROR: " .. tostring(err))
	end
end

-----------------------------------------------------------------------
-- Simulation Speed (non-toggling step controls)
-----------------------------------------------------------------------

_DEVMENU_SPEED_MIN = 1.0
_DEVMENU_SPEED_MAX = 1000.0

function DevMenu_SpeedDefault()
	if type(Misc_SetSimRate) ~= "function" or type(Misc_GetSimDefaultStepsPerSecond) ~= "function" then
		print("[DEVMENU] sim rate API unavailable")
		return
	end
	local def = Misc_GetSimDefaultStepsPerSecond()
	Misc_SetSimRate(def)
	print("[DEVMENU] sim rate -> default " .. tostring(def))
end

function DevMenu_SpeedIncrease()
	if type(Misc_SetSimRate) ~= "function" or type(Misc_GetSimRate) ~= "function" then
		print("[DEVMENU] sim rate API unavailable")
		return
	end
	local cur = Misc_GetSimRate()
	if type(cur) ~= "number" or cur <= 0 then
		cur = Misc_GetSimDefaultStepsPerSecond()
	end
	local next_rate = cur * 2.0
	if next_rate > _DEVMENU_SPEED_MAX then next_rate = _DEVMENU_SPEED_MAX end
	Misc_SetSimRate(next_rate)
	print("[DEVMENU] sim rate " .. tostring(cur) .. " -> " .. tostring(next_rate))
end

function DevMenu_SpeedDecrease()
	if type(Misc_SetSimRate) ~= "function" or type(Misc_GetSimRate) ~= "function" then
		print("[DEVMENU] sim rate API unavailable")
		return
	end
	local cur = Misc_GetSimRate()
	if type(cur) ~= "number" or cur <= 0 then
		cur = Misc_GetSimDefaultStepsPerSecond()
	end
	local next_rate = cur * 0.5
	if next_rate < _DEVMENU_SPEED_MIN then next_rate = _DEVMENU_SPEED_MIN end
	Misc_SetSimRate(next_rate)
	print("[DEVMENU] sim rate " .. tostring(cur) .. " -> " .. tostring(next_rate))
end

