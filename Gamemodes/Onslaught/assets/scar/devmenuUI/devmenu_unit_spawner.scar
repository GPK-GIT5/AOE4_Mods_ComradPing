-- Resolve per-unit card icon: check with-tier then base token in
-- _DEVMENU_UNIT_SBP_ICON; fall back to the provided group icon.
-- Logs [SPAWNER-ICON] FALLBACK when no table entry is found — unexpected if
-- icons are complete; run Icon Audit (DevMenu_UnitSpawner_AuditIconCoverage)
-- to diagnose missing entries.
local function _spawner_unit_icon(sbp, fallback)
	local with_tier, base = _sbp_base_token(sbp)
	local resolved = _DEVMENU_UNIT_SBP_ICON[with_tier] or _DEVMENU_UNIT_SBP_ICON[base]
	if resolved then
		return resolved
	end
	if _DEVMENU_SPAWNER_ICON_TRACE then
		print(string.format("[SPAWNER-ICON] FALLBACK sbp=%-42s base=%s", tostring(sbp), tostring(base)))
	end
	return fallback
end

-- Full icon audit: validates unit card icons (all catalog entries) AND civ section
-- flag icons (section header icons per civilization).
--
-- Output prefix [ICON-AUDIT] — result codes:
--   PASS   – correct icon resolved (confirmed/override civ flag, or runtime base-civ flag)
--   WARN   – civ flag is Tier-2 path-constructed (file likely present; not assembly-confirmed)
--   FAIL   – unit card has no icon table entry, OR civ flag uses a unit-icon placeholder
--
-- Expected result after a complete icon pass:
--   Unit card errors : 0
--   Civ flag errors  : 0  (mongol_ha_gol uses flag_goh — confirmed from normal_mongol_ha_gol.xml)
--   Civ flag warns   : 2  (byzantine, japanese — Tier-2 constructed; present in game, not assembly-confirmed)
--   TOTAL ERRORS     : 0
-- Call from a DevMenu button or the SCAR console.
function DevMenu_UnitSpawner_AuditIconCoverage()
	-- ── Section 1: Unit Card Icons ────────────────────────────────────────────
	print("[ICON-AUDIT] ══════ Unit Card Icon Coverage ══════")
	local unit_total, unit_confirmed, unit_heuristic, unit_errors = 0, 0, 0, 0

	-- Stable alphabetical civ order for consistent log output.
	local civs = {}
	for civ in pairs(_DEVMENU_UNIT_SPAWNER_CATALOG) do
		table.insert(civs, civ)
	end
	table.sort(civs)

	for _, civ_key in ipairs(civs) do
		local civ_data = _DEVMENU_UNIT_SPAWNER_CATALOG[civ_key]
		local civ_n, civ_errors, civ_heuristic = 0, 0, 0
		local all_rows = {}
		if civ_data.military then for _, r in ipairs(civ_data.military) do table.insert(all_rows, r) end end
		if civ_data.economy  then for _, r in ipairs(civ_data.economy)  do table.insert(all_rows, r) end end
		if civ_data.unique   then for _, r in ipairs(civ_data.unique)   do table.insert(all_rows, r) end end
		for _, row in ipairs(all_rows) do
			unit_total = unit_total + 1
			civ_n      = civ_n      + 1
			local with_tier, base = _sbp_base_token(row.sbp)
			local resolved = _DEVMENU_UNIT_SBP_ICON[with_tier] or _DEVMENU_UNIT_SBP_ICON[base]
			if not resolved then
				unit_errors = unit_errors + 1
				civ_errors  = civ_errors  + 1
				print(string.format("[ICON-AUDIT] FAIL   unit=%-44s base=%-26s civ=%s",
					tostring(row.sbp), tostring(base), tostring(civ_key)))
			elseif _DEVMENU_ICON_CONFIRMED_PATHS[resolved] then
				unit_confirmed = unit_confirmed + 1
			else
				-- Heuristic path: in table but not assembly-confirmed; may render as purple blank.
				unit_heuristic = unit_heuristic + 1
				civ_heuristic  = civ_heuristic  + 1
				print(string.format("[ICON-AUDIT] WARN   unit=%-44s base=%-26s civ=%s  (unconfirmed path)",
					tostring(row.sbp), tostring(base), tostring(civ_key)))
			end
		end
		if civ_errors > 0 then
			print(string.format("[ICON-AUDIT] FAIL   civ=%-20s units=%d  errors=%d",
				tostring(civ_key), civ_n, civ_errors))
		elseif civ_heuristic > 0 then
			print(string.format("[ICON-AUDIT] WARN   civ=%-20s units=%d  heuristic=%d  (unconfirmed paths — verify in-game)",
				tostring(civ_key), civ_n, civ_heuristic))
		else
			print(string.format("[ICON-AUDIT] PASS   civ=%-20s units=%d",
				tostring(civ_key), civ_n))
		end
	end
	print(string.format("[ICON-AUDIT] Unit Card Summary:   total=%-4d confirmed=%-4d heuristic=%-4d(warns) errors=%d",
		unit_total, unit_confirmed, unit_heuristic, unit_errors))

	-- ── Section 2: Civilization Flag Icons ───────────────────────────────────
	print("[ICON-AUDIT] ══════ Civilization Flag Icon Coverage ══════")
	-- Base civs: _PlayerUI_RaceImage provides confirmed civ_flags/ paths at runtime.
	local _BASE_CIVS = {}
	if type(_PlayerUI_RaceImage) == "table" then
		for civ in pairs(_PlayerUI_RaceImage) do _BASE_CIVS[civ] = true end
	else
		-- Fallback list when _PlayerUI_RaceImage is not yet populated.
		for _, c in ipairs({"english","french","hre","mongol","rus","chinese",
			                "abbasid","malian","ottoman","sultanate"}) do
			_BASE_CIVS[c] = true
		end
	end

	local flag_total, flag_pass, flag_warn, flag_fail = 0, 0, 0, 0
	for _, civ in ipairs(_DEVMENU_UNIT_SPAWNER_CIV_ORDER_DEFAULT) do
		flag_total = flag_total + 1
		if _BASE_CIVS[civ] then
			-- Base civ: _PlayerUI_RaceImage path is confirmed present in the WPF assembly.
			flag_pass = flag_pass + 1
			print(string.format("[ICON-AUDIT] PASS   civ=%-20s flag=runtime   (_PlayerUI_RaceImage)",
				tostring(civ)))
		elseif _DEVMENU_UNIT_SPAWNER_CIV_ICON[civ] ~= nil then
			local icon = _DEVMENU_UNIT_SPAWNER_CIV_ICON[civ]
			-- A proper civ flag URI contains "civ_flags/"; a unit-icon placeholder contains "icons/races/".
			if icon:find("icons/races/", 1, true) or icon:find("icons\\races\\", 1, true) then
				flag_fail = flag_fail + 1
				print(string.format("[ICON-AUDIT] FAIL   civ=%-20s flag=PLACEHOLDER (unit icon used; no civ_flags/ asset in game data)",
					tostring(civ)))
				print(string.format("[ICON-AUDIT]        uri=%s", tostring(icon)))
			else
				flag_pass = flag_pass + 1
				print(string.format("[ICON-AUDIT] PASS   civ=%-20s flag=override  (explicit civ_flags/ entry)",
					tostring(civ)))
			end
		else
			-- Tier-2: path-constructed. File likely exists but not confirmed in WPF assembly.
			flag_warn = flag_warn + 1
			print(string.format("[ICON-AUDIT] WARN   civ=%-20s flag=constructed (Tier-2; may be absent from assembly)",
				tostring(civ)))
		end
	end
	print(string.format("[ICON-AUDIT] Civ Flag Summary:    total=%-4d pass=%-4d warn=%-4d fail=%d",
		flag_total, flag_pass, flag_warn, flag_fail))

	-- ── Final Summary ─────────────────────────────────────────────────────────
	local total_errors = unit_errors + flag_fail
	print("[ICON-AUDIT] ══════ Final Summary ══════")
	print(string.format("[ICON-AUDIT] Unit card errors : %d", unit_errors))
	if flag_fail == 0 then
		print("[ICON-AUDIT] Civ flag errors  : 0")
	elseif flag_fail == 1 then
		print("[ICON-AUDIT] Civ flag errors  : 1  (placeholder — add a civ_flags/ asset when available)")
	else
		print(string.format("[ICON-AUDIT] Civ flag errors  : %d  (placeholders)", flag_fail))
	end
	print(string.format("[ICON-AUDIT] TOTAL ERRORS     : %d", total_errors))
	if total_errors == 0 then
		print("[ICON-AUDIT] STATUS: ALL PASS — icon coverage is complete.")
	else
		print(string.format("[ICON-AUDIT] STATUS: %d FAIL(S) — see [ICON-AUDIT] FAIL lines above.", total_errors))
	end

	-- ── Threshold Gate (Phase 4 / 2026-05-18 stabilization) ──────────────────
	-- Closes the audit blind spot where key-present-but-URI-unconfirmed icons
	-- rendered blank. Defaults:
	--   bp_fail (unit_errors + flag_fail) MUST be 0.
	--   heuristic (unit_heuristic) is reported with a tight default ceiling
	--   so silent drift is impossible. Adjust _DEVMENU_ICON_AUDIT_HEURISTIC_MAX
	--   intentionally; never raise it just to silence the warning.
	local heuristic_max = _DEVMENU_ICON_AUDIT_HEURISTIC_MAX or 0
	local audit_status = "PASS"
	if total_errors > 0 then
		audit_status = "FAIL"
		print(string.format(
			"[ICON-AUDIT] GATE  FAIL  bp_fail=%d (must be 0). Resolve missing icon entries before merge.",
			total_errors))
	elseif unit_heuristic > heuristic_max then
		audit_status = "WARN"
		print(string.format(
			"[ICON-AUDIT] GATE  WARN  heuristic=%d exceeds ceiling=%d. "
			.. "Promote unconfirmed paths to _DEVMENU_ICON_CONFIRMED_PATHS or raise the ceiling intentionally.",
			unit_heuristic, heuristic_max))
	else
		print(string.format(
			"[ICON-AUDIT] GATE  PASS  bp_fail=0 heuristic=%d ceiling=%d",
			unit_heuristic, heuristic_max))
	end
	return {
		status         = audit_status,
		unit_total     = unit_total,
		unit_confirmed = unit_confirmed,
		unit_heuristic = unit_heuristic,
		unit_errors    = unit_errors,
		flag_total     = flag_total,
		flag_pass      = flag_pass,
		flag_warn      = flag_warn,
		flag_fail      = flag_fail,
		bp_fail        = total_errors,
		heuristic_max  = heuristic_max,
	}
end

-- ---------------------------------------------------------------
-- _loc_to_str: file-level helper — converts a utf8_mt LocString userdata
-- to a plain Lua string via Loc_ToAnsi, falling back to tostring().
-- Defined here (before AuditIconFull) so all audit functions can use it.
-- Also used by _spawner_get_unit_meta (~line 1891) via closure; both
-- references resolve to this copy.
local function _loc_to_str(v)
	if v == nil then return nil end
	if type(Loc_ToAnsi) == "function" then
		local ok_a, a = pcall(Loc_ToAnsi, v)
		if ok_a and type(a) == "string" and a ~= "" then return a end
	end
	local s = tostring(v)
	if s == "" or s:find("^utf8_mt:", 1, true) then return nil end
	return s
end

-- ---------------------------------------------------------------
-- DevMenu_UnitSpawner_AuditIconFull
--
-- Full per-unit icon report: logs the resolved icon URI for every catalog
-- entry so each unit card can be visually verified against the spawner UI.
-- Produces one [ICON-AUDIT] UNIT line per entry (civ, section, SBP, and
-- the pack:// URI that will be used), followed by a TOTAL summary.
--
-- Also retrieves UI metadata (screenName, helpText) from BP_GetSquadUIInfo
-- for each SBP that is resident in the current map session. This confirms
-- the metadata fields are accessible and can later be attached to unit
-- cards as tooltips. Metadata lines are prefixed with [ICON-AUDIT] META.
--
-- Complements DevMenu_UnitSpawner_AuditIconCoverage (which only prints
-- PASS/FAIL per civ). Use this when you need the full icon-path list for
-- a side-by-side comparison with what is actually rendered in the UI.
--
-- BP_GetSquadUIInfo return fields (confirmed from engine scar_dump usage):
--   .iconName          — icon path (backslash-separated relative path)
--   .screenName        — localized unit display name (utf8_mt LocString)
--   .helpText          — description / tooltip text
--   .extraText         — secondary tooltip text
--   .tooltipDataTemplate — UI template class name (e.g. "BuildingMilitaryDataTemplate")
--
-- Output prefix: [ICON-AUDIT]
--   UNIT CONFIRMED – icon path is in _DEVMENU_ICON_CONFIRMED_PATHS (assembly-verified)
--   UNIT HEURISTIC – icon path is in the table but NOT assembly-confirmed; may render blank
--   UNIT FALLBACK  – no icon table entry at all; uses the section group icon
--   META  – screenName + helpText for each SBP that resolves via BP_GetSquadUIInfo
--   TOTAL – final counts: entries / confirmed / heuristic / fallback / meta_retrieved
-- ---------------------------------------------------------------
function DevMenu_UnitSpawner_AuditIconFull()
	print("[ICON-AUDIT] ══════ Full Unit Icon Report ══════")
	print("[ICON-AUDIT] Lists the resolved icon URI and UI metadata for every catalog entry.")
	print("[ICON-AUDIT] Compare against the spawner UI to verify visual accuracy.")

	-- Get the local player's race PBG — required by BP_GetSquadUIInfo.
	-- Icon resolution does not need this; metadata retrieval does.
	local race_pbg = nil
	pcall(function()
		local player = Game_GetLocalPlayer()
		if player then race_pbg = Player_GetRace(player) end
	end)
	if race_pbg == nil then
		print("[ICON-AUDIT] NOTE: race_pbg unavailable — screenName/helpText will be skipped.")
	end

	local civs = {}
	for civ in pairs(_DEVMENU_UNIT_SPAWNER_CATALOG) do
		table.insert(civs, civ)
	end
	table.sort(civs)

	local total, resolved_n, heuristic_n, fallback_n, meta_n = 0, 0, 0, 0, 0

	for _, civ_key in ipairs(civs) do
		local civ_data = _DEVMENU_UNIT_SPAWNER_CATALOG[civ_key]
		print(string.format("[ICON-AUDIT] ── civ=%s ──", tostring(civ_key)))

		local sections = {
			{ label = "military", rows = civ_data.military },
			{ label = "economy",  rows = civ_data.economy  },
			{ label = "unique",   rows = civ_data.unique   },
		}
		for _, sec in ipairs(sections) do
			if sec.rows and #sec.rows > 0 then
				for _, row in ipairs(sec.rows) do
					total = total + 1
					local with_tier, base = _sbp_base_token(row.sbp)
					local resolved = _DEVMENU_UNIT_SBP_ICON[with_tier] or _DEVMENU_UNIT_SBP_ICON[base]
					if resolved then
						resolved_n = resolved_n + 1
						if _DEVMENU_ICON_CONFIRMED_PATHS[resolved] then
							print(string.format("[ICON-AUDIT] UNIT CONFIRMED  %-10s  %-48s  %s",
								tostring(sec.label), tostring(row.sbp), tostring(resolved)))
						else
							heuristic_n = heuristic_n + 1
							print(string.format("[ICON-AUDIT] UNIT HEURISTIC  %-10s  %-48s  %s  ← unconfirmed; verify in-game",
								tostring(sec.label), tostring(row.sbp), tostring(resolved)))
						end
					else
						fallback_n = fallback_n + 1
						print(string.format("[ICON-AUDIT] UNIT FALLBACK   %-10s  %-48s  (no icon entry — uses group icon)",
							tostring(sec.label), tostring(row.sbp)))
					end

					-- UI metadata: screenName + helpText via BP_GetSquadUIInfo.
					-- Only available for SBPs that are resident in the current map session.
					-- screenName and helpText are utf8_mt LocString userdata; use _loc_to_str (Loc_ToAnsi).
					if race_pbg ~= nil then
						local ok_bp, sbp_pbg = pcall(BP_GetSquadBlueprint, row.sbp)
						if ok_bp and sbp_pbg ~= nil then
							local ok_ui, uiinfo = pcall(BP_GetSquadUIInfo, sbp_pbg, race_pbg)
							if ok_ui and uiinfo ~= nil then
								meta_n = meta_n + 1
								local sn = uiinfo.screenName ~= nil and _loc_to_str(uiinfo.screenName) or "(nil)"
								local ht = uiinfo.helpText   ~= nil and _loc_to_str(uiinfo.helpText)   or "(nil)"
								print(string.format("[ICON-AUDIT] META  screenName=%s", sn))
								print(string.format("[ICON-AUDIT] META  helpText_len=%d  helpText=%s",
									#ht, ht:sub(1, 80)))
							end
						end
					end
				end
			end
		end
	end

	print(string.format("[ICON-AUDIT] TOTAL: %d entries  confirmed=%d  heuristic=%d  fallback=%d  meta_retrieved=%d",
		total, resolved_n - heuristic_n, heuristic_n, fallback_n, meta_n))
	if fallback_n == 0 and heuristic_n == 0 then
		print("[ICON-AUDIT] STATUS: ALL CONFIRMED — every unit card has an assembly-verified icon.")
	elseif fallback_n == 0 then
		print(string.format("[ICON-AUDIT] STATUS: %d HEURISTIC path(s) — assumed; run Coverage audit and verify in-game for purple blanks.", heuristic_n))
	elseif heuristic_n == 0 then
		print(string.format("[ICON-AUDIT] STATUS: %d FALLBACK(S) — units with no icon entry use the section group icon.", fallback_n))
	else
		print(string.format("[ICON-AUDIT] STATUS: %d HEURISTIC + %d FALLBACK(S) — see UNIT HEURISTIC / UNIT FALLBACK lines above.", heuristic_n, fallback_n))
	end
	if race_pbg ~= nil then
		if meta_n == total then
			print(string.format("[ICON-AUDIT] METADATA: ALL %d units returned UI metadata via BP_GetSquadUIInfo.", meta_n))
		else
			print(string.format("[ICON-AUDIT] METADATA: %d/%d units returned UI metadata (missing = SBP not precached in this session).", meta_n, total))
		end
	end
end

-- ---------------------------------------------------------------
-- DevMenu_UnitSpawner_AuditIconCivMatch
--
-- Detects and flags every unit+age icon resolution where the resolved
-- icon path does not belong to the unit's own civilization folder or
-- the shared "common" folder.
--
-- This surfaces all intentional cross-civ icon reuse (e.g. Crossbowman IV
-- → French arbaletrier_4.png applied to jin/english/etc.), unconfirmed
-- (HEURISTIC) paths, and fully missing (FALLBACK) entries so each mapping
-- can be audited and patched.
--
-- Output prefix: [ICON-CIVMATCH]
--   CIV-CROSS       – resolved icon is from a different civ's folder
--   HEURISTIC       – path in table but NOT confirmed in assembly (purple risk)
--   HEURISTIC+CROSS – both conditions simultaneously
--   FALLBACK        – no icon entry at all; section group icon substituted
--   FAIL            – resolved icon in _DEVMENU_UNIT_SBP_ICON conflicts with BP_GetSquadUIInfo
--   SUMMARY         – totals after all civs processed
--
-- Each mismatch line includes five fields:
--   unit      – SBP name (e.g. unit_crossbowman_4_jin)
--   age       – roman tier label (I / II / III / IV / V)
--   resolved  – actual pack:// URI in use (or "(none)" for FALLBACK)
--   canonical – hypothetical own-civ reference path (races/{civ}/units/{token}.png)
--   reason    – classification + icon-civ/expected detail
--
-- META lines follow every flagged entry (uses same BP_GetSquadUIInfo API as [ICON-AUDIT]):
--   screenName  – from BP_GetSquadUIInfo; "(nil)" if SBP not loaded in this session
--   bp_icon     – blueprint iconName normalised to pack:// URI; "(unavail)" if format unknown
--   [MATCH]     – resolved icon matches blueprint ground truth
--   * FAIL      – resolved and blueprint icons disagree (stale or incorrect table entry)
--
-- [PATCH] suffix: every CIV-CROSS/HEURISTIC/FALLBACK entry is a patch candidate.
--   [PATCH: use confirmed canonical path]  = safe to apply now.
--   [PATCH: use confirmed common path]     = common fallback confirmed.
--   [PATCH: canonical unconfirmed]         = verify path in WPFGUI assembly before patching.
-- Civs with assembly folder != civ_key (jin_dynasty->jin, mongol->mongols) and HA civs that
-- inherit parent icons are handled via _CIV_ACCEPTED_FOLDERS; intentional reuse is not flagged.
-- ---------------------------------------------------------------
function DevMenu_UnitSpawner_AuditIconCivMatch()
	local _PACK  = "pack://application:,,,/WPFGUI;component/icons/races/"
	local _ROMAN = { ["1"]="I", ["2"]="II", ["3"]="III", ["4"]="IV", ["5"]="V" }

	-- Maps civ_key to icon-folder names accepted as own-civ in the WPFGUI assembly.
	-- (a) Assembly naming mismatches: jin_dynasty assets live under 'jin/', mongol under 'mongols/'.
	-- (b) HA-variant civs that legitimately inherit icons from a parent or historic-civ folder.
	local _CIV_ACCEPTED_FOLDERS = {
		jin_dynasty     = { jin=true, chinese=true },              -- assembly folder='jin'; chinese for khaganate_nest_of_bees
		mongol          = { mongols=true, campaign=true, rus=true, chinese=true },  -- assembly folder='mongols'
		mongol_ha_gol   = { mongols=true, rus=true, chinese=true },
		japanese_ha_sen = { japanese=true, sengoku=true },
		french_ha_01    = { french_historic=true },
		abbasid_ha_01   = { abbasid=true, abbasid_historic=true, campaign=true },
		chinese_ha_01   = { chinese_historic=true },
		hre_ha_01       = { hre=true },
		byzantine_ha_mac= { byzantine=true, macedonian=true },
		sultanate_ha_tug= { tughluq=true, sultanate=true },
	}
	-- For civs whose assembly folder name differs from their civ_key: used when building canon_own.
	local _CIV_ICON_FOLDER_PRIMARY = { jin_dynasty="jin", mongol="mongols" }

	print("[ICON-CIVMATCH] ══════ Icon Civ-Match Audit ══════")
	print("[ICON-CIVMATCH] Flags icon-civ mismatches (not own-civ, common, or accepted parent folder).")
	print("[ICON-CIVMATCH] Verifies resolved icon vs BP_GetSquadUIInfo ground truth ([ICON-AUDIT] source).")
	print("[ICON-CIVMATCH] [PATCH: confirmed]   = apply now; canonical path in _DEVMENU_ICON_CONFIRMED_PATHS.")
	print("[ICON-CIVMATCH] [PATCH: unconfirmed] = verify path in WPFGUI assembly, then add sbp_key override.")
	print("[ICON-CIVMATCH] FAIL                 = icon table entry disagrees with blueprint ground truth.")
	print("[ICON-CIVMATCH] META                 = screenName + bp_icon cross-check (per flagged entry).")

	local civs = {}
	for civ in pairs(_DEVMENU_UNIT_SPAWNER_CATALOG) do
		table.insert(civs, civ)
	end
	table.sort(civs)

	local n_total, n_ok, n_cross, n_heuristic, n_fallback, n_patch, n_fail, n_sn_miss = 0, 0, 0, 0, 0, 0, 0, 0

	-- Get the local player's race PBG — required by BP_GetSquadUIInfo (same pattern as AuditIconFull).
	local race_pbg = nil
	pcall(function()
		local player = Game_GetLocalPlayer()
		if player then race_pbg = Player_GetRace(player) end
	end)
	if race_pbg == nil then
		print("[ICON-CIVMATCH] NOTE: race_pbg unavailable — screenName/bp_icon cross-check will be skipped.")
	end

	-- Normalize BP_GetSquadUIInfo.iconName (backslash relative path or full pack:// URI)
	-- to a pack:// URI for direct comparison against _DEVMENU_UNIT_SBP_ICON entries.
	-- Returns nil when the format is unrecognised (comparison is skipped, not flagged as FAIL).
	local _PACK_ASM = "pack://application:,,,/WPFGUI;component/"
	local function _bp_icon_to_pack(raw)
		if type(raw) ~= "string" or raw == "" then return nil end
		local n = raw:gsub("\\", "/")
		if n:sub(1, 7):lower() == "pack://" then
			return n:find("%.png$") ~= nil and n or (n .. ".png")
		elseif n:sub(1, 6):lower() == "icons/" then
			return _PACK_ASM .. n .. (n:find("%.png$") ~= nil and "" or ".png")
		end
		return nil
	end

	for _, civ_key in ipairs(civs) do
		local civ_data = _DEVMENU_UNIT_SPAWNER_CATALOG[civ_key]
		local sections = {
			{ label = "military", rows = civ_data.military },
			{ label = "economy",  rows = civ_data.economy  },
			{ label = "unique",   rows = civ_data.unique   },
		}

		for _, sec in ipairs(sections) do
			if sec.rows and #sec.rows > 0 then
				for _, row in ipairs(sec.rows) do
					local sbp = row.sbp
					if sbp then
						local with_tier, base = _sbp_base_token(sbp)
						local tier_digit = with_tier and with_tier:match("_(%d+)$") or "?"
						local age_label  = _ROMAN[tier_digit] or tier_digit

						-- Resolve actual icon (mirrors _spawner_unit_icon logic).
						local sbp_key  = sbp:match("^unit_(.+)$")
						local resolved = _DEVMENU_UNIT_SBP_ICON[sbp_key] or _DEVMENU_UNIT_SBP_ICON[with_tier] or _DEVMENU_UNIT_SBP_ICON[base]

						-- Retrieve blueprint metadata: icon path + screenName for ground-truth cross-check.
						-- Mirrors the _audit_meta pattern in AuditIconFull ([ICON-AUDIT] source of truth).
						local bp_icon_pack = nil
						local bp_sn        = nil
						if race_pbg ~= nil then
							local ok1, sbp_pbg = pcall(BP_GetSquadBlueprint, sbp)
							if ok1 and sbp_pbg ~= nil then
								local ok2, uiinfo = pcall(BP_GetSquadUIInfo, sbp_pbg, race_pbg)
								if ok2 and uiinfo ~= nil then
									bp_icon_pack = _bp_icon_to_pack(uiinfo.iconName)
									if uiinfo.screenName ~= nil then
										bp_sn = _loc_to_str(uiinfo.screenName)
									end
								end
							end
						end

						-- Extract the civ folder name from the resolved pack:// URI.
						local icon_civ = resolved and resolved:match("/races/([^/]+)/") or nil

						-- Build own-civ canonical reference path.
						-- _CIV_ICON_FOLDER_PRIMARY remaps civs whose assembly folder name != civ_key
						-- (jin_dynasty->jin, mongol->mongols) so canon_own reflects a real assembly path.
						local token              = with_tier or base
						local civ_folder         = _CIV_ICON_FOLDER_PRIMARY[civ_key] or civ_key
						local canon_own          = _PACK .. civ_folder .. "/units/" .. token .. ".png"
						local canon_common       = _PACK .. "common"   .. "/units/" .. token .. ".png"
						local canon_confirmed    = _DEVMENU_ICON_CONFIRMED_PATHS[canon_own]   and true or false
						local common_confirmed   = _DEVMENU_ICON_CONFIRMED_PATHS[canon_common] and true or false

						-- Classify this entry.
						local is_fallback  = (resolved == nil)
						local is_heuristic = resolved and not _DEVMENU_ICON_CONFIRMED_PATHS[resolved]
						local _accepted    = _CIV_ACCEPTED_FOLDERS[civ_key]
						local _icon_own    = (icon_civ == civ_key) or (_accepted and _accepted[icon_civ] == true)
						local is_civ_cross = icon_civ ~= nil and icon_civ ~= "common" and not _icon_own

						n_total = n_total + 1

						-- Blueprint ground-truth failure: icon table disagrees with BP_GetSquadUIInfo.
						-- Indicates a stale or incorrect entry in _DEVMENU_UNIT_SBP_ICON.
						local is_bp_mismatch = bp_icon_pack ~= nil and resolved ~= nil and bp_icon_pack ~= resolved
						if is_bp_mismatch then n_fail = n_fail + 1 end
						-- Track screenName misses (only counted when race_pbg is available).
						if race_pbg ~= nil and bp_sn == nil then n_sn_miss = n_sn_miss + 1 end

						-- Print blueprint metadata line after any flagged entry (same style as [ICON-AUDIT] META).
						-- Shows screenName + bp_icon cross-check result.
						local function _print_bp_meta()
							if race_pbg == nil then return end
							local bp_icon_str = bp_icon_pack or "(unavail)"
							local icon_tag    = is_bp_mismatch and "  * FAIL: bp_icon!=resolved" or "  [MATCH]"
							local sn_str      = bp_sn or "(nil)"
							print(string.format("[ICON-CIVMATCH]   META  screenName=%-30s  bp_icon=%s%s",
								sn_str, bp_icon_str, icon_tag))
						end

						-- Determine patch annotation.
						-- canonical is always authoritative: every CIV-CROSS is a patch candidate.
						-- CONFIRMED = canonical path is in _DEVMENU_ICON_CONFIRMED_PATHS (safe to apply now).
						-- UNCONFIRMED = canonical path not yet verified in assembly (verify before applying).
						local function _patch_note()
							if canon_confirmed  then n_patch = n_patch + 1; return "  [PATCH: use confirmed canonical path]" end
							if common_confirmed then n_patch = n_patch + 1; return "  [PATCH: use confirmed common path]" end
							n_patch = n_patch + 1
							return "  [PATCH: canonical unconfirmed — verify path in assembly before applying]"
						end

						if is_fallback then
							n_fallback = n_fallback + 1
							print(string.format("[ICON-CIVMATCH] FALLBACK         unit=%-44s  age=%-3s  resolved=(none)  canonical=%s  reason=no_icon_entry%s",
								sbp, age_label, canon_own, _patch_note()))
							_print_bp_meta()

						elseif is_heuristic and is_civ_cross then
							n_heuristic = n_heuristic + 1
							n_cross     = n_cross     + 1
							print(string.format("[ICON-CIVMATCH] HEURISTIC+CROSS  unit=%-44s  age=%-3s  resolved=%s  canonical=%s  reason=unconfirmed;icon-civ=%s;expected=%s%s",
								sbp, age_label, tostring(resolved), canon_own, icon_civ, civ_key, _patch_note()))
							_print_bp_meta()

						elseif is_heuristic then
							n_heuristic = n_heuristic + 1
							print(string.format("[ICON-CIVMATCH] HEURISTIC        unit=%-44s  age=%-3s  resolved=%s  canonical=%s  reason=unconfirmed_path%s",
								sbp, age_label, tostring(resolved), canon_own, _patch_note()))
							_print_bp_meta()

						elseif is_civ_cross then
							n_cross = n_cross + 1
							print(string.format("[ICON-CIVMATCH] CIV-CROSS        unit=%-44s  age=%-3s  resolved=%s  canonical=%s  reason=icon-civ=%s;expected=%s%s",
								sbp, age_label, tostring(resolved), canon_own, icon_civ, civ_key, _patch_note()))
							_print_bp_meta()

						else
							n_ok = n_ok + 1
							-- For canonical units, still print FAIL if blueprint disagrees with the table.
							if is_bp_mismatch then
								print(string.format("[ICON-CIVMATCH] FAIL             unit=%-44s  age=%-3s  resolved=%s  reason=bp_icon_mismatch",
									sbp, age_label, tostring(resolved)))
								_print_bp_meta()
							end
						end
					end
				end
			end
		end
	end

	print(string.format("[ICON-CIVMATCH] SUMMARY: total=%d  ok=%d  civ-cross=%d  heuristic=%d  fallback=%d  patch_candidates=%d  bp_fail=%d  sn_miss=%d",
		n_total, n_ok, n_cross, n_heuristic, n_fallback, n_patch, n_fail, n_sn_miss))
	if n_fail > 0 then
		print(string.format("[ICON-CIVMATCH] STATUS: %d FAIL(S) — icon table entries conflict with BP_GetSquadUIInfo ground truth; fix _DEVMENU_UNIT_SBP_ICON.", n_fail))
	end
	if n_cross == 0 and n_heuristic == 0 and n_fallback == 0 and n_fail == 0 then
		print("[ICON-CIVMATCH] STATUS: ALL CANONICAL — every unit uses its own-civ or confirmed common icon.")
	elseif n_patch > 0 then
		print(string.format("[ICON-CIVMATCH] STATUS: %d patch candidate(s) found — review [PATCH] entries and add confirmed paths to _DEVMENU_UNIT_SBP_ICON.", n_patch))
	end
	if n_sn_miss > 0 then
		print(string.format("[ICON-CIVMATCH] STATUS: %d unit(s) returned nil screenName — SBP not loaded in this session (run in a live game).", n_sn_miss))
	end
end

-- ---------------------------------------------------------------
-- Per-civ catalog
--
-- Each civ entry lists units as { name, sbp, sub } where sub is one of
-- "infantry", "ranged", "cavalry", "siege", "naval" (military / unique)
-- or "land", "naval" (economy). Unique entries may also carry a sub for
-- the threshold-based subgrouping.
--
-- Coverage philosophy: each civ ships a representative cross-section of
-- the well-known SBPs (verified against canonical-units.json + leaver
-- fallback prefixes + CBA siege table). This is intentionally a curated
-- starter catalog rather than an exhaustive enumeration; new units can
-- be added here without touching any other file.
-- ---------------------------------------------------------------

-- Helper: build the SBP for a shared unit at a given age tier.
-- e.g. _u_shared("spearman", 1, "eng") -> "unit_spearman_1_eng"
local function _u_shared(base, tier, suffix)
	return "unit_" .. base .. "_" .. tostring(tier) .. "_" .. suffix
end

-- Helper: build a row { name=display, sbp=sbp_name, sub=primary-tag, tags=optional-second-tag }.
-- sub  = primary combat category (drives grouping, sorting, and group icon).
-- tags = optional string for a second display badge on the card (e.g. "ranged" on a cavalry archer).
local function _row(name, sbp, sub, tags)
	return { name = name, sbp = sbp, sub = sub, tags = tags }
end

-- Age label map: tier digit → AoE4 age name used in card display text.
local _AGE_LABEL = { [1] = "Dark", [2] = "Feudal", [3] = "Castle", [4] = "Imperial" }

-- Build consecutive tier rows for a unit spanning ages min_t..max_t.
-- Rows share the same base token and sub, so _flush_rows groups them into
-- one age-selector card automatically.
local function _u_tiers(display_base, sbp_base, min_t, max_t, suffix, sub)
	local out = {}
	for t = min_t, max_t do
		local age = _AGE_LABEL[t] or ("Age " .. t)
		table.insert(out, _row(display_base .. " (" .. age .. ")",
			"unit_" .. sbp_base .. "_" .. t .. "_" .. suffix, sub))
	end
	return out
end

-- Flatten a variable number of row-lists into one sequential table.
-- Used to build ordered catalog sections from multiple _u_tiers calls.
local function _merge_rows(...)
	local out = {}
	for _, tbl in ipairs({...}) do
		for _, v in ipairs(tbl) do table.insert(out, v) end
	end
	return out
end

-- Generate the standard "shared roster" rows for a civ that uses the
-- vanilla European unit set (French, HRE, Rus, Chinese, Byzantine, etc.).
-- Consecutive tier rows for each eligible unit auto-group into age-selector
-- cards via _flush_rows.  Single-tier units remain as flat cards.
-- spearman_min_t: first spearman tier to include. Most civs start at Dark Age (1);
-- English is Feudal (2) because unit_spearman_1_eng does not exist in attrib data
-- (English tier-1 spearman uses the core blueprint, not a civ-specific one).
-- knight_min_t: first knight tier. Most civs start at Castle (3). French starts at
-- Feudal (2) because unit_knight_2_fre is the Royal Knight and shares the knight BP family.
local function _shared_european_military(suffix, spearman_min_t, knight_min_t, manatarms_min_t)
	spearman_min_t  = spearman_min_t  or 1
	knight_min_t    = knight_min_t    or 3
	manatarms_min_t = manatarms_min_t or 3
	return _merge_rows(
		-- Infantry: Spearman (spearman_min_t)–Imperial, Man-at-Arms (manatarms_min_t)–Imperial
		_u_tiers("Spearman",    "spearman",  spearman_min_t,  4, suffix, "infantry"),
		_u_tiers("Man-at-Arms", "manatarms", manatarms_min_t, 4, suffix, "infantry"),
		-- Ranged: Archer Feudal–Imperial (3-tier), Crossbowman Castle–Imperial (2-tier), Handcannoneer single
		_u_tiers("Archer",      "archer",      2, 4, suffix, "ranged"),
		_u_tiers("Crossbowman", "crossbowman", 3, 4, suffix, "ranged"),
		{ _row("Handcannoneer (Imp.)", "unit_handcannon_4_" .. suffix, "ranged") },
		-- Cavalry: Horseman Feudal–Imperial (3-tier), Knight Castle–Imperial (2-tier), Scout single
		_u_tiers("Horseman", "horseman", 2, 4, suffix, "cavalry"),
		_u_tiers("Knight",   "knight",   knight_min_t, 4, suffix, "cavalry"),
		{ _row("Scout (Dark)", "unit_scout_1_" .. suffix, "cavalry") },
		-- Siege: all single-tier (no cross-age variants in attrib data)
		{ _row("Battering Ram (Castle)", "unit_ram_3_" .. suffix,          "siege") },
		{ _row("Mangonel (Castle)",      "unit_mangonel_3_" .. suffix,     "siege") },
		{ _row("Springald (Castle)",     "unit_springald_3_" .. suffix,    "siege") },
		{ _row("Trebuchet (Imperial)",   "unit_trebuchet_4_cw_" .. suffix, "siege") },
		{ _row("Bombard (Imperial)",     "unit_bombard_4_" .. suffix,      "siege") }
	)
end

local function _shared_european_economy(suffix)
	return {
		_row("Villager",                _u_shared("villager", 1, suffix), "land"),
		_row("Monk (Castle)",           _u_shared("monk",     3, suffix), "land"),
		_row("Trade Cart",              "unit_trade_cart_" .. suffix,            "land"),
		_row("Fishing Boat",            "unit_naval_fishing_boat_2_" .. suffix,  "naval"),
		_row("Trade Ship",              "unit_naval_trade_ship_3_" .. suffix,    "naval"),
	}
end

-- Build the catalog. Each civ entry has { military={}, economy={}, unique={} }.
_DEVMENU_UNIT_SPAWNER_CATALOG = {

	english = {
		-- English uses _shared_european_military with spearman_min_t=2 because
		-- unit_spearman_1_eng does not exist (English uses the core spearman_1 blueprint).
		-- manatarms_min_t=1: English Man-at-Arms starts at Dark Age (unit_manatarms_1_eng confirmed).
		-- The Longbowman IS unit_archer_*_eng, so the Archer age-selector covers Feudal–Imperial.
		military = _shared_european_military("eng", 2, nil, 1),
		economy  = _shared_european_economy("eng"),
		unique   = {
			-- Longbowman tiers now in the military Archer age-selector above.
			_row("Abbey King (Feudal)",       "unit_abbey_king_2",           "infantry"),
			_row("Wynguard Army (Imperial)",  "unit_wynguard_army_eng",      "infantry"),
			_row("Wynguard Footman (Imp.)",   "unit_footman_wynguard_4_eng", "infantry"),
			_row("Wynguard Ranger (Imp.)",    "unit_ranger_wynguard_4_eng",  "ranged"),
		},
	},

	french = {
		-- knight_min_t=2: Royal Knight (unit_knight_2_fre) merged into the
		-- 3-tier military Knight selector (Feudal → Castle → Imperial).
		military = _shared_european_military("fre", nil, 2),
		economy  = _shared_european_economy("fre"),
		unique   = {
			-- Royal Knight: now in military Knight age selector (Feudal→Castle→Imperial).
			-- Arbaletrier: unit_crossbowman_4_fre is the military Crossbowman Imperial tier;
			-- BP_GetSquadUIInfo resolves its label as "Arbaletrier" for French.
			_row("Cannon (Imperial)",          "unit_cannon_4_fre",       "siege"),
		},
	},

	hre = {
		-- manatarms_min_t=2: HRE Man-at-Arms starts at Feudal Age (unit_manatarms_2_hre confirmed).
		military = _shared_european_military("hre", nil, nil, 2),
		economy  = {
			_row("Villager",                "unit_villager_1_hre",               "land"),
			_row("Prelate (Dark)",          "unit_monk_1_hre",                   "land"),
			_row("Trade Cart",              "unit_trade_cart_hre",               "land"),
			_row("Fishing Boat",            "unit_naval_fishing_boat_2_hre",     "naval"),
			_row("Trade Ship",              "unit_naval_trade_ship_3_hre",       "naval"),
		},
		unique   = {
			-- Landsknecht: Castle+Imperial 2-tier selector (unit_landsknecht_4_hre confirmed).
			_row("Landsknecht (Castle)",       "unit_landsknecht_3_hre",   "infantry"),
			_row("Landsknecht (Imperial)",     "unit_landsknecht_4_hre",   "infantry"),
			_row("Black Rider (Imperial)",     "unit_black_rider_hre",     "ranged"),
		},
	},

	rus = {
		-- knight_min_t=2: Rus Knight starts at Feudal Age (unit_knight_2_rus confirmed).
		military = _shared_european_military("rus", nil, 2),
		economy  = _shared_european_economy("rus"),
		unique   = {
			-- Streltsy removed: unit_handcannon_4_rus is the military Handcannoneer.
			-- BP_GetSquadUIInfo resolves its label as "Streltsy" for Rus.
