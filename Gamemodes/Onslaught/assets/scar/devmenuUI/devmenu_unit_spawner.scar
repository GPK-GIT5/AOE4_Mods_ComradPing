-- ---------------------------------------------------------------
-- Subgroup metadata for the rendered cards.
-- The DEV-menu submenu render path uses entry.group / entry.group_label
-- / entry.group_sort to lay out groups within a section.
-- ---------------------------------------------------------------

local _MIL_SUB_LABEL = {
	infantry = "Infantry",
	ranged   = "Ranged",
	cavalry  = "Cavalry",
	siege    = "Siege",
	naval    = "Naval",
}
local _MIL_SUB_SORT = {
	infantry = 110, ranged = 120, cavalry = 130, siege = 140, naval = 150,
}
local _ECO_SUB_LABEL = {
	land  = "Land Economy",
	naval = "Naval Economy",
}
local _ECO_SUB_SORT = {
	land = 210, naval = 220,
}

-- Tag display priority for 2-tag badge chips on unit cards.
-- Cavalry always renders first (10); Unique always renders last (90).
local _TAG_DISPLAY_PRIORITY = {
	cavalry = 10, infantry = 20, ranged = 30, siege = 40, naval = 50, land = 60, unique = 90,
}

-- Build the hint/badge string shown on a unit card.
-- sub = primary tag (string). extra = optional second tag string (from row.tags).
-- is_unique: when true, injects "unique" as the last tag in the badge.
local function _tags_hint(sub, extra, is_unique)
	local parts = {}
	if sub   and sub   ~= "" then table.insert(parts, sub)   end
	if extra and extra ~= "" then table.insert(parts, extra) end
	if is_unique then
		local has_u = false
		for _, p in ipairs(parts) do if p == "unique" then has_u = true; break end end
		if not has_u then table.insert(parts, "unique") end
	end
	table.sort(parts, function(a, b)
		return (_TAG_DISPLAY_PRIORITY[a] or 50) < (_TAG_DISPLAY_PRIORITY[b] or 50)
	end)
	local out = {}
	for _, v in ipairs(parts) do table.insert(out, string.upper(v)) end
	return table.concat(out, " · ")
end

-- ---------------------------------------------------------------
-- Dispatch table: per-card index -> SBP name. Built at submenu
-- creation time; consumed by per-card global wrappers.
-- ---------------------------------------------------------------
_devmenu_unit_spawner_dispatch      = {} -- [idx] = sbp_name (string)
_devmenu_unit_spawner_dispatch_name = {} -- [idx] = display name (string)
_devmenu_unit_spawner_dispatch_type = {} -- [idx] = type tag ("naval", "land", "infantry", etc.)

-- Per-card click handlers are pre-generated up to a hard cap.
-- Catalog audit (2026-05-15): shared_european_military emits tier chains
-- (spearman 1–4, archer 2–4, horseman 2–4, etc.) adding ~250 rows across 9 civs.
-- Comprehensive cross-civ audit (2026-05-16): all multi-tier units verified and
-- expanded across every civ (mongol, abbasid, ottoman, sultanate, malian, japanese,
-- sengoku, lancaster, templar, sultanate_ha_tug, byzantine, chinese). +~200 rows.
-- Cap raised from 600 → 1200 to accommodate full catalog + future DLC headroom.
local _DEVMENU_UNIT_SPAWNER_DISPATCH_CAP = 1200

-- ---------------------------------------------------------------
-- Spawn Panel history (newest first, max _DEVMENU_SPAWN_HISTORY_MAX).
-- Populated on every unit selection regardless of spawn success.
-- ---------------------------------------------------------------
_devmenu_spawn_history     = {}
_DEVMENU_SPAWN_HISTORY_MAX = 3

-- Push an SBP to the front of the Spawn Panel history, deduplicate,
-- trim to max, then notify the Spawn Panel to refresh its DC.
function DevMenu_SpawnPanel_Record(sbp_name, display_name)
	if type(sbp_name) ~= "string" or sbp_name == "" then return end
	-- Remove any duplicate entry with the same SBP so it moves to front.
	for i = #_devmenu_spawn_history, 1, -1 do
		if _devmenu_spawn_history[i].sbp == sbp_name then
			table.remove(_devmenu_spawn_history, i)
		end
	end
	table.insert(_devmenu_spawn_history, 1, {
		sbp  = sbp_name,
		name = display_name or sbp_name,
	})
	while #_devmenu_spawn_history > _DEVMENU_SPAWN_HISTORY_MAX do
		table.remove(_devmenu_spawn_history)
	end
	if type(DevMenu_SpawnPanel_Refresh) == "function" then
		DevMenu_SpawnPanel_Refresh()
	end
end

local function _make_spawner_dispatcher(idx)
	local fn_name = "DevMenu_UnitSpawner_Click_" .. tostring(idx)
	if type(_G[fn_name]) == "function" then
		return fn_name
	end
	_G[fn_name] = function()
		local sbp  = _devmenu_unit_spawner_dispatch[idx]
		if type(sbp) ~= "string" or sbp == "" then
			print("[DEVMENU-SPAWNER] click " .. tostring(idx) .. ": no SBP bound")
			return
		end
		local name = _devmenu_unit_spawner_dispatch_name
			and _devmenu_unit_spawner_dispatch_name[idx]
		DevMenu_UnitSpawner_Spawn(sbp, name)
	end
	return fn_name
end

-- ---------------------------------------------------------------
-- Spawn entry point: MP-safe via DEVMENU_SPAWN_UNIT network dispatch.
-- Respects _devmenu.spawn_group_count (1–8).
-- ---------------------------------------------------------------
function DevMenu_UnitSpawner_Spawn(sbp_name, display_name)
	if type(sbp_name) ~= "string" or sbp_name == "" then return end
	-- Record selection immediately so Spawn Panel history is updated
	-- regardless of whether the spawn actually succeeds.
	DevMenu_SpawnPanel_Record(sbp_name, display_name or sbp_name)
	local player = nil
	if type(_devmenu_local_player) == "function" then
		player = _devmenu_local_player()
	elseif type(Game_GetLocalPlayer) == "function" then
		player = Game_GetLocalPlayer()
	end
	if player == nil then
		print("[DEVMENU-SPAWNER] spawn: no local player")
		return
	end
	local count = (_devmenu and type(_devmenu.spawn_group_count) == "number"
		and _devmenu.spawn_group_count >= 1) and _devmenu.spawn_group_count or 1
	local use_cam = _devmenu and _devmenu.spawn_at_camera == true
	-- Resolve spawn position up-front: camera target (cam mode) or town centre.
	-- _devmenu_camera_forward_pos(-40) offsets 40 units toward the camera from the
	-- focal point — the same position used by Teleport Selected and DoSpawnArmyAtCamera.
	-- Used by both the MP serialization path and the SP direct-call path.
	local spawn_pos = nil
	if use_cam and type(_devmenu_camera_forward_pos) == "function" then
		spawn_pos = _devmenu_camera_forward_pos(-40)
	end
	if spawn_pos == nil and type(GetTownCentrePosition) == "function" then
		spawn_pos = GetTownCentrePosition(player)
	end
	-- MP path: route through lockstep network bus. Returns true in MP.
	-- Cam mode: serialize the camera position into the message so all peers
	-- spawn at the same world coordinates (mirrors DevMenu_DoSpawnArmyAtCamera).
	if type(_devmenu_mp_net_action) == "function" then
		local dispatched = false
		if use_cam and spawn_pos ~= nil then
			local ok_x, cx = pcall(function() return spawn_pos.x end)
			local ok_y, cy = pcall(function() return spawn_pos.y end)
			local ok_z, cz = pcall(function() return spawn_pos.z end)
			if ok_x and ok_y and ok_z and type(cx) == "number" then
				local coord_str = string.format("%.4f %.4f %.4f", cx, cy, cz)
				dispatched = _devmenu_mp_net_action(player, "DEVMENU_SPAWN_UNIT_CAM",
					sbp_name .. " " .. tostring(count) .. " " .. coord_str)
			end
		end
		if not dispatched then
			dispatched = _devmenu_mp_net_action(player, "DEVMENU_SPAWN_UNIT", sbp_name .. " " .. tostring(count))
		end
		if dispatched then
			if type(DevMenu_ShowToast) == "function" then
				DevMenu_ShowToast("Spawning ×" .. tostring(count) .. ": " .. sbp_name)
			end
			return
		end
	end
	-- SP fallback: direct call.
	if type(SpawnUnitBPForPlayer) ~= "function" then
		print("[DEVMENU-SPAWNER] spawn SP: SpawnUnitBPForPlayer unavailable")
		return
	end
	if spawn_pos == nil then
		print("[DEVMENU-SPAWNER] spawn SP: no spawn position (no town centre, cam unavailable)")
		return
	end
	for i = 1, count do
		local ok, err = pcall(SpawnUnitBPForPlayer, sbp_name, player, spawn_pos, true)
		if not ok then
			print("[DEVMENU-SPAWNER] spawn SP failed (i=" .. i .. "): sbp=" .. tostring(sbp_name) .. " err=" .. tostring(err))
			break
		end
	end
	if type(DevMenu_ShowToast) == "function" then
		DevMenu_ShowToast("Spawned ×" .. tostring(count) .. ": " .. sbp_name)
	end
end

-- ---------------------------------------------------------------
-- Unit metadata helper: try BP_GetSquadUIInfo to get the localized
-- screenName and helpText for a unit blueprint. Returns two values:
--   screenName (utf8_mt LocString or nil)
--   helpText   (utf8_mt LocString on nil)
-- Failures are silent (bad SBP, no race_pbg, engine not ready).
-- ---------------------------------------------------------------

-- Manual display-name overrides for units whose localized screenName contains
-- characters unsupported by the SCAR UI text renderer (e.g. accented letters).
-- Key: exact SBP name string. Value: ASCII-safe replacement label.
local _SPAWNER_NAME_OVERRIDE = {
	-- French Imperial Crossbowman: BP screenName is "Arbal\195\169trier" (with accent).
	-- The SCAR text renderer cannot display 'é'; use the plain ASCII fallback.
	["unit_crossbowman_4_fre"] = "Arbaletrier",
}

-- One-shot diagnostic flag; set true after first successful LocString probe.
local _spawner_meta_probe_done = false

local function _spawner_get_unit_meta(sbp_name, race_pbg)
	if type(sbp_name) ~= "string" or sbp_name == "" then return nil, nil end
	if type(BP_GetSquadBlueprint) ~= "function" or type(BP_GetSquadUIInfo) ~= "function" then
		return nil, nil
	end
	local ok1, sbp_pbg = pcall(BP_GetSquadBlueprint, sbp_name)
	if not ok1 or sbp_pbg == nil then return nil, nil end
	local ok2, uiinfo = pcall(BP_GetSquadUIInfo, sbp_pbg, race_pbg)
	-- BP_GetSquadUIInfo returns a C++ struct as userdata (not a Lua table).
	-- Only reject on failure or explicit nil return.
	if not ok2 or uiinfo == nil then return nil, nil end
	-- screenName and helpText are utf8_mt LocString userdata.
	-- Converted via the file-level _loc_to_str helper (defined before AuditIconFull).
	local sn = _loc_to_str(uiinfo.screenName)
	local ht = _loc_to_str(uiinfo.helpText)
	-- Apply ASCII-safe override for units with unsupported display characters.
	local name_override = _SPAWNER_NAME_OVERRIDE[sbp_name]
	if name_override then sn = name_override end
	-- One-shot probe: log the first resolved values so we can verify
	-- real text is flowing (not fallback hardcoded names).
	if not _spawner_meta_probe_done then
		_spawner_meta_probe_done = true
		print("[SPAWNER-META] probe sbp=" .. sbp_name
			.. " screenName=" .. tostring(sn)
			.. " helpText_len=" .. tostring(ht ~= nil and #ht or 0))
	end
	return sn, ht
end

-- Roman numeral labels keyed by the SBP tier digit (age number).
-- Used by the tier-selector tab buttons.
local _SBP_TIER_ROMAN = { ["1"] = "I", ["2"] = "II", ["3"] = "III", ["4"] = "IV" }

-- ---------------------------------------------------------------
-- Tier card XAML builder.
-- Builds a containing Grid cell (2 rows: card body + tier row).
-- tier_count: 2 or 3 → UniformGrid tabs; 4 → prev/label/next stepper.
-- The card body is structurally identical to _DEVMENU_BUILD_CARD_XAML
-- but with a reduced MinHeight to leave room for the tier strip.
-- ---------------------------------------------------------------
local function _build_spawner_tier_card_xaml(idx, grid_row, grid_col, tier_count)
	local n = tostring(idx)
	local nc = tostring(tier_count)
	-- Card body: same bindings as standard card but MinHeight reduced.
	local card_body =
		'<Button Command="{Binding [cmd_' .. n .. ']}"' ..
		' Tag="{Binding [kind_' .. n .. ']}"' ..
		' Style="{StaticResource DevMenuCardButtonStyle}"' ..
		' Visibility="{Binding [vis_' .. n .. '], Converter={StaticResource BoolToVis}}">' ..
			'<Grid>' ..
				'<Grid.RowDefinitions>' ..
					'<RowDefinition Height="Auto" />' ..
					'<RowDefinition Height="6" />' ..
					'<RowDefinition Height="*" />' ..
				'</Grid.RowDefinitions>' ..
				'<Grid.ColumnDefinitions>' ..
					'<ColumnDefinition Width="Auto" />' ..
					'<ColumnDefinition Width="*" />' ..
				'</Grid.ColumnDefinitions>' ..
				'<Border Grid.Row="0" Grid.ColumnSpan="2" HorizontalAlignment="Right" CornerRadius="3" Padding="5,1" Background="#443A506B">' ..
					'<TextBlock Text="{Binding [hint_' .. n .. ']}" FontSize="9" Foreground="#CFE6FF" FontWeight="SemiBold" />' ..
				'</Border>' ..
				'<Image Grid.Row="2" Grid.Column="0" Source="{Binding [icon_' .. n .. ']}" Width="36" Height="36"' ..
					' VerticalAlignment="Top" Margin="0,0,8,0" />' ..
				'<StackPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Top">' ..
					'<TextBlock Text="{Binding [label_' .. n .. ']}"' ..
						' FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF" TextWrapping="Wrap" LineStackingStrategy="BlockLineHeight" LineHeight="15" />' ..
					'<TextBlock Text="{Binding [desc_' .. n .. ']}"' ..
						' FontSize="11" Foreground="#99AABB" TextWrapping="Wrap" Margin="0,3,0,0" LineStackingStrategy="BlockLineHeight" LineHeight="13" />' ..
					'<TextBlock Text="{Binding [note_' .. n .. ']}"' ..
						' FontSize="10" Foreground="#7FB3FF" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0" Visibility="{Binding [note_vis_' .. n .. '], Converter={StaticResource BoolToVis}}" LineStackingStrategy="BlockLineHeight" LineHeight="12" />' ..
					'<TextBlock Text="{Binding [state_' .. n .. ']}"' ..
						' FontSize="10" Foreground="#B8FFD2" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" MinHeight="12" />' ..
					'<TextBlock Text="&#x1F512; LOCKED"' ..
						' FontSize="10" FontWeight="Bold" Foreground="#AAAACC"' ..
						' Margin="0,4,0,0" TextWrapping="NoWrap"' ..
						' Visibility="{Binding [locked_vis_' .. n .. '], Converter={StaticResource BoolToVis}}" />' ..
					'<TextBlock Text="&#x1F512; MP LOCKED"' ..
						' FontSize="10" FontWeight="Bold" Foreground="#FFAA44"' ..
						' Margin="0,4,0,0" TextWrapping="NoWrap"' ..
						' Visibility="{Binding [mplocked_vis_' .. n .. '], Converter={StaticResource BoolToVis}}" />' ..
				'</StackPanel>' ..
			'</Grid>' ..
		'</Button>'

	-- Tier strip: 2–4 tiers → UniformGrid tabs; 5+ tiers → stepper.
	local tier_strip
	if tier_count <= 4 then
		local tabs = ""
		for t = 1, tier_count do
			local ts = tostring(t)
			tabs = tabs ..
				'<Button Tag="{Binding [tact_' .. n .. '_' .. ts .. ']}"' ..
				' Command="{Binding [tcmd_' .. n .. '_' .. ts .. ']}"' ..
				' Style="{StaticResource TierTabStyle}">' ..
					'<TextBlock Text="{Binding [tlbl_' .. n .. '_' .. ts .. ']}"' ..
						' FontSize="10" FontWeight="SemiBold" Foreground="#E8F4FF"' ..
						' HorizontalAlignment="Center" VerticalAlignment="Center" />' ..
				'</Button>'
		end
		tier_strip =
			'<Border Background="#0E1520" CornerRadius="0,0,4,4"' ..
			' BorderBrush="#33557788" BorderThickness="1,0,1,1" Padding="2,2"' ..
			' Visibility="{Binding [tvis_' .. n .. '], Converter={StaticResource BoolToVis}}">' ..
				'<UniformGrid Columns="' .. nc .. '" Rows="1">' ..
					tabs ..
				'</UniformGrid>' ..
			'</Border>'
	else
		-- 4-tier stepper: prev / label / next
		tier_strip =
			'<Border Background="#0E1520" CornerRadius="0,0,4,4"' ..
			' BorderBrush="#33557788" BorderThickness="1,0,1,1" Padding="2,2"' ..
			' Visibility="{Binding [tvis_' .. n .. '], Converter={StaticResource BoolToVis}}">' ..
				'<Grid Height="26">' ..
					'<Grid.ColumnDefinitions>' ..
						'<ColumnDefinition Width="30" />' ..
						'<ColumnDefinition Width="*" />' ..
						'<ColumnDefinition Width="30" />' ..
					'</Grid.ColumnDefinitions>' ..
					'<Button Grid.Column="0" Command="{Binding [tcmd_' .. n .. '_prev]}"' ..
						' Style="{StaticResource StepperBtnStyle}" ToolTip="Previous age">' ..
						'<TextBlock Text="&#x2039;" FontSize="15" FontWeight="Bold" Foreground="#6699AA"' ..
							' HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>' ..
					'<Border Grid.Column="1" BorderBrush="#33557788" BorderThickness="1,0">' ..
						'<TextBlock Text="{Binding [tsel_label_' .. n .. ']}" FontSize="11" FontWeight="Bold"' ..
							' Foreground="#FFD54F" HorizontalAlignment="Center" VerticalAlignment="Center"' ..
							' TextOptions.TextFormattingMode="Display" /></Border>' ..
					'<Button Grid.Column="2" Command="{Binding [tcmd_' .. n .. '_next]}"' ..
						' Style="{StaticResource StepperBtnStyle}" ToolTip="Next age">' ..
						'<TextBlock Text="&#x203A;" FontSize="15" FontWeight="Bold" Foreground="#6699AA"' ..
							' HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>' ..
				'</Grid>' ..
			'</Border>'
	end

	return
		'<Grid Grid.Row="' .. tostring(grid_row) .. '" Grid.Column="' .. tostring(grid_col) .. '" Margin="6,6">' ..
			'<Grid.RowDefinitions>' ..
				'<RowDefinition Height="*" />' ..
				'<RowDefinition Height="Auto" />' ..
			'</Grid.RowDefinitions>' ..
			'<Grid Grid.Row="0">' ..
				card_body ..
			'</Grid>' ..
			'<Grid Grid.Row="1">' ..
				tier_strip ..
			'</Grid>' ..
		'</Grid>'
end

-- ---------------------------------------------------------------
-- Catalog → submenu rows
--
-- For each civ, generate flat submenu rows with section/group/sort
-- metadata that the existing _devmenu_build_dev_submenu_panel
-- consumes. Section key is `civ_<civ_internal_name>`; groups are
-- "military_<sub>" / "economy_<sub>" / "unique" (or "unique_<sub>"
-- when the civ has 8+ uniques).
--
-- race_pbg: optional RacePBG for the local player, used to resolve
-- localized screenName/helpText via BP_GetSquadUIInfo.
-- ---------------------------------------------------------------

local function _build_civ_rows(civ_internal, civ_data, dispatch_cursor, race_pbg)
	local rows = {}
	local section_key = "civ_" .. civ_internal

	local function _add(entry, idx, sbp_name, type_tag)
		_devmenu_unit_spawner_dispatch[idx]      = sbp_name
		_devmenu_unit_spawner_dispatch_name[idx] = tostring(entry.label or sbp_name)
		_devmenu_unit_spawner_dispatch_type[idx] = type_tag or "land"
		_make_spawner_dispatcher(idx)
		entry.action = "DevMenu_UnitSpawner_Click_" .. tostring(idx)
		entry.section = section_key
		table.insert(rows, entry)
	end

	-- ---------------------------------------------------------------
	-- DC key helper used by tier-selector closures.
	--
	-- After _devmenu_build_section applies a suffix (e.g.
	-- "_civ_jin_dynasty_military_siege"), every card binding key becomes
	-- "base_key_<suffix>" in both the XAML and the stored DC.  The tier
	-- selector closures are built here — before the suffix is known —
	-- so they cannot compute the suffixed names directly.
	--
	-- This helper writes `val` to:
	--   dc[base_key]              — the plain unsuffixed key
	--   dc[base_key .. "_" .. *]  — every suffixed variant present in dc
	--
	-- Because we test for the literal "_" separator, "label_5_foo" is
	-- correctly matched for base_key="label_5" but "label_50_foo" is not
	-- (the 9th character would be "0", not "_").
	-- ---------------------------------------------------------------
	local function _spawner_dc_set_all_variants(dc, base_key, val)
		dc[base_key] = val
		local pfx = base_key .. "_"
		local pfx_len = #pfx
		for k in pairs(dc) do
			if #k > pfx_len and k:sub(1, pfx_len) == pfx then
				dc[k] = val
			end
		end
	end

	-- ---------------------------------------------------------------
	-- Resolve a list of catalog rows into one or more submenu entries,
	-- grouping consecutive rows that share the same base token + sub
	-- into a single tier-selector card.
	--
	-- catalog_rows  : list of { name, sbp, sub } tables (from the catalog)
	-- hint_for_sub  : function(sub) → hint string for single entries
	-- is_unique      : whether these rows are from the "unique" table
	-- group_key_fn  : function(sub) → group key string
	-- group_label_fn: function(sub) → group label string
	-- group_desc_fn : function(sub) → group desc string
	-- group_sort_fn : function(sub) → group sort int
	-- sort_fn       : function(sub) → card sort int
	-- ---------------------------------------------------------------
	local function _flush_rows(catalog_rows, hint_for_sub, is_unique,
			group_key_fn, group_label_fn, group_desc_fn, group_sort_fn, sort_fn)

		-- Group consecutive rows by (base_token, sub).
		-- We scan linearly; whenever (base_token, sub) changes, flush the
		-- accumulated group.
		local groups = {}      -- list of { base, sub, rows={…} }
		local cur_base, cur_sub, cur_group

		local function _flush_cur()
			if cur_group and #cur_group.rows > 0 then
				table.insert(groups, cur_group)
			end
			cur_group = nil; cur_base = nil; cur_sub = nil
		end

		for _, row in ipairs(catalog_rows) do
			local _, base = _sbp_base_token(row.sbp)
			local sub = row.sub or "infantry"
			if base ~= cur_base or sub ~= cur_sub then
				_flush_cur()
				cur_base  = base
				cur_sub   = sub
				cur_group = { base = base, sub = sub, tags = row.tags, rows = {} }
			end
			table.insert(cur_group.rows, row)
		end
		_flush_cur()

		-- Emit one entry per group.
		for _, grp in ipairs(groups) do
			local sub    = grp.sub
			local n_tiers = #grp.rows

			if n_tiers == 1 then
				-- Single entry: no tier selector.
				local row = grp.rows[1]
				dispatch_cursor = dispatch_cursor + 1
				local sn, ht = _spawner_get_unit_meta(row.sbp, race_pbg)
				local gk = group_key_fn(sub, grp.base)
				local entry = {
					label       = sn or row.name,
					desc        = ht or (is_unique and "UNIQUE" or (hint_for_sub and hint_for_sub(sub) or sub)),
					icon        = _spawner_unit_icon(row.sbp, _DEVMENU_UNIT_SPAWNER_GROUP_ICON[gk] or _DEVMENU_ICON_DEFAULT),
					group       = gk,
					group_label = group_label_fn(sub, grp.base),
					group_desc  = group_desc_fn(sub, grp.base),
					group_sort  = group_sort_fn(sub, grp.base),
					sort        = sort_fn(sub, grp.base),
					hint        = _tags_hint(sub, grp.tags, is_unique),
					locked      = (sub == "naval"),
				}
				_add(entry, dispatch_cursor, row.sbp, sub)
			else
				-- Tier group (2–4 tiers): ONE dispatch slot, tier selector row.
				dispatch_cursor = dispatch_cursor + 1
				local idx = dispatch_cursor

				-- Use metadata from the first tier for the card face.
				local first_row = grp.rows[1]
				local sn, ht = _spawner_get_unit_meta(first_row.sbp, race_pbg)
				local gk = group_key_fn(sub, grp.base)

				-- Build tier data: labels (age-matched Roman numerals), SBP list, and per-tier icons.
				local tier_sbps   = {}
				local tier_names  = {}
				local tier_labels = {}
				local tier_icons  = {}
				local _group_icon_fallback = _DEVMENU_UNIT_SPAWNER_GROUP_ICON[gk] or _DEVMENU_ICON_DEFAULT
				for _, r in ipairs(grp.rows) do
					-- Reuse _sbp_base_token which returns "base_tier" as with_tier;
					-- extract the trailing digit from that token for the Roman label.
					local with_tier, _ = _sbp_base_token(r.sbp)
					local tier_digit = with_tier and with_tier:match("_(%d+)$") or nil
					table.insert(tier_sbps,   r.sbp)
					local r_sn = _spawner_get_unit_meta(r.sbp, race_pbg)
					table.insert(tier_names,  r_sn and tostring(r_sn) or r.name)
					table.insert(tier_labels, _SBP_TIER_ROMAN[tier_digit] or "?")
					table.insert(tier_icons,  _spawner_unit_icon(r.sbp, _group_icon_fallback))
				end

				-- Register tier-select global handlers.
				-- Each handler: updates dispatch[idx] and refreshes DC tier state.
				--
				-- dc_idx_ref: shared mutable cell whose .val is populated by the XAML
				-- builder function at card build time (_devmenu_build_cards passes the
				-- entry-list position as didx).  TierSel closures MUST use dc_idx_ref.val
				-- for DC key names — NOT the dispatch_cursor idx — because
				-- _build_spawner_tier_card_xaml uses the entry-list position for all
				-- binding key names (tact_N_T, state_N, label_N, etc.).
				local dc_idx_ref = { val = idx, suffix = "" }  -- default = dispatch cursor + no suffix; both set at build time
				for t = 1, n_tiers do
					local t_copy   = t
					local sbp_copy = tier_sbps[t]
					local nm_copy  = tier_names[t]
					local ic_copy  = tier_icons[t]
					local fn_key   = "DevMenu_UnitSpawner_TierSel_" .. idx .. "_" .. t
					_G[fn_key] = function()
						_devmenu_unit_spawner_dispatch[idx]      = sbp_copy
						_devmenu_unit_spawner_dispatch_name[idx] = nm_copy
						local dc = _devmenu and _devmenu.dev_submenu_data_contexts
							and _devmenu.dev_submenu_data_contexts["unit_spawner"]
						if dc == nil then return end
						-- Exact-key writes prevent cross-section contamination: multiple sections
						-- each number their entries from 1, so _spawner_dc_set_all_variants on
						-- "state_3" would hit every section's pos-3 key. Write only the two
						-- keys that belong to this specific card (unsuffixed + suffixed).
						local di  = dc_idx_ref.val
						local suf = dc_idx_ref.suffix
						for tt = 1, n_tiers do
							local tact_key = "tact_" .. di .. "_" .. tt
							local tact_val = (tt == t_copy) and "active" or ""
							dc[tact_key] = tact_val
							if suf ~= "" then dc[tact_key .. suf] = tact_val end
						end
						-- Update the unit icon, name, and age badge to the selected tier.
						local icon_key = "icon_" .. di
						dc[icon_key] = ic_copy
						if suf ~= "" then dc[icon_key .. suf] = ic_copy end
						local label_key = "label_" .. di
						dc[label_key] = nm_copy
						if suf ~= "" then dc[label_key .. suf] = nm_copy end
						local state_key = "state_" .. di
						local state_val = "AGE " .. (tier_labels[t_copy] or tostring(t_copy))
						dc[state_key] = state_val
						if suf ~= "" then dc[state_key .. suf] = state_val end
						UI_SetDataContext("DevMenuDEVSubmenu_unit_spawner", dc)
					end
				end

				-- Register stepper handlers for 5+ tier variant (currently theoretical).
				if n_tiers > 4 then
					local sel_ref = { val = 1 }   -- mutable closure cell
					local function _update_stepper(new_sel, dc)
						sel_ref.val = new_sel
						_devmenu_unit_spawner_dispatch[idx]      = tier_sbps[new_sel]
						_devmenu_unit_spawner_dispatch_name[idx] = tier_names[new_sel]
						local di  = dc_idx_ref.val
						local suf = dc_idx_ref.suffix
						local tsel_key = "tsel_label_" .. di
						local tsel_val = tier_labels[new_sel] or tostring(new_sel)
						dc[tsel_key] = tsel_val
						if suf ~= "" then dc[tsel_key .. suf] = tsel_val end
						-- Update the unit icon, name, the stepper label, and the age badge to the selected tier.
						local icon_key = "icon_" .. di
						local icon_val = tier_icons[new_sel]
						dc[icon_key] = icon_val
						if suf ~= "" then dc[icon_key .. suf] = icon_val end
						local label_key = "label_" .. di
						local label_val = tier_names[new_sel]
						dc[label_key] = label_val
						if suf ~= "" then dc[label_key .. suf] = label_val end
						local state_key = "state_" .. di
						local state_val = "AGE " .. (tier_labels[new_sel] or tostring(new_sel))
						dc[state_key] = state_val
						if suf ~= "" then dc[state_key .. suf] = state_val end
						UI_SetDataContext("DevMenuDEVSubmenu_unit_spawner", dc)
					end
					_G["DevMenu_UnitSpawner_TierPrev_" .. idx] = function()
						local dc = _devmenu and _devmenu.dev_submenu_data_contexts
							and _devmenu.dev_submenu_data_contexts["unit_spawner"]
						if dc == nil then return end
						local new_sel = ((sel_ref.val - 2) % n_tiers) + 1
						_update_stepper(new_sel, dc)
					end
					_G["DevMenu_UnitSpawner_TierNext_" .. idx] = function()
						local dc = _devmenu and _devmenu.dev_submenu_data_contexts
							and _devmenu.dev_submenu_data_contexts["unit_spawner"]
						if dc == nil then return end
						local new_sel = (sel_ref.val % n_tiers) + 1
						_update_stepper(new_sel, dc)
					end
				end

				-- Build the per-entry card XAML builder function name.
				-- Registered globally so _devmenu_build_cards can call it.
				-- IMPORTANT: also captures dc_idx_ref so the entry-list position (didx)
				-- is recorded at build time, enabling TierSel closures to target the
				-- correct DC keys when they fire later.
				local xaml_fn_name = "DevMenu_UnitSpawner_TierCard_" .. idx
				local n_tiers_copy = n_tiers
				_G[xaml_fn_name] = function(didx, grow, gcol, section_suffix)
					dc_idx_ref.val    = didx                   -- entry-list position for TierSel DC key writes
					dc_idx_ref.suffix = section_suffix or ""   -- section suffix for exact-key writes (prevents cross-section contamination)
					return _build_spawner_tier_card_xaml(didx, grow, gcol, n_tiers_copy)
				end

				-- Tier-selector DC data (consumed by _devmenu_build_cards tier block).
				local tier_cmds = {}
				if n_tiers <= 4 then
					for t = 1, n_tiers do
						tier_cmds[t] = "DevMenu_UnitSpawner_TierSel_" .. idx .. "_" .. t
					end
				else
					-- Stepper uses prev/next keys for 5+ tier units (theoretical).
					tier_cmds[1] = "DevMenu_UnitSpawner_TierPrev_" .. idx
					tier_cmds[2] = "DevMenu_UnitSpawner_TierNext_" .. idx
				end

				local entry = {
					label        = sn or first_row.name,
					desc         = ht or (is_unique and "UNIQUE" or (hint_for_sub and hint_for_sub(sub) or sub)),
					icon         = tier_icons[1],
					group        = gk,
					group_label  = group_label_fn(sub, grp.base),
					group_desc   = group_desc_fn(sub, grp.base),
					group_sort   = group_sort_fn(sub, grp.base),
					sort         = sort_fn(sub, grp.base),
					hint         = _tags_hint(sub, grp.tags, is_unique),
					locked       = (sub == "naval"),
					-- Tier selector state (picked up by _devmenu_build_cards).
					tier_vis     = true,
					tier_count   = n_tiers,
					tier_data    = {
						count  = n_tiers,
						labels = tier_labels,
						sel    = 1,
						cmds   = tier_cmds,
					},
					card_xaml_fn = xaml_fn_name,
				}
				-- Seed dispatch slot with the first tier's SBP.
				_devmenu_unit_spawner_dispatch[idx]      = tier_sbps[1]
				_devmenu_unit_spawner_dispatch_name[idx] = tier_names[1]
				_devmenu_unit_spawner_dispatch_type[idx] = sub
				_make_spawner_dispatcher(idx)
				entry.action  = "DevMenu_UnitSpawner_Click_" .. idx
				entry.section = section_key
				-- Seed age state label so the green row shows the initial age on first render.
				entry.state_init = "AGE " .. (tier_labels[1] or "I")
				-- For 5+ tier stepper, seed the stepper label binding key.
				if n_tiers > 4 then
					entry.tsel_label_init = tier_labels[1]
				end
				table.insert(rows, entry)
			end
		end
	end

	-- Military: Infantry/Ranged/Cavalry merged into one group; Siege and Naval are separate.
	local _MIL_MERGE    = { infantry = true, ranged = true, cavalry = true }
	-- Fine-grained sort within the merged Military group: keyed on SBP base token.
	-- Spearman → MaA (infantry); Archer → Crossbow → Handcannon (ranged);
	-- Horseman → Knight (cavalry). Tokens not listed fall back to _MIL_SUB_FALLBACK.
	-- Unique unit base tokens are also listed here so within-subsection ordering
	-- matches the equivalent standard-unit position (Iron Pagoda ≈ knight, etc.).
	local _MIL_BASE_SORT = {
		-- Infantry
		spearman            = 100,
		heavy_spearman      = 105,
		manatarms           = 110,
		serjeant            = 115,
		condottiero         = 120,
		-- Ranged
		archery             = 200,
		archer              = 200,
		yeoman              = 205,
		crossbow            = 210,
		crossbowman         = 210,
		genoese_crossbow    = 212,
		handcannon          = 220,
		-- Cavalry
		horseman            = 300,
		hobelar             = 305,
		genitour            = 306,
		chevalier_confrere  = 308,
		knight              = 310,
		-- Unique unit equivalents (sorted by equivalent role position)
		gbeto               = 108,  -- Malian light infantry ≈ between spearman and manatarms
		kharash             = 108,  -- Golden Horde light infantry ≈ between spearman and manatarms
		samurai             = 110,  -- heavy infantry ≈ manatarms
		earlsguard          = 110,  -- Lancaster heavy infantry ≈ manatarms
		freebornwarrior     = 112,
		kanabo              = 113,  -- heavy infantry ≈ manatarms
		zhanma_swordsman    = 114,  -- heavy infantry ≈ manatarms
		javelin             = 205,  -- ranged ≈ archer/yeoman
		mansa_javelin       = 206,
		eruptor             = 220,  -- Jin ranged ≈ handcannon
		horsearcher         = 301,  -- cavalry archer ≈ horseman
		sipahi              = 302,  -- light cavalry ≈ horseman
		camel_archer        = 303,  -- cavalry archer ≈ horseman
		war_elephant        = 312,  -- heavy cavalry ≈ knight
		camel_rider         = 312,  -- heavy cavalry ≈ knight
		iron_pagoda         = 310,  -- Jin sole knight-equivalent (no standard knight in Jin catalog)
		daimyo              = 310,  -- Sengoku sole knight-equivalent
		ming_guard          = 310,  -- Zhu Xi sole knight-equivalent
		knight_templar      = 314,
		knight_hospitaller  = 314,
		szlachta_knight     = 316,
	}
	-- Sub-tag fallback for base tokens not listed in _MIL_BASE_SORT.
	local _MIL_SUB_FALLBACK = { infantry = 150, ranged = 250, cavalry = 350 }
	-- Offset added to unique-unit sort values when mixing into the standard military group
	-- (< 4 unique units: no dedicated subsection). Ensures unique cards always sort last.
	local _UNIQUE_SORT_OFFSET = 600

	_flush_rows(civ_data.military or {}, function(sub) return _MIL_SUB_LABEL[sub] or sub end, false,
		function(sub)
			local merged = _MIL_MERGE[sub]
			return merged and "military" or ("military_" .. sub)
		end,
		function(sub) return _MIL_MERGE[sub] and "Military" or (_MIL_SUB_LABEL[sub] or sub) end,
		function(sub)
			return _MIL_MERGE[sub] and "Infantry, Cavalry, and Ranged units."
				or ((_MIL_SUB_LABEL[sub] or sub) .. " units.")
		end,
		function(sub) return _MIL_MERGE[sub] and 100 or (_MIL_SUB_SORT[sub] or 140) end,
		function(sub, base)
			if _MIL_MERGE[sub] then
				return _MIL_BASE_SORT[base] or _MIL_SUB_FALLBACK[sub] or 199
			end
			return _MIL_SUB_SORT[sub] or 199
		end
	)

	-- Economy: land/naval split.
	_flush_rows(civ_data.economy or {}, function(sub) return _ECO_SUB_LABEL[sub] or sub end, false,
		function(sub) return "economy_" .. sub end,
		function(sub) return _ECO_SUB_LABEL[sub] or sub end,
		function(_sub) return "Economy units." end,
		function(_sub) return 200 end,
		function(sub) return (_ECO_SUB_SORT[sub] or 299) end
	)

	-- Unique: tagged "UNIQUE".
	-- When a civ has 4+ unique unit-groups, a dedicated "Unique Units" subsection is
	-- created (group_sort=160, after siege=140 and naval=150). With fewer than 4 unique
	-- units the cards merge into the standard military group and a +600 sort offset
	-- guarantees they always appear after all standard units.
	local function _count_unique_groups(catalog_rows)
		local count, cur_base, cur_sub = 0, nil, nil
		for _, row in ipairs(catalog_rows) do
			local _, base = _sbp_base_token(row.sbp)
			local sub = row.sub or "infantry"
			if base ~= cur_base or sub ~= cur_sub then
				count = count + 1
				cur_base = base; cur_sub = sub
			end
		end
		return count
	end
	local unique_groups = _count_unique_groups(civ_data.unique or {})
	local use_unique_subsection = (unique_groups >= 4)

	-- Collect the standard sort positions already covered by this civ's military units.
	-- Sole-role-replacement detection uses this to know when a unique unit is the ONLY
	-- representative of a standard cavalry position (e.g. no knight → iron_pagoda fills it).
	local covered_mil_sort = {}
	for _, row in ipairs(civ_data.military or {}) do
		local _, base = _sbp_base_token(row.sbp)
		local pos = _MIL_BASE_SORT[base]
		if pos then covered_mil_sort[pos] = true end
	end

	-- Unique units that are the SOLE representative of a standard military role:
	-- when no standard unit occupies that sort position for this civ, the unique unit
	-- is placed in the Military group at that exact position (no unique subsection,
	-- no +600 offset) so it appears where a knight/etc. would in other civs.
	local _SOLE_ROLE_SORT = {
		iron_pagoda = 310,  -- Jin sole knight-equivalent
		daimyo      = 310,  -- Sengoku sole knight-equivalent
		ming_guard  = 310,  -- Zhu Xi sole knight-equivalent
	}

	_flush_rows(civ_data.unique or {}, function(_sub) return "UNIQUE" end, true,
		function(sub, base)
			if sub == "land" then return "economy_land" end
			local role_pos = _SOLE_ROLE_SORT[base]
			if role_pos and not covered_mil_sort[role_pos] then
				return _MIL_MERGE[sub] and "military" or ("military_" .. sub)
			end
			if use_unique_subsection then return "military_unique" end
			return _MIL_MERGE[sub] and "military" or ("military_" .. sub)
		end,
		function(sub, base)
			if sub == "land" then return _ECO_SUB_LABEL[sub] or sub end
			local role_pos = _SOLE_ROLE_SORT[base]
			if role_pos and not covered_mil_sort[role_pos] then
				return _MIL_MERGE[sub] and "Military" or (_MIL_SUB_LABEL[sub] or sub)
			end
			if use_unique_subsection then return "Unique Units" end
			return _MIL_MERGE[sub] and "Military" or (_MIL_SUB_LABEL[sub] or sub)
		end,
		function(sub, base)
			if sub == "land" then return "Economy units." end
			local role_pos = _SOLE_ROLE_SORT[base]
			if role_pos and not covered_mil_sort[role_pos] then
				return _MIL_MERGE[sub] and "Infantry, Cavalry, and Ranged units."
					or ((_MIL_SUB_LABEL[sub] or sub) .. " units.")
			end
			if use_unique_subsection then return "Civilization-specific unique units." end
			return _MIL_MERGE[sub] and "Infantry, Cavalry, and Ranged units."
				or ((_MIL_SUB_LABEL[sub] or sub) .. " units.")
		end,
		function(sub, base)
			if sub == "land" then return 200 end
			local role_pos = _SOLE_ROLE_SORT[base]
			if role_pos and not covered_mil_sort[role_pos] then
				return _MIL_MERGE[sub] and 100 or (_MIL_SUB_SORT[sub] or 140)
			end
			if use_unique_subsection then return 160 end
			return _MIL_MERGE[sub] and 100 or (_MIL_SUB_SORT[sub] or 140)
		end,
		function(sub, base)
			if sub == "land" then return (_ECO_SUB_SORT[sub] or 299) end
			local base_sort = _MIL_BASE_SORT[base] or _MIL_SUB_FALLBACK[sub] or 199
			-- Sole role replacement: sort at the exact standard position (no offset).
			local role_pos = _SOLE_ROLE_SORT[base]
			if role_pos and not covered_mil_sort[role_pos] then
				return role_pos
			end
			if use_unique_subsection then
				-- Dedicated subsection: sort by equivalent base-unit position (no offset).
				return base_sort
			end
			-- Mixed into military: add offset so unique cards always follow standard units.
			return base_sort + _UNIQUE_SORT_OFFSET
		end
	)

	return rows, dispatch_cursor
end

-- Build the synthetic category that the DEV-menu submenu render path
-- will consume. Recomputed on every Open so the player's current civ
-- floats to the top section.
function DevMenu_UnitSpawner_BuildCategory()
	-- Reset the per-build dispatch table to avoid index drift between
	-- successive opens (catalog edits or civ-order changes).
	_devmenu_unit_spawner_dispatch      = {}
	_devmenu_unit_spawner_dispatch_name = {}
	_devmenu_unit_spawner_dispatch_type = {}

	-- Determine player civ for "player first" ordering and for the page
	-- subtitle ("Local player civ: <Display Name>").
	local local_civ = nil
	if type(Game_GetLocalPlayer) == "function" and type(Player_GetRaceName) == "function" then
		local p = Game_GetLocalPlayer()
		if p ~= nil then
			local ok, race = pcall(Player_GetRaceName, p)
			if ok and race ~= nil and race ~= "" then
				local_civ = race
			end
		end
	end

	-- Resolve RacePBG for the local player so _build_civ_rows can call
	-- BP_GetSquadUIInfo to obtain localized screenName / helpText.
	-- NOTE: pcall(Player_GetRace, p) direct form silently returns nil in the SCAR runtime
	-- for DLC civs; the closure form pcall(function() ... end) works correctly.
	-- Fallback: BP_GetRaceBlueprint(parent_civ) for non-DLC civs in offline/pre-game contexts.
	local race_pbg = nil
	do
		local p = type(Game_GetLocalPlayer) == "function" and Game_GetLocalPlayer() or nil
		if p ~= nil and type(Player_GetRace) == "function" then
			pcall(function() race_pbg = Player_GetRace(p) end)
		end
		-- Fallback: BP_GetRaceBlueprint for pre-game / offline contexts.
		if race_pbg == nil and local_civ ~= nil and type(BP_GetRaceBlueprint) == "function" then
			local ok_rpbg, rpbg = pcall(BP_GetRaceBlueprint, local_civ)
			if ok_rpbg and rpbg ~= nil then race_pbg = rpbg end
		end
	end
	print("[SPAWNER-INIT] BuildCategory: local_civ=" .. tostring(local_civ)
		.. " race_pbg=" .. (race_pbg ~= nil and "OK" or "nil")
		.. " BP_GetSquadBlueprint=" .. tostring(type(BP_GetSquadBlueprint))
		.. " BP_GetSquadUIInfo=" .. tostring(type(BP_GetSquadUIInfo)))

	-- Civ render order: player's civ first, then default order, dedup'd.
	local order = {}
	local seen  = {}
	if local_civ ~= nil and _DEVMENU_UNIT_SPAWNER_CATALOG[local_civ] ~= nil then
		table.insert(order, local_civ)
		seen[local_civ] = true
	end
	for _, civ in ipairs(_DEVMENU_UNIT_SPAWNER_CIV_ORDER_DEFAULT) do
		if not seen[civ] and _DEVMENU_UNIT_SPAWNER_CATALOG[civ] ~= nil then
			table.insert(order, civ)
			seen[civ] = true
		end
	end
	-- Catch any catalog civs not in the default order (forward-compat).
	for civ, _ in pairs(_DEVMENU_UNIT_SPAWNER_CATALOG) do
		if not seen[civ] then
			table.insert(order, civ)
			seen[civ] = true
		end
	end

	-- Register section meta + section order for each civ. Insert into the
	-- DEV-menu render tables (now globals) so the existing pipeline picks
	-- up titles, subtitles, and pill labels without further changes.
	local flag_base       = _DEVMENU_RACE_FLAG_BASE
		or "pack://application:,,,/WPFGUI;component/images/civ_flags/flag_"
	local flag_overrides  = _DEVMENU_RACE_FLAG_OVERRIDES or { sultanate = "sultanates" }
	-- Tier 1.5: For DLC civs active in the current game, use World_GetRaceIcon which
	-- returns the authoritative engine path (not in _PlayerUI_RaceImage which only has
	-- the 10 base civs). Built once per BuildCategory() call by iterating active players.
	local _civ_flag_from_world = {}
	if type(Player_GetRaceName) == "function" and type(Player_GetRace) == "function"
		and type(World_GetRaceIcon) == "function"
		and type(PlayerUI_AdaptIconPathForXaml) == "function" then
		local all_players = _PlayerUI_AllPlayers or {}
		for _, p in ipairs(all_players) do
			local ok_r, race = pcall(Player_GetRaceName, p)
			if ok_r and race and race ~= "" and not _civ_flag_from_world[race] then
				local ok_bp, race_bp = pcall(Player_GetRace, p)
				if ok_bp and race_bp then
					local ok_icon, icon_path = pcall(World_GetRaceIcon, race_bp)
					if ok_icon and icon_path and icon_path ~= "" then
						_civ_flag_from_world[race] = PlayerUI_AdaptIconPathForXaml(icon_path)
					end
				end
			end
		end
	end
	for _, civ in ipairs(order) do
		local key  = "civ_" .. civ
		local name = _DEVMENU_UNIT_SPAWNER_CIV_DISPLAY[civ] or civ
		-- Resolve flag URI:
		-- Tier 0 = _DEVMENU_UNIT_SPAWNER_CIV_ICON: per-civ override (DLC civs
		--          that have no civ_flags/ image; uses an emblematic unit icon).
		-- Tier 1 = _PlayerUI_RaceImage (10 base civs; provably correct pack:// paths).
		-- Tier 1.5 = World_GetRaceIcon from active player (DLC civs in this game).
		-- Tier 2 = path construction (offline DLC civs, modded civs).
		local flag_uri
		if _DEVMENU_UNIT_SPAWNER_CIV_ICON[civ] ~= nil then
			flag_uri = _DEVMENU_UNIT_SPAWNER_CIV_ICON[civ]
		elseif type(_PlayerUI_RaceImage) == "table" and _PlayerUI_RaceImage[civ] ~= nil then
			flag_uri = _PlayerUI_RaceImage[civ]
		elseif _civ_flag_from_world[civ] ~= nil then
			flag_uri = _civ_flag_from_world[civ]
		else
			local flag_key = flag_overrides[civ] or civ
			flag_uri = flag_base .. tostring(flag_key) .. ".png"
		end
		local prefix = (civ == local_civ) and "★ " or ""
		_DEVMENU_SUBMENU_SECTION_META[key] = {
			title    = prefix .. name,
			subtitle = (civ == local_civ)
				and "Your civilization. Click any card to spawn one unit at your Keep."
				or  ("Spawn units from " .. name .. " (regardless of in-game presence)."),
			icon     = flag_uri,
		}
		-- Append to render order if not already present (don't duplicate).
		local already = false
		for _, k in ipairs(_DEVMENU_SUBMENU_SECTION_ORDER) do
			if k == key then already = true; break end
		end
		if not already then
			table.insert(_DEVMENU_SUBMENU_SECTION_ORDER, key)
		end
	end
	-- Move the player's civ section to the front of the order so it
	-- renders first (the existing submenu builder honours
	-- _DEVMENU_SUBMENU_SECTION_ORDER strictly).
	if local_civ ~= nil then
		local first_key = "civ_" .. local_civ
		local kept = { first_key }
		for _, k in ipairs(_DEVMENU_SUBMENU_SECTION_ORDER) do
			if k ~= first_key then table.insert(kept, k) end
		end
		_DEVMENU_SUBMENU_SECTION_ORDER = kept
	end

	-- Build flat submenu rows.
	local submenu_rows  = {}
	local cursor        = 0
	local _spawner_tier_group_count = 0
	local _spawner_single_count     = 0
	for _, civ in ipairs(order) do
		local civ_data = _DEVMENU_UNIT_SPAWNER_CATALOG[civ]
		if civ_data ~= nil then
			local before_cursor = cursor
			local rows, new_cursor = _build_civ_rows(civ, civ_data, cursor, race_pbg)
			cursor = new_cursor
			for _, r in ipairs(rows) do
				table.insert(submenu_rows, r)
				if r.tier_vis then
					_spawner_tier_group_count = _spawner_tier_group_count + 1
				else
					_spawner_single_count = _spawner_single_count + 1
				end
			end
			if cursor >= _DEVMENU_UNIT_SPAWNER_DISPATCH_CAP then
				print("[DEVMENU-SPAWNER] dispatch cap (" .. tostring(_DEVMENU_UNIT_SPAWNER_DISPATCH_CAP) .. ") hit; truncating catalog")
				break
			end
		end
	end
	print("[SPAWNER-INIT] rows built: total=" .. tostring(#submenu_rows)
		.. " single=" .. tostring(_spawner_single_count)
		.. " tier_groups=" .. tostring(_spawner_tier_group_count))

	local cat_subtitle = "Spawn one unit per click at your Keep. MP-safe (routed via lockstep network)."
	if local_civ ~= nil and _DEVMENU_UNIT_SPAWNER_CIV_DISPLAY[local_civ] ~= nil then
		cat_subtitle = "Local civilization: " .. _DEVMENU_UNIT_SPAWNER_CIV_DISPLAY[local_civ]
			.. ". Spawn one unit per click at your Keep. MP-safe."
	end

	local cat = {
		key     = "unit_spawner",
		label   = "Unit Spawner Menu",
		desc    = cat_subtitle,
		icon    = _DEVMENU_ICON_DEFAULT,
		submenu = submenu_rows,
	}

	-- Register in the global category index so _devmenu_ensure_submenu_presenter
	-- can find it. Also append to _DEVMENU_DEV_CATEGORIES so any (future) DEV-menu
	-- listing that iterates the categories list sees this entry too.
	_DEVMENU_DEV_CATEGORY_INDEX = _DEVMENU_DEV_CATEGORY_INDEX or {}
	_DEVMENU_DEV_CATEGORY_INDEX["unit_spawner"] = cat
	_DEVMENU_DEV_CATEGORIES = _DEVMENU_DEV_CATEGORIES or {}
	local in_list = false
	for _, c in ipairs(_DEVMENU_DEV_CATEGORIES) do
		if c.key == "unit_spawner" then
			-- Replace in place so a re-init refreshes the submenu rows.
			c.submenu = cat.submenu
			c.desc    = cat.desc
			in_list   = true
			break
		end
	end
	if not in_list then
		table.insert(_DEVMENU_DEV_CATEGORIES, cat)
	end

	return cat
end

-- ---------------------------------------------------------------
-- Init: registers the category once so the open handler is bound.
-- Called from devmenu.scar :: _devmenu_create_ui_now after the CHEAT
-- panel is created (regardless of dev-mode gate).
-- ---------------------------------------------------------------
function DevMenu_UnitSpawner_Init()
	DevMenu_UnitSpawner_BuildCategory()
	-- Bind DevMenu_OpenCategory_unit_spawner so it routes through
	-- DevMenu_OpenSubmenuByKey if anything else (or future code paths)
	-- triggers via the standard DEV-menu category-card name. We do NOT
	-- rely on this for the CHEAT-menu flow — DevMenu_UnitSpawner_Open
	-- below is the canonical entry point — but it's cheap to register.
	if type(_devmenu_bind_category_open_handlers) == "function" then
		_devmenu_bind_category_open_handlers({ _DEVMENU_DEV_CATEGORY_INDEX["unit_spawner"] })
	end
	print("[DEVMENU-SPAWNER] init complete: catalog civs=" .. tostring(_devmenu_table_count(_DEVMENU_UNIT_SPAWNER_CATALOG)))
end

-- Tiny helper because Lua has no built-in for "count keys in a hash".
function _devmenu_table_count(t)
	if type(t) ~= "table" then return 0 end
	local n = 0
	for _ in pairs(t) do n = n + 1 end
	return n
end

-- ---------------------------------------------------------------
-- Open / Back / Close
--
-- Open is invoked from the CHEAT panel's "Unit Spawner Menu" entry.
-- Back returns to the CHEAT panel (NOT to the DEV categories panel,
-- which doesn't exist in lobby-cheats-only mode). Close hides both
-- the submenu AND the CHEAT panel.
-- ---------------------------------------------------------------

function DevMenu_UnitSpawner_Open()
	if _devmenu == nil or not _devmenu.is_ui_created then
		print("[DEVMENU-SPAWNER] Open: UI not ready")
		return
	end
	-- Rebuild the catalog so the player's current civ floats to the top
	-- on every open (handles late race resolution and re-host scenarios).
	DevMenu_UnitSpawner_BuildCategory()

	-- Drop any cached presenter so the freshly-built rows + section meta
	-- take effect. The submenu render path keys off `dev_submenu_data_contexts`
	-- so clearing it forces _devmenu_ensure_submenu_presenter to rebuild.
	_devmenu.dev_submenu_data_contexts["unit_spawner"] = nil

	-- Lazy-create the presenter. This calls _devmenu_build_dev_submenu_panel
	-- under the hood and adds a XamlPresenter named DevMenuDEVSubmenu_unit_spawner.
	if type(_devmenu_ensure_submenu_presenter) ~= "function"
		or not _devmenu_ensure_submenu_presenter("unit_spawner") then
		print("[DEVMENU-SPAWNER] Open: ensure_submenu_presenter failed")
		return
	end

	local dc = _devmenu.dev_submenu_data_contexts["unit_spawner"]
	if dc == nil then
		print("[DEVMENU-SPAWNER] Open: missing presenter DC after ensure")
		return
	end

	-- Override Back/Close so they return to the CHEAT panel instead of the
	-- DEV categories panel (which is only created in dev mode).
	dc.cmd_back  = UI_CreateCommand("DevMenu_UnitSpawner_Back")
	dc.cmd_close = UI_CreateCommand("DevMenu_UnitSpawner_Close")

	-- Hide CHEAT panel + any other open submenu, then show ours.
	if type(DevMenu_CloseCHEATPanel) == "function" then
		DevMenu_CloseCHEATPanel()
	end
	if type(_devmenu_hide_all_submenus) == "function" then
		_devmenu_hide_all_submenus()
	end
	dc.panel_visible = true
	UI_SetDataContext("DevMenuDEVSubmenu_unit_spawner", dc)
	_devmenu.dev_active_submenu_key = "unit_spawner"
	print("[DEVMENU-SPAWNER] opened (rows=" .. tostring(#((_DEVMENU_DEV_CATEGORY_INDEX["unit_spawner"] or {}).submenu or {})) .. ")")
end

function DevMenu_UnitSpawner_Back()
	if _devmenu == nil or not _devmenu.is_ui_created then return end
	if type(_devmenu_hide_all_submenus) == "function" then
		_devmenu_hide_all_submenus()
	end
	-- Show CHEAT panel.
	if _devmenu.cheat_panel_data_context ~= nil then
		_devmenu.cheat_panel_data_context.panel_visible = true
		UI_SetDataContext("DevMenuCHEATPanel", _devmenu.cheat_panel_data_context)
	end
end

function DevMenu_UnitSpawner_Close()
	if _devmenu == nil or not _devmenu.is_ui_created then return end
	if type(_devmenu_hide_all_submenus) == "function" then
		_devmenu_hide_all_submenus()
	end
	if type(DevMenu_CloseCHEATPanel) == "function" then
		DevMenu_CloseCHEATPanel()
	end
end
