-- Extract the base token and base-with-tier from an SBP name.
-- Pass 1: unit_<base>_<tier>_<civsuffix>  e.g. unit_knight_3_eng  -> ("knight_3", "knight")
-- Pass 2: strip a known DLC suffix (no tier in name) e.g. unit_trade_cart_chi -> ("trade_cart","trade_cart")
--         Handles multi-segment suffixes like abb_ha_01, byz_ha_mac, rus_mon.
--         Runs BEFORE Pass 3 so unit_ming_guard_chi_ha_01 strips "chi_ha_01" instead of treating "01" as a bare tier.
-- Pass 3: unit_<base>_<tier>               e.g. unit_abbey_king_2  -> ("abbey_king_2", "abbey_king")
local _KNOWN_SUFFIXES = {
	-- Multi-segment first (order matters - greedy match from start)
	"abb_ha_01", "chi_ha_01", "fre_ha_01", "hre_ha_01",
	"byz_ha_mac", "jpn_ha_sen", "sul_ha_tug",
	"rus_mon",
	-- Single-segment civ tags
	"chi", "eng", "fre", "hre", "mon", "rus", "abb", "mal",
	"ott", "sul", "byz", "ayy", "jpn", "lan", "tem", "jin",
}
local function _sbp_base_token(sbp)
	local s = sbp:match("^unit_(.+)$") or sbp
	-- Pass 1: standard unit_<base>_<tier>_<civsuffix>
	local base, tier = s:match("^(.-)_(%d+)_%a")
	if base and tier then
		return base .. "_" .. tier, base
	end
	-- Pass 2: strip known DLC suffix (no tier) — must run before digit-at-end pass
	for _, suf in ipairs(_KNOWN_SUFFIXES) do
		local stripped = s:match("^(.-)_" .. suf .. "$")
		if stripped and stripped ~= "" then
			return stripped, stripped
		end
	end
	-- Pass 3: tier at the end, no civ suffix (e.g. abbey_king_2)
	local base3, tier3 = s:match("^(.-)_(%d+)$")
	if base3 and tier3 then
		return base3 .. "_" .. tier3, base3
	end
	return s, s
end

-- When true, the runtime icon resolver logs unexpected fallbacks to scarlog:
--   [SPAWNER-ICON] FALLBACK – no table entry found; group icon used as fallback.
--     Should not fire if icons are complete. Run Icon Audit (DevMenu_UnitSpawner_AuditIconCoverage)
--     to diagnose missing entries.
-- Toggle off to suppress; the Icon Audit is the authoritative coverage check.
_DEVMENU_SPAWNER_ICON_TRACE = true

