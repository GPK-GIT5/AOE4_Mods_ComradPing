-----------------------------------------------------------------------
-- DevMenu Unit Spawner Menu
--
-- A Cheat-menu sub-page (mirrors the Stress Test Menu layout) that lets
-- the local player spawn one unit at a time at their Keep. Spawning is
-- routed through the lockstep network bus so the action is MP-safe.
--
--
-- Visible behaviour
-- -----------------
--   Cheat panel  →  "Unit Spawner Menu" entry  →  opens this sub-page
--   Sub-page     →  one section per civilization (player's civ first)
--                   each section groups units into Military / Economy /
--                   Unique. Military splits into Infantry / Ranged /
--                   Cavalry / Siege / Naval. Economy splits Naval into
--                   its own subgroup. Unique units use the Military
--                   subgroup structure ONLY when the civ has 8+ unique
--                   entries (matches the user-confirmed threshold).
--
-- Architecture
-- ------------
--   The page is rendered by the DEV-menu submenu builder
--   (_devmenu_build_dev_submenu_panel) — we register a synthetic
--   category in `_DEVMENU_DEV_CATEGORY_INDEX` keyed `unit_spawner`
--   and rely on the existing render path. The presenter is created
--   lazily on first open via _devmenu_ensure_submenu_presenter.
--
--   Each card's action is a per-index dispatcher
--   (`DevMenu_UnitSpawner_Click_<idx>`) generated at build time;
--   the dispatch table maps idx -> SBP name. Click → dispatch
--   → DevMenu_UnitSpawner_Spawn(sbp) → MP-safe network route.
--
-- MP safety
-- ---------
--   All spawns route via `_devmenu_mp_net_action(player, "DEVMENU_SPAWN_UNIT", sbp)`.
--   The MP handler (`_DEVMENU_NET_ACTIONS.DEVMENU_SPAWN_UNIT` in
--   devmenu_mp_gate.scar) calls SpawnUnitBPForPlayer at GetTownCentrePosition(pid)
--   on EVERY peer at the same sim tick — fully deterministic. The MP risk entry
--   `unit_spawner` is registered as MED.
-----------------------------------------------------------------------

-- ---------------------------------------------------------------
-- Section meta + ordering hooks (registered into the existing
-- DEV-menu submenu render tables; safe because we own the
-- `civ_<civname>` namespace and never collide with logging_*/whole_game/etc.)
-- ---------------------------------------------------------------

-- Civ display ordering used when the local player's civ cannot be detected
-- (initial render before lobby/race info is available). Player's civ is
-- always promoted to the front at sub-page build time.
_DEVMENU_UNIT_SPAWNER_CIV_ORDER_DEFAULT = {
	-- Base civs
	"english", "french", "hre", "mongol", "rus", "chinese", "abbasid", "malian",
	"ottoman", "sultanate", "byzantine", "japanese",
	-- Dynasties DLC (internal names returned by Player_GetRaceName)
	"abbasid_ha_01", "french_ha_01", "hre_ha_01", "chinese_ha_01",
	-- Knights DLC
	"jin_dynasty", "mongol_ha_gol", "lancaster", "templar",
	-- Sultan's Ascend DLC
	"byzantine_ha_mac", "japanese_ha_sen", "sultanate_ha_tug",
}

