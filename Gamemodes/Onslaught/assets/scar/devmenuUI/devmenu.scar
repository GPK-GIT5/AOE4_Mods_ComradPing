	},
	logging_onslaught = {
		title = "ONSLAUGHT",
		subtitle = "Core trace, precache, and runtime instrumentation channels.",
	},
	logging_systems = {
		title = "SYSTEMS",
		subtitle = "Gameplay-system logs and verbose debug variants layered on the master gates.",
	},
	logging_ui = {
		title = "UI",
		subtitle = "PlayerUI runtime and diagnostic output channels.",
	},
	whole_game = {
		title = "WHOLE GAMEMODE",
		subtitle = "Start here — every item tests or stresses the entire gamemode, not just one subsystem.",
	},
	ai = {
		title = "AI SYSTEM",
