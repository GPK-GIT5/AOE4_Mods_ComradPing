local function _devmenu_submenu_sort_value(value, fallback)
	local num = tonumber(value)
	if num ~= nil then
		return num
	end
	return fallback or 999999
end

local function _devmenu_sort_submenu_entries(a, b)
	local a_sort = _devmenu_submenu_sort_value(a and a.sort)
	local b_sort = _devmenu_submenu_sort_value(b and b.sort)
	if a_sort ~= b_sort then
		return a_sort < b_sort
	end
	local a_label = string.upper(tostring((a and a.label) or ""))
	local b_label = string.upper(tostring((b and b.label) or ""))
	return a_label < b_label
end

local function _devmenu_sort_submenu_groups(a, b)
	local a_sort = _devmenu_submenu_sort_value(a and a.sort)
	local b_sort = _devmenu_submenu_sort_value(b and b.sort)
	if a_sort ~= b_sort then
		return a_sort < b_sort
	end
	local a_label = string.upper(tostring((a and a.label) or ""))
	local b_label = string.upper(tostring((b and b.label) or ""))
	return a_label < b_label
end

local function _devmenu_render_submenu_section(menu_type, section_key, section_entries, dc)
	table.sort(section_entries, _devmenu_sort_submenu_entries)

	local grouped = {}
	local group_list = {}
	local ungrouped = {}
	local has_groups = false

	for _, entry in ipairs(section_entries or {}) do
		local group_key = entry.group
		if type(group_key) == "string" and group_key ~= "" then
			has_groups = true
			local group_record = grouped[group_key]
			if group_record == nil then
				group_record = {
					key = group_key,
					label = entry.group_label or string.upper(group_key),
					subtitle = entry.group_desc or "",
					sort = _devmenu_submenu_sort_value(entry.group_sort, _devmenu_submenu_sort_value(entry.sort)),
					entries = {},
				}
				grouped[group_key] = group_record
				table.insert(group_list, group_record)
			else
				local candidate_sort = _devmenu_submenu_sort_value(entry.group_sort, _devmenu_submenu_sort_value(entry.sort))
				if candidate_sort < group_record.sort then
					group_record.sort = candidate_sort
				end
				if group_record.subtitle == "" and type(entry.group_desc) == "string" and entry.group_desc ~= "" then
					group_record.subtitle = entry.group_desc
				end
			end
			table.insert(group_record.entries, entry)
		else
			table.insert(ungrouped, entry)
		end
	end

	local content_parts = {}
	local entry_count = 0

	if #ungrouped > 0 then
		local cards_xaml, _ = _devmenu_build_section(menu_type .. "_flat", ungrouped, "_flat", dc)
		table.insert(content_parts, _devmenu_wrap_cards_grid(cards_xaml))
		entry_count = entry_count + #ungrouped
	end

	if not has_groups then
		return table.concat(content_parts, "\n"), entry_count
	end

	table.sort(group_list, _devmenu_sort_submenu_groups)
	for _, group_record in ipairs(group_list) do
		table.sort(group_record.entries, _devmenu_sort_submenu_entries)
		local suffix = "_" .. section_key .. "_" .. group_record.key
		local cards_xaml, _ = _devmenu_build_section(menu_type .. suffix, group_record.entries, suffix, dc)
		table.insert(content_parts, _DEVMENU_BUILD_DEV_SUBMENU_GROUP_XAML(group_record.label, group_record.subtitle, cards_xaml))
		entry_count = entry_count + #group_record.entries
	end

	return table.concat(content_parts, "\n"), entry_count
end

-----------------------------------------------------------------------
-- DEV two-level navigation (categories + per-category submenus)
-----------------------------------------------------------------------

-- Build the L1 categories panel (with optional Top-3 Recent strip).
-- Returns (panel_xaml, dc, entry_count).
local function _devmenu_build_dev_categories_panel()
	local categories = _DEVMENU_DEV_CATEGORIES or {}
	local dc = {}

	-- CUSTOM section: explicitly curated, always unlocked.
	local custom_entries = {}
	local custom_keys = {
		logging = true,
		stress  = true,
	}
	-- OPEN MENU unlocked: appear in the Open Menu section as live (non-locked) cards.
	-- These are NOT in the custom section but ARE clickable (entry.locked is not set).
	-- debugger_tools is intentionally absent: it shows as a locked decorative card.
	local open_unlocked_keys = {
		spawner_debug  = true,
	}
	local logging_cat = _DEVMENU_DEV_CATEGORY_INDEX and _DEVMENU_DEV_CATEGORY_INDEX.logging
	if logging_cat ~= nil then
		table.insert(custom_entries, _devmenu_build_category_card_entry(logging_cat))
	end
	local stress_cat = _DEVMENU_DEV_CATEGORY_INDEX and _DEVMENU_DEV_CATEGORY_INDEX.stress
	if stress_cat ~= nil then
		table.insert(custom_entries, _devmenu_build_category_card_entry(stress_cat))
	end

	-- Remaining categories are split by behavior.
	-- Non-custom entries are flagged `locked = true` (decorative, NoOp on click)
	-- unless they are listed in open_unlocked_keys (live cards in Open Menu).
	local open_menu_entries = {}
	local run_now_entries = {}
	for _, cat in ipairs(categories) do
		if not custom_keys[cat.key] then
			local submenu = cat.submenu or {}
			local entry = _devmenu_build_category_card_entry(cat)
			if not open_unlocked_keys[cat.key] then
				entry.locked = true
			end
			if #submenu > 1 then
				table.insert(open_menu_entries, entry)
			else
				table.insert(run_now_entries, entry)
			end
		end
	end

	local custom_cards_xaml, custom_visible = _devmenu_build_section("devcustom", custom_entries, "_custom", dc)
	local open_cards_xaml, open_visible = _devmenu_build_section("devopen", open_menu_entries, "_open", dc)
	local run_cards_xaml, run_visible = _devmenu_build_section("devrun", run_now_entries, "_run", dc)
	local entry_count = #custom_entries + #open_menu_entries + #run_now_entries

	-- Recent strip (built only when artifact has at least one valid key).
	local recent_xaml = ""
	local recent_visible = "Collapsed"
	if _DEVMENU_DEV_RECENT and _DEVMENU_DEV_RECENT.keys and #_DEVMENU_DEV_RECENT.keys > 0 then
		local recent_entries = {}
		for _, key in ipairs(_DEVMENU_DEV_RECENT.keys) do
			local cat = _DEVMENU_DEV_CATEGORY_INDEX and _DEVMENU_DEV_CATEGORY_INDEX[key]
			if cat ~= nil then
				local e = _devmenu_build_category_card_entry(cat)
				e.label = "* " .. (e.label or cat.key)
				table.insert(recent_entries, e)
			end
		end
		if #recent_entries > 0 then
			local r_xaml, r_dc, _ = _devmenu_build_cards("devrecent", recent_entries)
			recent_xaml = r_xaml
			recent_xaml = _devmenu_suffix_card_bindings(recent_xaml, "_r")
			_devmenu_merge_dc_with_suffix(dc, r_dc, "_r")
			recent_visible = "Visible"
		end
	end

	dc.panel_visible = false
	dc.cmd_close     = UI_CreateCommand("DevMenu_CloseDEVPanel")

	local panel_xaml = _DEVMENU_BUILD_DEV_PANEL_XAML(
		recent_xaml,
		recent_visible,
		custom_cards_xaml,
		custom_visible,
		open_cards_xaml,
		open_visible,
		run_cards_xaml,
		run_visible
	)
	return panel_xaml, dc, entry_count
end

-- Build a single L2 submenu panel for a category.
-- Returns (panel_xaml, dc, entry_count).
local function _devmenu_build_dev_submenu_panel(cat)
	local entries = {}
	local sectioned_entries = {}
	local has_sections = false
	for _, item in ipairs(cat.submenu or {}) do
		local is_on = _devmenu_eval_toggle_state(item.toggle_state_fn)
		local kind = "action"
		local hint = item.hint or "RUN NOW"
		local state = ""
		if is_on ~= nil then
			kind = is_on and "toggle_on" or "toggle_off"
			hint = is_on and "TOGGLE: ON" or "TOGGLE: OFF"
			state = is_on and "ENABLED" or "DISABLED"
		end
		local entry = {
			label        = item.label or "?",
			desc         = item.desc  or "",
			icon         = item.icon or cat.icon or _DEVMENU_ICON_DEFAULT,
			action       = item.action,
			kind         = kind,
			hint         = hint,
			state        = state,
			mp_locked    = item.mp_locked == true,
			card_xaml_fn = item.card_xaml_fn,
		}
		local section_key = item.section
		local note_parts = {}
		if type(item.included_by) == "string" and item.included_by ~= "" then
			table.insert(note_parts, "Included in " .. item.included_by)
		end
		if type(item.warning) == "string" and item.warning ~= "" then
			table.insert(note_parts, item.warning)
		end
		entry.note = table.concat(note_parts, " | ")
		if type(section_key) == "string" and section_key ~= "" then
			has_sections = true
			if sectioned_entries[section_key] == nil then
				sectioned_entries[section_key] = {}
			end
			entry.sort = item.sort
			entry.group = item.group
			entry.group_label = item.group_label
			entry.group_desc = item.group_desc
			entry.group_sort = item.group_sort
			-- Tier fields: pass through from catalog entry verbatim.
			entry.tier_vis   = item.tier_vis
			entry.tier_count = item.tier_count
			entry.tier_data  = item.tier_data
			entry.state_init = item.state_init
			table.insert(sectioned_entries[section_key], entry)
		else
			table.insert(entries, entry)
		end
	end
	local menu_type = "devsub_" .. cat.key

	if has_sections then
		local dc = {}
		local body_parts = {}
		local entry_count = 0
		local consumed = {}
		local sections_present = {}  -- { {key, title}, ... } in display order

		-- Registers a section in the navigator, wraps its XAML in a visibility-gated
		-- StackPanel structure, and appends to body_parts.
		--   Outer: gated by sec_N_vis (filter gate or expanded = all visible).
		--   Header button: DevMenuSecHeaderStyle — click toggles sec_N_content_vis.
		--     Tag = "expanded"/"collapsed" drives chevron direction.
		--   Inner: gated by sec_N_content_vis — card content shown/hidden.
		--
		-- nav_pill_cmd_N  → SLOT index (1.._DEVMENU_PILL_WINDOW), window-relative.
		-- sec_header_cmd_N → ABSOLUTE section index N.
		local function _register_section(section_key, meta, cards_xaml, added_count)
			table.insert(sections_present, { key = section_key, title = meta.title })
			local sec_idx  = #sections_present
			local sec_n    = tostring(sec_idx)
			local hdr_fn   = _devmenu_make_sec_toggle_dispatcher(cat.key, sec_idx)
			dc["sec_header_cmd_"   .. sec_n] = UI_CreateCommand(hdr_fn)
			dc["sec_header_title_" .. sec_n] = meta.title or ""
			dc["sec_header_tag_"   .. sec_n] = (sec_idx == 1) and "expanded" or "collapsed"
			-- Optional icon support (used by Unit Spawner Menu civ sections; other
			-- sections leave icon_uri nil so the Image stays hidden).
			local icon_uri = (meta.icon ~= nil and meta.icon ~= "") and meta.icon or ""
			dc["sec_header_icon_"     .. sec_n] = icon_uri
			dc["sec_header_icon_vis_" .. sec_n] = icon_uri ~= ""
			local section_xaml = _DEVMENU_BUILD_DEV_SUBMENU_SECTION_XAML("", meta.subtitle, cards_xaml)
			table.insert(body_parts,
				'<StackPanel Visibility="{Binding [sec_' .. sec_n .. '_vis], Converter={StaticResource BoolToVis}}">' .. '\n' ..
				'<Button Command="{Binding [sec_header_cmd_' .. sec_n .. ']}" Tag="{Binding [sec_header_tag_' .. sec_n .. ']}" Style="{StaticResource DevMenuSecHeaderStyle}">' .. '\n' ..
				'<StackPanel Orientation="Horizontal">' .. '\n' ..
				'<Image Source="{Binding [sec_header_icon_' .. sec_n .. ']}" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center" Visibility="{Binding [sec_header_icon_vis_' .. sec_n .. '], Converter={StaticResource BoolToVis}}" />' .. '\n' ..
				'<TextBlock Text="{Binding [sec_header_title_' .. sec_n .. ']}" FontSize="11" FontWeight="SemiBold" Foreground="#B0C8E8" VerticalAlignment="Center" />' .. '\n' ..
				'</StackPanel>' .. '\n' ..
				'</Button>' .. '\n' ..
				'<StackPanel Visibility="{Binding [sec_' .. sec_n .. '_content_vis], Converter={StaticResource BoolToVis}}">' .. '\n' ..
				section_xaml ..
				'\n</StackPanel>\n' ..
				'</StackPanel>')
			entry_count = entry_count + added_count
		end

		for _, section_key in ipairs(_DEVMENU_SUBMENU_SECTION_ORDER) do
			local section_entries = sectioned_entries[section_key]
			if section_entries ~= nil and #section_entries > 0 then
				local cards_xaml, added_count = _devmenu_render_submenu_section(menu_type .. "_" .. section_key, section_key, section_entries, dc)
				local meta = _DEVMENU_SUBMENU_SECTION_META[section_key] or { title = string.upper(section_key), subtitle = "" }
				_register_section(section_key, meta, cards_xaml, added_count)
				consumed[section_key] = true
			end
		end

		local extra_keys = {}
		for section_key, section_entries in pairs(sectioned_entries) do
			if not consumed[section_key] and section_entries ~= nil and #section_entries > 0 then
				table.insert(extra_keys, section_key)
			end
		end
		table.sort(extra_keys)
		for _, section_key in ipairs(extra_keys) do
			local section_entries = sectioned_entries[section_key]
			local cards_xaml, added_count = _devmenu_render_submenu_section(menu_type .. "_" .. section_key, section_key, section_entries, dc)
			local meta = _DEVMENU_SUBMENU_SECTION_META[section_key] or { title = string.upper(section_key), subtitle = "" }
			_register_section(section_key, meta, cards_xaml, added_count)
		end

		if #entries > 0 then
			local cards_xaml, _ = _devmenu_build_section(menu_type .. "_other", entries, "_other", dc)
			_register_section("__other", { title = "OTHER", subtitle = "" }, cards_xaml, #entries)
		end

		-- Store section list; default to expanded (all sections visible) on
		-- first build. First section content visible; rest collapsed.
		_devmenu.dev_submenu_sections[cat.key] = sections_present
		local first_key = sections_present[1] and sections_present[1].key or nil
		if _devmenu.dev_active_section_by_cat[cat.key] == nil then
			_devmenu.dev_active_section_by_cat[cat.key] = first_key
		end
		if _devmenu.dev_section_expanded_by_cat[cat.key] == nil then
			_devmenu.dev_section_expanded_by_cat[cat.key] = true   -- all sections visible
		end
		if _devmenu.dev_sec_content_vis[cat.key] == nil then
			_devmenu.dev_sec_content_vis[cat.key] = _devmenu_default_sec_content_vis(sections_present)
		end
		if _devmenu.dev_pill_scroll_by_cat[cat.key] == nil then
			_devmenu.dev_pill_scroll_by_cat[cat.key] = 0
		end
		-- Pre-register pill slot commands (slots 1.._DEVMENU_PILL_WINDOW).
		for slot = 1, _DEVMENU_PILL_WINDOW do
			dc["nav_pill_cmd_" .. tostring(slot)] = UI_CreateCommand(_devmenu_make_nav_dispatcher(cat.key, slot))
		end
		local left_fn, right_fn = _devmenu_make_nav_scroll_dispatchers(cat.key)
		dc.nav_scroll_left_cmd  = UI_CreateCommand(left_fn)
		dc.nav_scroll_right_cmd = UI_CreateCommand(right_fn)
		_devmenu_update_submenu_nav_dc(
			dc, sections_present,
			_devmenu.dev_active_section_by_cat[cat.key],
			_devmenu.dev_section_expanded_by_cat[cat.key],
			_devmenu.dev_sec_content_vis[cat.key],
			_devmenu.dev_pill_scroll_by_cat[cat.key])
		dc.nav_expand_cmd = UI_CreateCommand(_devmenu_make_nav_expand_dispatcher(cat.key))

		dc.panel_visible = false
		dc.cmd_back  = UI_CreateCommand("DevMenu_BackToCategories")
		dc.cmd_close = UI_CreateCommand("DevMenu_CloseDEVAll")

		local panel_xaml = _DEVMENU_BUILD_DEV_SUBMENU_XAML(cat.label or cat.key, cat.desc or "", table.concat(body_parts, "\n"))
		return panel_xaml, dc, entry_count
	end

	local cards_xaml, dc, entry_count = _devmenu_build_cards(menu_type, entries)

	-- No sections: zero out nav DC keys so the strip and toggle are hidden.
	_devmenu.dev_submenu_sections[cat.key] = {}
	_devmenu_update_submenu_nav_dc(dc, {}, nil, true, nil, 0)
	dc.nav_expand_cmd       = UI_CreateCommand("DevMenu_NoOp")
	dc.nav_scroll_left_cmd  = UI_CreateCommand("DevMenu_NoOp")
	dc.nav_scroll_right_cmd = UI_CreateCommand("DevMenu_NoOp")

	dc.panel_visible = false
	dc.cmd_back  = UI_CreateCommand("DevMenu_BackToCategories")
	dc.cmd_close = UI_CreateCommand("DevMenu_CloseDEVAll")

	local panel_xaml = _DEVMENU_BUILD_DEV_SUBMENU_XAML(cat.label or cat.key, cat.desc or "", _devmenu_wrap_cards_grid(cards_xaml))
	return panel_xaml, dc, entry_count
end

_devmenu_refresh_dynamic_cards = function(menu_type)
	-- Refresh the Quick Panel after any of its own clicks so toggle state
	-- chrome (Invuln/FoW/Instant Build) reflects the new ON/OFF value.
	if menu_type == "cheatquick" then
		if not _devmenu.is_ui_created or _devmenu.quick_panel_data_context == nil then
			return
		end
		local visible = _devmenu.quick_panel_data_context.panel_visible
		local _, dc, count = _devmenu_build_quick_panel(_DEVMENU_ENTRIES or {})
		dc.panel_visible = visible
		_devmenu.quick_panel_data_context = dc
		_devmenu.quick_panel_entry_count  = count
		UI_SetDataContext("DevMenuCHEATQuickPanel", dc)
		-- Cross-refresh the CHEAT modal so toggle-state chrome (ON/OFF colour,
		-- state label) stays in sync when a toggle is clicked from the Quick Panel.
		if _devmenu.cheat_panel_data_context ~= nil and _DEVMENU_ENTRIES ~= nil then
			local cvisible = _devmenu.cheat_panel_data_context.panel_visible
			local _, cdc, ccount = _devmenu_build_cheat_panel_categorized(_DEVMENU_ENTRIES)
			cdc.panel_visible = cvisible
			_devmenu.cheat_panel_data_context = cdc
			_devmenu.cheat_entry_count = ccount
			UI_SetDataContext("DevMenuCHEATPanel", cdc)
		end
		return
	end

	if menu_type ~= "dev" and menu_type ~= "devrecent" and menu_type ~= "devcustom" and menu_type ~= "devopen" and menu_type ~= "devrun" and not string.find(menu_type or "", "^devsub_") and not string.find(menu_type or "", "^cheat_cat_") then
		return
	end
	if not _devmenu.is_ui_created then
		return
	end

	if menu_type == "dev" or menu_type == "devrecent" or menu_type == "devcustom" or menu_type == "devopen" or menu_type == "devrun" then
		if _devmenu.dev_panel_data_context == nil then
			return
		end
		local visible = _devmenu.dev_panel_data_context.panel_visible
		local panel_xaml, dc, entry_count = _devmenu_build_dev_categories_panel()
		dc.panel_visible = visible
		_devmenu.dev_panel_data_context = dc
		_devmenu.dev_entry_count = entry_count
		UI_SetDataContext("DevMenuDEVPanel", dc)
		return
	end

	if string.find(menu_type or "", "^cheat_cat_") then
		-- Rebuild the whole categorized CHEAT panel so toggle-state chrome
		-- (ON/OFF colour, state label) refreshes after any toggle click.
		if _devmenu.cheat_panel_data_context == nil then return end
		local visible = _devmenu.cheat_panel_data_context.panel_visible
		local _, dc, count = _devmenu_build_cheat_panel_categorized(_DEVMENU_ENTRIES or {})
		dc.panel_visible = visible
		_devmenu.cheat_panel_data_context = dc
		_devmenu.cheat_entry_count = count
		UI_SetDataContext("DevMenuCHEATPanel", dc)
		-- Also refresh the quick panel in case any quick-panel-mirrored toggle
		-- was activated from the modal (e.g. Invuln, FoW, Instant Build).
		if _devmenu.quick_panel_data_context ~= nil then
			local qvisible = _devmenu.quick_panel_data_context.panel_visible
			local _, qdc, qcount = _devmenu_build_quick_panel(_DEVMENU_ENTRIES or {})
			qdc.panel_visible = qvisible
			_devmenu.quick_panel_data_context = qdc
			_devmenu.quick_panel_entry_count  = qcount
			UI_SetDataContext("DevMenuCHEATQuickPanel", qdc)
		end
		return
	end

	if string.find(menu_type or "", "^devsub_") then
		local key = string.gsub(menu_type, "^devsub_", "")
		local dc_existing = _devmenu.dev_submenu_data_contexts[key]
		local cat = _DEVMENU_DEV_CATEGORY_INDEX and _DEVMENU_DEV_CATEGORY_INDEX[key]
		if dc_existing == nil or cat == nil then
			return
		end
		local visible = dc_existing.panel_visible
		local sub_xaml, sub_dc, _ = _devmenu_build_dev_submenu_panel(cat)
		sub_dc.panel_visible = visible
		-- Restore whichever section the user was viewing AND the expanded state
		-- before the rebuild. The build path already seeds default-expanded for
		-- first-time opens; this branch only matters after a toggle-driven rebuild.
		local active_key = _devmenu.dev_active_section_by_cat[key]
		local expanded   = _devmenu.dev_section_expanded_by_cat[key]
		if expanded == nil then expanded = true end
		if active_key ~= nil then
			local secs = _devmenu.dev_submenu_sections[key]
			if secs ~= nil then
				local still_present = false
				for _, s in ipairs(secs) do
					if s.key == active_key then still_present = true; break end
				end
				if still_present then
					_devmenu_update_submenu_nav_dc(
						sub_dc, secs, active_key, expanded,
						_devmenu.dev_sec_content_vis[key],
						_devmenu.dev_pill_scroll_by_cat[key] or 0)
				end
			end
		end
		_devmenu.dev_submenu_data_contexts[key] = sub_dc
		UI_SetDataContext("DevMenuDEVSubmenu_" .. key, sub_dc)
		return
	end
end

local function _devmenu_bind_category_open_handlers(categories)
	for _, cat in ipairs(categories or {}) do
		local key_copy = cat.key
		_G["DevMenu_OpenCategory_" .. key_copy] = function()
			DevMenu_OpenSubmenuByKey(key_copy)
		end
	end
end

_devmenu_ensure_submenu_presenter = function(key)
	if _devmenu.dev_submenu_data_contexts[key] ~= nil then
		return true
	end
	local cat = _DEVMENU_DEV_CATEGORY_INDEX and _DEVMENU_DEV_CATEGORY_INDEX[key]
	if cat == nil then
		return false
	end
	local sub_xaml, sub_dc, _ = _devmenu_build_dev_submenu_panel(cat)
	_devmenu.dev_submenu_data_contexts[key] = sub_dc

	local presenter_name = "DevMenuDEVSubmenu_" .. key
	UI_AddChild("ScarDefault", "XamlPresenter", presenter_name, {
		IsHitTestVisible = true,
		Xaml             = sub_xaml,
		DataContext      = UI_CreateDataContext(sub_dc),
	})
	print("[DEVMENU] lazy submenu created key=" .. tostring(key))
	return true
end

-- Hide the L1 panel (used when navigating into a submenu).
local function _devmenu_hide_dev_categories()
	if _devmenu.dev_panel_data_context ~= nil then
		_devmenu.dev_panel_data_context.panel_visible = false
		UI_SetDataContext("DevMenuDEVPanel", _devmenu.dev_panel_data_context)
	end
end

-- Show the L1 panel.
local function _devmenu_show_dev_categories()
	if _devmenu.dev_panel_data_context ~= nil then
		_devmenu.dev_panel_data_context.panel_visible = true
		UI_SetDataContext("DevMenuDEVPanel", _devmenu.dev_panel_data_context)
	end
end

-- Hide every L2 submenu panel.
_devmenu_hide_all_submenus = function()
	for key, dc in pairs(_devmenu.dev_submenu_data_contexts) do
		if dc ~= nil and dc.panel_visible then
			dc.panel_visible = false
			UI_SetDataContext("DevMenuDEVSubmenu_" .. key, dc)
		end
	end
	_devmenu.dev_active_submenu_key = nil
end

-- Open a specific submenu (called by per-category dispatcher functions).
function DevMenu_OpenSubmenuByKey(key)
	if not _devmenu.is_ui_created then return end
	if _devmenu.dev_submenu_data_contexts[key] == nil then
		if not _devmenu_ensure_submenu_presenter(key) then
			print("[DEVMENU] OpenSubmenu: unknown category '" .. tostring(key) .. "'")
			return
		end
	end
	local dc = _devmenu.dev_submenu_data_contexts[key]
	if dc == nil then
		print("[DEVMENU] OpenSubmenu: unknown category '" .. tostring(key) .. "'")
		return
	end
	-- Always reset Back/Close to DEV-categories targets so a stale cmd_back
	-- from a prior Spawn Panel or CHEAT open does not misdirect navigation.
	dc.cmd_back  = UI_CreateCommand("DevMenu_BackToCategories")
	dc.cmd_close = UI_CreateCommand("DevMenu_CloseDEVAll")
	_devmenu_hide_all_submenus()
	_devmenu_hide_dev_categories()
	dc.panel_visible = true
	UI_SetDataContext("DevMenuDEVSubmenu_" .. key, dc)
	_devmenu.dev_active_submenu_key = key
end

-- Back navigation: close active submenu, return to categories.
-- Falls back to the Spawn Panel when the DEV panel has never been created
-- (CHEAT-only mode: spawner was opened from the Spawn Panel, not DEV categories).
function DevMenu_BackToCategories()
	if not _devmenu.is_ui_created then return end
	_devmenu_hide_all_submenus()
	if _devmenu.dev_panel_data_context ~= nil then
		_devmenu_show_dev_categories()
	elseif _devmenu.spawn_panel_enabled then
		DevMenu_ShowSpawnPanel()
	end
end

-- Close everything DEV (categories + any open submenu).
function DevMenu_CloseDEVAll()
	if not _devmenu.is_ui_created then return end
	_devmenu_hide_all_submenus()
	if _devmenu.dev_panel_data_context ~= nil then
		_devmenu.dev_panel_data_context.panel_visible = false
		UI_SetDataContext("DevMenuDEVPanel", _devmenu.dev_panel_data_context)
	end
end

local function _devmenu_create_ui_now(source)
	if _devmenu.is_ui_created then return end
	print("[DEVMENU] UI create begin (source=" .. tostring(source or "direct") .. ")")

	-- ===== CHEAT MENU =====
	-- Create CHEAT button.
	print("[DEVMENU] create phase 1/5: CHEAT button")
	_devmenu.cheat_btn_data_context = {
		cmd_cheat = UI_CreateCommand("DevMenu_ToggleCHEATPanel"),
	}
	UI_AddChild("ScarDefault", "XamlPresenter", "DevMenuCHEATButton", {
		IsHitTestVisible = true,
		Xaml             = _DEVMENU_BTN_CHEAT_XAML,
		DataContext      = UI_CreateDataContext(_devmenu.cheat_btn_data_context),
	})

	-- Create CHEAT panel from _DEVMENU_ENTRIES.
	print("[DEVMENU] create phase 2/5: CHEAT panel")
	local cheat_panel_xaml, cheat_dc, cheat_count = _devmenu_build_cheat_panel_categorized(_DEVMENU_ENTRIES or {})
	_devmenu.cheat_panel_data_context = cheat_dc
	_devmenu.cheat_entry_count = cheat_count
	UI_AddChild("ScarDefault", "XamlPresenter", "DevMenuCHEATPanel", {
		IsHitTestVisible = true,
		Xaml             = cheat_panel_xaml,
		DataContext      = UI_CreateDataContext(cheat_dc),
	})

	-- Persistent (non-modal) Quick Panel — built once, shown/hidden via DC flip.
	-- Uses "ScarAlwaysVisible" (not "ScarDefault") so it renders above all
	-- ScarDefault content — including LimitsUI — regardless of creation order.
	-- WPF renders later-added ScarDefault siblings on top, so LimitsUI (created
	-- after devmenu) would otherwise cover the panel. ScarAlwaysVisible is a
	-- separate layer that the engine places above ScarDefault unconditionally.
	print("[DEVMENU] create phase 2b/5: CHEAT Quick Panel (ScarAlwaysVisible)")
	local quick_xaml, quick_dc, quick_count = _devmenu_build_quick_panel(_DEVMENU_ENTRIES or {})
	_devmenu.quick_panel_data_context = quick_dc
	_devmenu.quick_panel_entry_count  = quick_count
	UI_AddChild("ScarAlwaysVisible", "XamlPresenter", "DevMenuCHEATQuickPanel", {
		IsHitTestVisible = true,
		Xaml             = quick_xaml,
		DataContext      = UI_CreateDataContext(quick_dc),
	})

	-- Toast notification overlay — hit-test-invisible, bottom-center, auto-dismiss.
	print("[DEVMENU] create phase 2c/5: Toast overlay (ScarAlwaysVisible)")
	local toast_dc = {
		toast_visible    = false,
		-- Inline message row: prefix + colored state word + suffix.
		-- Plain toasts set msg_prefix to the full message; state/suffix fields default off.
		msg_prefix       = "",
		msg_state_word   = "",
		msg_suffix       = "",
		state_on_visible  = false,  -- green state word
		state_off_visible = false,  -- red state word
		suffix_visible    = false,
		-- Player identity row (convert toast).
		target_visible   = false,
		flag_visible     = false,
		flag_image       = "",
		player_name      = "",
		subtext_visible  = false,
		subtext          = "",
	}
	_devmenu.toast_data_context = toast_dc
	UI_AddChild("ScarAlwaysVisible", "XamlPresenter", "DevMenuToast", {
		IsHitTestVisible = false,
		Xaml             = _DEVMENU_BUILD_TOAST_XAML(),
		DataContext      = UI_CreateDataContext(toast_dc),
	})

	-- ===== VICTIM PROMPT (interactive overlay shown to targeted units' owner) =====
	print("[DEVMENU] create phase 2c-vp/5: Victim Prompt (ScarAlwaysVisible)")
	local victim_prompt_dc = {
		victim_prompt_visible = false,
		attacker_name_text    = "",
		btn_block_label       = "Block Actions",
		cmd_block   = UI_CreateCommand("DevMenu_VictimPromptBlock"),
		cmd_close   = UI_CreateCommand("DevMenu_VictimPromptClose"),
		cmd_disable = UI_CreateCommand("DevMenu_VictimPromptDisable"),
	}
	_devmenu.victim_prompt_data_context = victim_prompt_dc
	UI_AddChild("ScarAlwaysVisible", "XamlPresenter", "DevMenuVictimPrompt", {
		IsHitTestVisible = true,
		Xaml             = _DEVMENU_BUILD_VICTIM_PROMPT_XAML(),
		DataContext      = UI_CreateDataContext(victim_prompt_dc),
	})

	-- ===== SPAWN PANEL (persistent right-side last-spawned history) =====
	print("[DEVMENU] create phase 2d/5: Spawn Panel (ScarAlwaysVisible)")
	local spawn_xaml, spawn_dc = _devmenu_build_spawn_panel()
	_devmenu.spawn_panel_data_context = spawn_dc
	UI_AddChild("ScarAlwaysVisible", "XamlPresenter", "DevMenuSpawnPanel", {
		IsHitTestVisible = true,
		Xaml             = spawn_xaml,
		DataContext      = UI_CreateDataContext(spawn_dc),
	})

	-- (Teleport arm overlay removed 2026-05-11: Misc_GetMouseOnTerrain
	-- is unusable from SCAR UI context, and the transparent overlay was
	-- bugging the camera. Teleport now warps to camera center directly.)

	-- ===== DEV MENU (requires -dev flag; not shown for lobby-cheats-only sessions) =====
	local dev_count = 0
	if _devmenu_is_dev_mode() then
		-- Create DEV button.
		print("[DEVMENU] create phase 3/5: DEV button (dev mode active)")
		_devmenu.dev_btn_data_context = {
			cmd_dev = UI_CreateCommand("DevMenu_ToggleDEVPanel"),
		}
		UI_AddChild("ScarDefault", "XamlPresenter", "DevMenuDEVButton", {
			IsHitTestVisible = true,
			Xaml             = _DEVMENU_BTN_DEV_XAML,
			DataContext      = UI_CreateDataContext(_devmenu.dev_btn_data_context),
		})

		-- L1: DEV categories panel (with optional Top-3 Recent strip).
		print("[DEVMENU] create phase 4/5: DEV categories panel")
		local categories = _DEVMENU_DEV_CATEGORIES or {}
		local dev_panel_xaml, dev_dc
		dev_panel_xaml, dev_dc, dev_count = _devmenu_build_dev_categories_panel()
		_devmenu.dev_panel_data_context = dev_dc
		_devmenu.dev_entry_count = dev_count
		UI_AddChild("ScarDefault", "XamlPresenter", "DevMenuDEVPanel", {
			IsHitTestVisible = true,
			Xaml             = dev_panel_xaml,
			DataContext      = UI_CreateDataContext(dev_dc),
		})

		-- L2: bind category open handlers now; create submenu presenters lazily.
		print("[DEVMENU] create phase 5/5: bind category handlers count=" .. tostring(#categories) .. " (lazy submenus)")
		_devmenu_bind_category_open_handlers(categories)
	else
		print("[DEVMENU] DEV menu skipped: -dev flag not set")
	end

	_devmenu.is_ui_created = true
	_devmenu.is_ui_creation_scheduled = false
	print("[DEVMENU] UI created: CHEAT(" .. tostring(cheat_count) .. ") + QuickPanel(" .. tostring(quick_count) .. ") + DEV(" .. tostring(dev_count) .. ") entries")
end

function DevMenu_CreateUIDeferred()
	local ok, err = pcall(function()
		_devmenu_create_ui_now("deferred")
	end)
	if not ok then
		_devmenu.is_ui_creation_scheduled = false
		print("[DEVMENU] deferred UI create failed: " .. tostring(err))
	end
end

-----------------------------------------------------------------------
-- Lifecycle: create UI on play.
--
-- Core_OnPlay fires the <Module>_OnPlay delegates. We check if cheats
-- are enabled and, if so, build both CHEAT and DEV button+panel presenters.
-- The panels start hidden. If cheats are disabled, no UI is created.
-----------------------------------------------------------------------

function DevMenu_OnPlay()
	if _devmenu.is_ui_created then return end

	-- Engine sanity: bail quietly if UI APIs aren't available in this context.
	if type(UI_AddChild)        ~= "function"
		or type(UI_CreateCommand)     ~= "function"
		or type(UI_CreateDataContext) ~= "function"
	then
		print("[DEVMENU] UI APIs unavailable; skipping creation")
		return
	end

	-- Diagnostics: always emitted via raw print so they appear regardless of logging state.
	local cmdline_cheat  = type(Misc_IsCommandLineOptionSet) == "function" and Misc_IsCommandLineOptionSet("cheat")
	local cmdline_dev    = type(Misc_IsCommandLineOptionSet) == "function" and Misc_IsCommandLineOptionSet("dev")
	local mod_debug      = _mod ~= nil and _mod.debug == true
	local lobby_cheat    = AGS_GLOBAL_SETTINGS ~= nil and AGS_GLOBAL_SETTINGS.CheatMenu == true
	_devmenu_print("[DEVMENU-GATE] cmdline_cheat=" .. tostring(cmdline_cheat)
		.. " cmdline_dev=" .. tostring(cmdline_dev)
		.. " mod_debug=" .. tostring(mod_debug)
		.. " lobby_cheat=" .. tostring(lobby_cheat))

	local enabled, source = _devmenu_are_cheats_enabled()
	_devmenu.cheats_enabled = enabled
	if not _devmenu.cheats_enabled then
		_devmenu_print("[DEVMENU-GATE] disabled (source=" .. tostring(source) .. "); skipping menu creation")
		return
	end

	if _devmenu.is_ui_creation_scheduled then return end

	local delay = _DEVMENU_STARTUP_DELAY_SEC or 0
	if delay <= 0 or type(Rule_AddOneShot) ~= "function" then
		_devmenu_print("[DEVMENU-GATE] enabled (source=" .. tostring(source) .. "); creating menus immediately")
		_devmenu_create_ui_now("immediate")
		return
	end

	_devmenu.is_ui_creation_scheduled = true
	_devmenu_print("[DEVMENU-GATE] enabled (source=" .. tostring(source) .. "); deferring UI create by " .. tostring(delay) .. "s")
	Rule_AddOneShot(DevMenu_CreateUIDeferred, delay)
end

function DevMenu_OnGameRestore()
	-- After a restore the UI children may be gone; rebuild on next OnPlay.
	_devmenu.is_ui_created = false
	_devmenu.is_ui_creation_scheduled = false
	DevMenu_OnPlay()
end
