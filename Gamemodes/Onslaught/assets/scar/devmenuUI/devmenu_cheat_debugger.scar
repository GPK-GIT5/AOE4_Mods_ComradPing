-----------------------------------------------------------------------
-- DevMenu Cheat Action Debugger — DEVMENU_DIAG
--
-- Entry: DEV → Spawner Debugger → DEVMENU_DIAG
--
-- Runs every cheat action sequentially with runtime output hooks,
-- logs detailed diagnostics to scarlog under the [DEVMENU-CDBG] tag,
-- and validates each action against its expected result.
--
-- For actions that require a selected unit or building, a non-blocking
-- prompt appears at the right edge of the screen.  Press [READY] once
-- a valid selection exists, or [SKIP] to skip the test.
--
-- Entry point: DevMenu_RunCheatsDebugger()
-----------------------------------------------------------------------

-----------------------------------------------------------------------
-- Build tag (bump on every meaningful change so scarlog diffs are
-- self-identifying when a stale cache is loaded by accident).
-----------------------------------------------------------------------
_CDBG_BUILD_TAG = "2026-05-26.d"

-----------------------------------------------------------------------
-- Helper: detect when a captured target's owner has Block Actions enabled.
-- When true, every net handler in devmenu_mp_gate.scar correctly suppresses
-- the mutation, so the verify step seeing "state unchanged" is the CORRECT
-- outcome (not a bug). Verifiers use this to convert false-FAIL into PASS.
-- Accepts either a squad id or an entity id; returns false on any error.
-----------------------------------------------------------------------
function _cdbg_owner_is_blocked(id_or_nil)
	if id_or_nil == nil then return false end
	if _DEVMENU_BLOCK_ACTIONS_MAP == nil then return false end
	local owner = nil
	if type(Squad_GetPlayerOwner) == "function" then
		local ok, p = pcall(Squad_GetPlayerOwner, id_or_nil)
		if ok and p ~= nil then owner = p end
	end
	if owner == nil and type(Entity_GetPlayerOwner) == "function" then
		local ok, p = pcall(Entity_GetPlayerOwner, id_or_nil)
		if ok and p ~= nil then owner = p end
	end
	if owner == nil or type(Player_GetID) ~= "function" then return false end
	local ok_pid, pid = pcall(Player_GetID, owner)
	if not ok_pid or pid == nil then return false end
	return _DEVMENU_BLOCK_ACTIONS_MAP[pid] == true
end

-----------------------------------------------------------------------
-- Logger
-----------------------------------------------------------------------
local function _cdbg_log(msg)
	print("[DEVMENU-CDBG] " .. tostring(msg))
end

-----------------------------------------------------------------------
-- State
-----------------------------------------------------------------------
local _cdbg_pass    = 0
local _cdbg_fail    = 0
local _cdbg_skip    = 0
local _cdbg_running = false
local _cdbg_queue   = {}
local _cdbg_idx     = 0

-- Output recorder (populated by hooks)
local _cdbg_rec   = { toasts = {}, victim_prompts = {}, block_notifies = {}, net_queues = {} }
local _cdbg_hooks = {}  -- saved original function references

-- Selection prompt state
local _cdbg_sel_dc     = nil
local _cdbg_ui_created = false

-- Module-level globals so the named-global READY/SKIP handlers can read them
-- after a Rule_AddOneShot fires them.
_cdbg_pending_ready_fn = nil
_cdbg_pending_skip_fn  = nil

-- Cross-function capture for deferred verify steps
_cdbg_capture_eids      = {}   -- entity IDs captured before a destructive action
_cdbg_capture_sids      = {}   -- squad IDs captured before an invuln toggle
_cdbg_capture_owner     = nil  -- owner player captured before convert
_cdbg_invuln_before_cap = -1   -- min-cap value captured before invuln toggle
_cdbg_bsim_stage    = 0        -- block simulation: current stage (1=units 2=bldg 3=keep)
_cdbg_bsim_action   = 0        -- block simulation: current action index within stage
_cdbg_bsim_attacker      = ""    -- block simulation: AI attacker display name
_cdbg_bsim_attacker_flag = nil   -- block simulation: AI attacker civ flag icon URI
_cdbg_bsim_was_enabled   = false -- block simulation: block state before sim started
_cdbg_init_instant_build = false -- initial instant build state (captured at test start)
_cdbg_init_block_enabled = false -- initial block enabled state (captured at test start)
_cdbg_bsim_aborted          = false -- block simulation: abort flag (guard rail for future use)
_cdbg_bsim_vp_disabled_count = 0    -- block simulation: VP-disable events recorded mid-bsim
_cdbg_bsim_vp_shown          = 0    -- block simulation: gate calls where VP was shown
_cdbg_bsim_vp_gated          = 0    -- block simulation: gate calls suppressed by Disable/Close-cooldown
_cdbg_bsim_vp_enabled_count  = 0    -- block simulation: VP-enable events recorded mid-bsim
_cdbg_bsim_verb_gated        = {}   -- block simulation: per-verb gated count (verb -> count); enables
                                    -- SKIP-instead-of-FAIL in vp_verb coverage when a verb never had
                                    -- a non-gated opportunity (every call was suppressed by CLOSE_UNTIL)
_cdbg_bsim_verb_shown        = {}   -- block simulation: per-verb shown count (verb -> count); diagnostic
_cdbg_keep_burn_failed       = false -- T7/T8: set true if keep-burn guard bypass FAILed (drives NOTICE)
_cdbg_keep_invuln_failed     = false -- T7/T8: set true if keep-invuln guard bypass FAILed (drives NOTICE)
_cdbg_notify_expecting_disable = false -- T11 S4: suppress hook _fail while user intentionally clicks Disable
_cdbg_notify_disable_detected  = false -- T11 S5: set true by hook when Disable button is clicked
_cdbg_notify_expecting_close   = false -- T11 S2: armed when VP shown; Close hook fires auto-advance
_cdbg_notify_close_detected    = false -- T11 S3: set true by Close hook for S3 source log
_cdbg_vp_last_hide_time        = nil   -- World_GetGameTime() of last VP hide (VictimPromptClose hook)
_cdbg_vp_last_show_time        = nil   -- World_GetGameTime() of last VP show (ShowVictimPrompt hook)

-----------------------------------------------------------------------
-- Recorder
-----------------------------------------------------------------------
local function _cdbg_clear_rec()
	_cdbg_rec = { toasts = {}, victim_prompts = {}, block_notifies = {}, net_queues = {} }
end

-- Forward declaration: _fail is defined after _cdbg_install_hooks, but the
-- DevMenu_VictimPromptDisable hook closure captures it.  Forward-declaring it
-- here makes Lua compile the reference as an upvalue (not a global lookup),
-- so the assignment at the Result helpers section fills the upvalue correctly.
local _fail

-- Returns true if the VictimPrompt data context reports visible=true.
-- Safe to call even before the UI is constructed (returns false when context is nil).
local function _cdbg_vp_is_visible()
	return type(_devmenu) == "table"
		and type(_devmenu.victim_prompt_data_context) == "table"
		and _devmenu.victim_prompt_data_context.victim_prompt_visible == true
end

-----------------------------------------------------------------------
-- Hook system
-- Wraps notification functions to capture calls without changing
-- visible behaviour.  Always chains through to the original.
-----------------------------------------------------------------------
local function _cdbg_install_hooks()
	_cdbg_hooks = {}
	local function wrap(name, record_fn)
		if type(_G[name]) == "function" then
			_cdbg_hooks[name] = _G[name]
			_G[name] = function(...)
				record_fn(...)
				return _cdbg_hooks[name](...)
			end
		end
	end
	wrap("DevMenu_ShowToast", function(arg)
		_cdbg_rec.toasts[#_cdbg_rec.toasts + 1] = arg
	end)
	wrap("DevMenu_ShowVictimPrompt", function(name, verb)
		_cdbg_vp_last_show_time = type(World_GetGameTime) == "function" and World_GetGameTime() or nil
		_cdbg_rec.victim_prompts[#_cdbg_rec.victim_prompts + 1] = { name = name, verb = verb }
		-- Runtime assertion: VP must not be created while disabled outside of bsim.
		-- bsim calls DevMenu_ShowVictimPrompt directly (intentional bypass), so skip
		-- during active stages.  Any other context is a suppression failure.
		if _DEVMENU_VICTIM_PROMPT_ENABLED == false and _cdbg_bsim_stage == 0 then
			_fail("vp/created_while_disabled",
				"DevMenu_ShowVictimPrompt called while _DEVMENU_VICTIM_PROMPT_ENABLED=false "
				.. "outside bsim -- suppression gate not working")
		end
	end)
	wrap("DevMenu_ShowBlockNotify", function(n)
		_cdbg_rec.block_notifies[#_cdbg_rec.block_notifies + 1] = n
	end)
	-- NOTIFY-CORR: record every action dispatched to the network (verb token is the
	-- first arg, e.g. "DEVMENU_TELEPORT", "DEVMENU_DESTROY_ENTITY", "DEVMENU_BURN_ENTITY").
	-- Used by bldg1/bldg2 teleport steps to distinguish a real-no-op (no squads selected
	-- -> abort, no dispatch) from a real success (dispatch queued).
	wrap("DevMenu_NetworkDispatch", function(verb, ...)
		_cdbg_rec.net_queues[#_cdbg_rec.net_queues + 1] = tostring(verb)
	end)
	-- Hook the VP Close button (user-initiated hide) to auto-advance T11 S2→S3.
	-- record_fn fires before the original DevMenu_VictimPromptClose/HideVictimPrompt,
	-- so the hide timestamp is captured on the same tick as the close event.
	wrap("DevMenu_VictimPromptClose", function()
		_cdbg_vp_last_hide_time = type(World_GetGameTime) == "function" and World_GetGameTime() or nil
		if _cdbg_notify_expecting_close then
			_cdbg_notify_expecting_close = false
			_cdbg_notify_close_detected  = true
			-- Auto-advance: dismiss the sel prompt and schedule S3.
			-- Clear pending_ready_fn to prevent READY button from double-advancing.
			_cdbg_hide_sel_prompt()
			_cdbg_pending_ready_fn = nil
			if type(Rule_AddOneShot) == "function" then
				Rule_AddOneShot(_cdbg_notify_s3_delay_start, 0.1)
			else
				_cdbg_notify_s3_delay_start()
			end
		end
	end)
	-- Detect if user clicks "Disable Notifications" during a test run.
	-- T12 bsim uses DevMenu_TestVictimPromptGate (the real gate path), so clicking
	-- Disable mid-bsim correctly gates subsequent VP calls, replicating live behaviour.
	wrap("DevMenu_VictimPromptDisable", function()
		if _cdbg_bsim_stage > 0 then
			-- VP disabled mid-bsim: record the event; do NOT restore the flag.
			-- Subsequent bsim actions go through the gate and will be suppressed,
			-- which is exactly what live gameplay does.
			_cdbg_bsim_vp_disabled_count = (_cdbg_bsim_vp_disabled_count or 0) + 1
			_cdbg_log("[BSIM] Disable clicked mid-bsim (count=" .. tostring(_cdbg_bsim_vp_disabled_count)
				.. "); subsequent VP calls will be gated (live-gameplay behaviour)")
		elseif _cdbg_notify_expecting_disable then
			-- T11 S4: user was asked to click Disable Notifications.
			-- Auto-advance to S5: dismiss sel prompt and schedule validation.
			-- The original DevMenu_VictimPromptDisable (sets flag=false, hides VP)
			-- runs immediately after this record_fn, so S5 fires 0.1s later
			-- when both the flag and VP visibility are already settled.
			_cdbg_notify_disable_detected  = true
			_cdbg_notify_expecting_disable = false
			_cdbg_hide_sel_prompt()
			_cdbg_pending_ready_fn = nil
			if type(Rule_AddOneShot) == "function" then
				Rule_AddOneShot(_cdbg_notify_s5_validate_disable, 0.1)
			else
				_cdbg_notify_s5_validate_disable()
			end
		else
			_fail("notify/victim_prompt_disable",
				"'Disable Notifications' clicked during test -- _DEVMENU_VICTIM_PROMPT_ENABLED set false; "
				.. "direct ShowVictimPrompt calls (CDBG bsim) bypass this flag and still fire")
		end
	end)
	-- Track mid-bsim Enable clicks.  As of 2026-05-25, DevMenu_VictimPromptEnable
	-- itself clears _DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL directly (design: Enable
	-- fully restores VP).  This bsim-context hook retains a redundant CLOSE_UNTIL=0
	-- reset as belt-and-suspenders so any future regression in the real function
	-- doesn't silently leave bsim actions gated.
	wrap("DevMenu_VictimPromptEnable", function()
		if _cdbg_bsim_stage > 0 then
			_cdbg_bsim_vp_enabled_count = (_cdbg_bsim_vp_enabled_count or 0) + 1
			_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 0
			_cdbg_log("[BSIM] Enable clicked mid-bsim (count=" .. tostring(_cdbg_bsim_vp_enabled_count)
				.. "); CLOSE_UNTIL reset — VP will resume on next gate call"
				.. "  (ENABLED before=" .. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED) .. ")")
		else
			-- Enable pressed outside bsim (stage=0).  The original still runs and sets
			-- ENABLED=true, but no bsim actions remain to benefit — log for diagnosis.
			_cdbg_log("[HOOK] VictimPromptEnable: pressed outside bsim (stage=0)"
				.. "  ENABLED before=" .. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED)
				.. "  CLOSE_UNTIL=" .. tostring(_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL or 0))
		end
	end)
	_cdbg_log("  hooks: ShowToast=" .. tostring(type(_cdbg_hooks["DevMenu_ShowToast"]))
		.. " ShowVictimPrompt=" .. tostring(type(_cdbg_hooks["DevMenu_ShowVictimPrompt"]))
		.. " VictimPromptClose=" .. tostring(type(_cdbg_hooks["DevMenu_VictimPromptClose"]))
		.. " ShowBlockNotify=" .. tostring(type(_cdbg_hooks["DevMenu_ShowBlockNotify"]))
		.. " VictimPromptDisable=" .. tostring(type(_cdbg_hooks["DevMenu_VictimPromptDisable"]))
		.. " VictimPromptEnable=" .. tostring(type(_cdbg_hooks["DevMenu_VictimPromptEnable"])))
end

local function _cdbg_restore_hooks()
	for name, fn in pairs(_cdbg_hooks) do
		_G[name] = fn
	end
	_cdbg_hooks = {}
end

-----------------------------------------------------------------------
-- Result helpers
-----------------------------------------------------------------------
-- Phase 4a NOTIFY-CORR (2026-05-25): for unit/bldg1/bldg2 step results,
-- emit a follow-up line correlating notification activity at the moment
-- the result was recorded.  Counts are deltas since the step's clear_rec
-- call.  Gated flag reflects whether VP suppression (Disable or CLOSE_UNTIL)
-- was active at this point in time.  Silent for non-action result names
-- (T14 attribution, gate integrity, etc.) to keep scarlog readable.
local function _cdbg_notify_corr(name)
	if type(name) ~= "string" then return end
	if not (name:sub(1, 5) == "unit/" or name:sub(1, 6) == "bldg1/" or name:sub(1, 6) == "bldg2/") then
		return
	end
	local _vp = (_cdbg_rec and _cdbg_rec.victim_prompts) and #_cdbg_rec.victim_prompts or 0
	local _to = (_cdbg_rec and _cdbg_rec.toasts)         and #_cdbg_rec.toasts         or 0
	local _nq = (_cdbg_rec and _cdbg_rec.net_queues)     and #_cdbg_rec.net_queues     or 0
	local _bn = (_cdbg_rec and _cdbg_rec.block_notifies) and #_cdbg_rec.block_notifies or 0
	local _gametime = (type(World_GetGameTime) == "function") and World_GetGameTime() or 0
	local _close_active = (type(_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL) == "number"
		and _DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL > _gametime) or false
	local _gated = (_DEVMENU_VICTIM_PROMPT_ENABLED == false) or _close_active
	_cdbg_log("  [NOTIFY-CORR] step=" .. name
		.. "  vp_delta=" .. _vp
		.. "  toast_delta=" .. _to
		.. "  netq_delta=" .. _nq
		.. "  blocknotify_delta=" .. _bn
		.. "  gated=" .. tostring(_gated)
		.. " (enabled=" .. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED)
		.. " close_active=" .. tostring(_close_active) .. ")")
end

local function _pass(name, detail)
	_cdbg_pass = _cdbg_pass + 1
	_cdbg_log("[PASS] " .. name .. ": " .. tostring(detail))
	_cdbg_notify_corr(name)
end

_fail = function(name, reason)
	_cdbg_fail = _cdbg_fail + 1
	_cdbg_log("[FAIL] " .. name .. ": " .. tostring(reason))
	_cdbg_notify_corr(name)
end

local function _skip(name, reason)
	_cdbg_skip = _cdbg_skip + 1
	_cdbg_log("[SKIP] " .. name .. ": " .. tostring(reason))
	_cdbg_notify_corr(name)
end

local function _check_fn(name)
	if type(_G[name]) == "function" then return true end
	_skip("API/" .. name, "not available (type=" .. type(_G[name]) .. ")")
	return false
end

-----------------------------------------------------------------------
-- Queue runner
-- Each test function must be a named global because Rule_AddOneShot
-- requires a callable global by name.
-----------------------------------------------------------------------
local function _cdbg_advance()
	_cdbg_idx = _cdbg_idx + 1
	local fn = _cdbg_queue[_cdbg_idx]
	if fn == nil then
		_cdbg_finish_run()
		return
	end
	if type(Rule_AddOneShot) == "function" then
		Rule_AddOneShot(fn, 0.3)
	else
		fn()
	end
end

-- Named global so it can be called by _cdbg_advance after the queue empties.
function _cdbg_finish_run()
	_cdbg_restore_hooks()
	_cdbg_running = false
	_CDBG_SESSION_ACTIVE = nil   -- cross-file bridge: clear before any early-return paths
	_cdbg_hide_sel_prompt()
	-- Reset cheat toggles to their initial state (captured at test start).
	if type(DevMenu_SpeedDefault) == "function" then
		pcall(DevMenu_SpeedDefault)
		_cdbg_log("  finish: speed reset to default")
	end
	if type(DevMenu_GetInstantBuildEnabled) == "function" and type(DevMenu_DoInstantBuild) == "function" then
		local cur_ib = DevMenu_GetInstantBuildEnabled()
		if (cur_ib == true) ~= _cdbg_init_instant_build then
			pcall(DevMenu_DoInstantBuild)
			_cdbg_log("  finish: instant_build restored to " .. tostring(_cdbg_init_instant_build))
		end
	end
	if type(DevMenu_GetBlockActionsEnabled) == "function" and type(DevMenu_DoToggleBlockActions) == "function" then
		local cur_ba = DevMenu_GetBlockActionsEnabled()
		if (cur_ba == true) ~= _cdbg_init_block_enabled then
			pcall(DevMenu_DoToggleBlockActions)
			_cdbg_log("  finish: block_actions restored to " .. tostring(_cdbg_init_block_enabled))
		end
	end
	-- Phase 3b (2026-05-25): toast attribution summary.  Walk _cdbg_rec.toasts and
	-- count by state_word + presence of attribution fields (flag/name/target_pid/subtext).
	-- This makes the suite's attribution behaviour visible in scarlog without needing
	-- the user to grep individual toast lines.  Note: toasts are repeatedly cleared by
	-- _cdbg_clear_rec during the run, so this only captures toasts since the LAST clear
	-- (typically the T12 bsim cleanup).  Recorded counts are nevertheless a useful
	-- attribution-shape snapshot ("are attribution fields ever being populated?").
	do
		local _ts = _cdbg_rec.toasts or {}
		local _total = #_ts
		local _with_flag, _with_name, _with_pid, _with_sub, _with_target = 0, 0, 0, 0, 0
		local _by_state = {}
		for _, t in ipairs(_ts) do
			if type(t) == "table" then
				if t.flag       ~= nil then _with_flag   = _with_flag   + 1 end
				if t.name       ~= nil then _with_name   = _with_name   + 1 end
				if t.target_pid ~= nil then _with_pid    = _with_pid    + 1 end
				if t.subtext    ~= nil then _with_sub    = _with_sub    + 1 end
				if t.target     ~= nil then _with_target = _with_target + 1 end
				local sw = tostring(t.state_word or "?")
				_by_state[sw] = (_by_state[sw] or 0) + 1
			end
		end
		_cdbg_log("[TOAST-SUMMARY] total=" .. _total
			.. "  flag=" .. _with_flag
			.. "  name=" .. _with_name
			.. "  target_pid=" .. _with_pid
			.. "  target=" .. _with_target
			.. "  subtext=" .. _with_sub)
		local _bs = ""
		for sw, n in pairs(_by_state) do _bs = _bs .. " [" .. sw .. "=" .. n .. "]" end
		if _bs ~= "" then _cdbg_log("[TOAST-SUMMARY] by_state_word:" .. _bs) end
	end
	-- Phase 4b (2026-05-25): production-bug NOTICE.  The keep-burn and keep-invuln
	-- guards are tracked separately by T7/T8 step verifies; surface them here as a
	-- single one-liner so the failure mode is obvious in the final scarlog summary.
	if _cdbg_keep_burn_failed or _cdbg_keep_invuln_failed then
		_cdbg_log("[NOTICE] keep-guard regression detected this run:"
			.. "  keep_burn_failed="   .. tostring(_cdbg_keep_burn_failed)
			.. "  keep_invuln_failed=" .. tostring(_cdbg_keep_invuln_failed)
			.. "  -- this is a real production bug in DevMenu action handlers, NOT a test bug;"
			.. " investigate the keep-guard branches in devmenu_actions.scar")
	end
	_cdbg_log(string.format(
		"=== CDBG END: %d PASS  %d SKIP  %d FAIL ===",
		_cdbg_pass, _cdbg_skip, _cdbg_fail))
	if type(DevMenu_ShowToast) == "function" then
		DevMenu_ShowToast({
			prefix     = "CDBG done \226\128\148 ",
			state_word = _cdbg_pass .. " pass",
			state_on   = (_cdbg_fail == 0),
			suffix     = " / " .. _cdbg_fail .. " fail / " .. _cdbg_skip .. " skip \226\128\148 see [DEVMENU-CDBG]",
		})
	end
end

-----------------------------------------------------------------------
-- Selection prompt XAML
-- Positioned at the right edge, vertically centred.  The inner Border
-- carries all content; the outer Grid spans the screen but is
-- transparent (Background="{x:Null}") so it does not block clicks on
-- the rest of the HUD.
-----------------------------------------------------------------------
local function _cdbg_build_sel_xaml()
	return
[[<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:esUtility="clr-namespace:WPFGUI.Shared.Utility;assembly=EngineUI"
		Background="{x:Null}"
		HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
	<Border Background="#EE111C2A" CornerRadius="8" Padding="16,12,16,14"
			HorizontalAlignment="Right" VerticalAlignment="Center"
			Margin="0,0,24,0"
			MaxWidth="300"
			BorderBrush="#AA886600" BorderThickness="1"
			Visibility="{Binding [prompt_visible], Converter={StaticResource BoolToVis}}">
		<StackPanel>
			<TextBlock Text="{Binding [prompt_title]}"
					FontSize="10" FontWeight="SemiBold" Foreground="{Binding [prompt_title_color]}"
					HorizontalAlignment="Center" Margin="0,0,0,8" />
			<TextBlock Text="{Binding [prompt_msg]}"
					FontSize="11" Foreground="#C8E8FF"
					HorizontalAlignment="Center" TextWrapping="Wrap"
					MaxWidth="260" Margin="0,0,0,12" />
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
				<Button Command="{Binding [cmd_ready]}"
						esUtility:AudioAttachedProperty.PreviewMouseLeftButtonUpSound="sfx_ui_hud_inGame_button_play"
						Cursor="Hand" Width="110" Height="30" Margin="0,0,8,0">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border Name="RdyBorder" Background="#CC1A4A10" CornerRadius="5"
									BorderBrush="#7755AA33" BorderThickness="1" Padding="10,5">
								<TextBlock Text="READY"
										FontSize="11" FontWeight="SemiBold" Foreground="#CCFFCC"
										HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="RdyBorder" Property="Background" Value="#EE285E18" />
									<Setter TargetName="RdyBorder" Property="BorderBrush" Value="#AA77CC44" />
								</Trigger>
								<Trigger Property="IsPressed" Value="True">
									<Setter TargetName="RdyBorder" Property="Background" Value="#FF305E1A" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Button.Template>
				</Button>
				<Button Command="{Binding [cmd_skip]}"
						esUtility:AudioAttachedProperty.PreviewMouseLeftButtonUpSound="sfx_ui_hud_inGame_button_play"
						Cursor="Hand" Width="80" Height="30">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border Name="SkpBorder" Background="#CC1A2332" CornerRadius="5"
									BorderBrush="#44668899" BorderThickness="1" Padding="10,5">
								<TextBlock Text="SKIP"
										FontSize="11" FontWeight="SemiBold" Foreground="#99AABB"
										HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="SkpBorder" Property="Background" Value="#E81A2E44" />
									<Setter TargetName="SkpBorder" Property="BorderBrush" Value="#66899ABB" />
								</Trigger>
								<Trigger Property="IsPressed" Value="True">
									<Setter TargetName="SkpBorder" Property="Background" Value="#FF1A2E44" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Button.Template>
				</Button>
			</StackPanel>
		</StackPanel>
	</Border>
</Grid>
]]
end

-----------------------------------------------------------------------
-- Selection prompt UI helpers
-----------------------------------------------------------------------
local function _cdbg_ensure_ui()
	if _cdbg_ui_created then return end
	if type(UI_AddChild) ~= "function" or type(UI_CreateDataContext) ~= "function" then
		_cdbg_log("WARN: UI_AddChild unavailable — selection prompt disabled")
		return
	end
	_cdbg_sel_dc = {
		prompt_visible     = false,
		prompt_msg         = "",
		prompt_title       = "\226\154\160 Selection Required",
		prompt_title_color = "#FFCC44",
		cmd_ready          = UI_CreateCommand("_cdbg_sel_do_ready"),
		cmd_skip           = UI_CreateCommand("_cdbg_sel_do_skip"),
	}
	UI_AddChild("ScarAlwaysVisible", "XamlPresenter", "DevMenuCDbgSelPrompt", {
		IsHitTestVisible = true,
		Xaml             = _cdbg_build_sel_xaml(),
		DataContext      = UI_CreateDataContext(_cdbg_sel_dc),
	})
	_cdbg_ui_created = true
end

-- Named global — wired to the READY button via UI_CreateCommand.
function _cdbg_sel_do_ready()
	_cdbg_hide_sel_prompt()
	if type(_cdbg_pending_ready_fn) == "function" then
		if type(Rule_AddOneShot) == "function" then
			Rule_AddOneShot(_cdbg_pending_ready_fn, 0.1)
		else
			_cdbg_pending_ready_fn()
		end
	end
end

-- Named global — wired to the SKIP button via UI_CreateCommand.
function _cdbg_sel_do_skip()
	_cdbg_hide_sel_prompt()
	if type(_cdbg_pending_skip_fn) == "function" then
		if type(Rule_AddOneShot) == "function" then
			Rule_AddOneShot(_cdbg_pending_skip_fn, 0.1)
		else
			_cdbg_pending_skip_fn()
		end
	end
end

local function _cdbg_show_sel_prompt(msg, failed)
	if type(DevMenu_CloseDEVPanel) == "function" then pcall(DevMenu_CloseDEVPanel) end
	_cdbg_ensure_ui()
	if _cdbg_sel_dc == nil then return end
	_cdbg_sel_dc.prompt_msg    = tostring(msg or "")
	_cdbg_sel_dc.prompt_visible = true
	if failed then
		_cdbg_sel_dc.prompt_title       = "Selection Failed"
		_cdbg_sel_dc.prompt_title_color = "#FF4444"
	else
		_cdbg_sel_dc.prompt_title       = "\226\154\160 Selection Required"
		_cdbg_sel_dc.prompt_title_color = "#FFCC44"
	end
	if type(UI_SetDataContext) == "function" then
		UI_SetDataContext("DevMenuCDbgSelPrompt", _cdbg_sel_dc)
	end
end

-- Named global so it can be called from Rule_AddOneShot in _cdbg_finish_run.
function _cdbg_hide_sel_prompt()
	if _cdbg_sel_dc == nil then return end
	_cdbg_sel_dc.prompt_visible = false
	if type(UI_SetDataContext) == "function" then
		UI_SetDataContext("DevMenuCDbgSelPrompt", _cdbg_sel_dc)
	end
end

-----------------------------------------------------------------------
-- Selection check helpers
-- Fires ready_fn immediately when selection already has enough items,
-- otherwise shows the prompt and waits for the player to press READY.
-- Both ready_fn and skip_fn must be named globals.
-----------------------------------------------------------------------
local function _cdbg_need_squad(label, min, ready_fn, skip_fn)
	local sg = nil
	if type(SGroup_Create) == "function" and type(Misc_GetSelectedSquads) == "function" then
		if type(SGroup_Exists) == "function" and SGroup_Exists("sg_cdbg_check") then
			sg = SGroup_FromName("sg_cdbg_check")
			if type(SGroup_Clear) == "function" then SGroup_Clear(sg) end
		else
			sg = SGroup_Create("sg_cdbg_check")
		end
		Misc_GetSelectedSquads(sg, false)
	end
	local count = (sg ~= nil and type(SGroup_CountSpawned) == "function")
		and SGroup_CountSpawned(sg) or 0
	_cdbg_pending_ready_fn = ready_fn
	_cdbg_pending_skip_fn  = skip_fn
	if count >= min then
		_cdbg_sel_do_ready()
	else
		_cdbg_log("[SEL] " .. label .. ": need " .. min .. "+ squad(s), have " .. count)
		_cdbg_show_sel_prompt(label
			.. "\n\nSelect " .. min .. "+ unit(s) then press READY,\nor press SKIP to skip this test.")
	end
end

local function _cdbg_need_entity(label, min, ready_fn, skip_fn)
	local eg = nil
	if type(EGroup_Create) == "function" and type(Misc_GetSelectedEntities) == "function" then
		if type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_check") then
			eg = EGroup_FromName("eg_cdbg_check")
			if type(EGroup_Clear) == "function" then EGroup_Clear(eg) end
		else
			eg = EGroup_Create("eg_cdbg_check")
		end
		Misc_GetSelectedEntities(eg, false)
	end
	local count = (eg ~= nil and type(EGroup_CountSpawned) == "function")
		and EGroup_CountSpawned(eg) or 0
	_cdbg_pending_ready_fn = ready_fn
	_cdbg_pending_skip_fn  = skip_fn
	if count >= min then
		_cdbg_sel_do_ready()
	else
		_cdbg_log("[SEL] " .. label .. ": need " .. min .. "+ entity/ies, have " .. count)
		_cdbg_show_sel_prompt(label
			.. "\n\nSelect " .. min .. "+ building(s)/unit(s) then press READY,\nor press SKIP to skip this test.")
	end
end

-----------------------------------------------------------------------
-- T1: Resources (Food / Wood / Gold / Stone / Oil / All)
-----------------------------------------------------------------------
function _cdbg_t_resources()
	_cdbg_log("[TEST] T1: Resources")
	local p = type(_devmenu_local_player) == "function" and _devmenu_local_player() or nil

	local function test_res(label, fn_name, rt_const)
		if not _check_fn(fn_name) then return end
		_cdbg_clear_rec()
		local before = (p ~= nil and type(Player_GetResource) == "function" and rt_const ~= nil)
			and Player_GetResource(p, rt_const) or nil
		local ok, err = pcall(_G[fn_name])
		if not ok then _fail("resources/" .. label, "crash: " .. tostring(err)); return end
		local after = (p ~= nil and type(Player_GetResource) == "function" and rt_const ~= nil)
			and Player_GetResource(p, rt_const) or nil
		if before ~= nil and after ~= nil then
			if after > before then
				_pass("resources/" .. label, before .. " \226\134\146 " .. after)
			else
				_fail("resources/" .. label, "no increase (before=" .. before .. " after=" .. after .. ")")
			end
		else
			_pass("resources/" .. label, "called without crash (no state API available)")
		end
	end

	-- RT_* are engine-global constants; guard each in case the civ/mode doesn't define them.
	local rt_food  = (type(RT_Food)  ~= "nil") and RT_Food  or nil
	local rt_wood  = (type(RT_Wood)  ~= "nil") and RT_Wood  or nil
	local rt_gold  = (type(RT_Gold)  ~= "nil") and RT_Gold  or nil
	local rt_stone = (type(RT_Stone) ~= "nil") and RT_Stone or nil
	local rt_oil   = (type(RT_Oil)   ~= "nil") and RT_Oil   or nil

	test_res("food",  "DevMenu_DoResourcesFood",  rt_food)
	test_res("wood",  "DevMenu_DoResourcesWood",  rt_wood)
	test_res("gold",  "DevMenu_DoResourcesGold",  rt_gold)
	test_res("stone", "DevMenu_DoResourcesStone", rt_stone)
	test_res("oil",   "DevMenu_DoResourcesOil",   rt_oil)

	if type(DevMenu_DoResourcesAll) == "function" then
		_cdbg_clear_rec()
		local ok, err = pcall(DevMenu_DoResourcesAll)
		if ok then _pass("resources/all", "called without crash")
		else      _fail("resources/all", "crash: " .. tostring(err)) end
	end

	_cdbg_advance()
end

-----------------------------------------------------------------------
-- T2: Progression (Age Up, Pop Cap)
-----------------------------------------------------------------------
function _cdbg_t_progression()
	_cdbg_log("[TEST] T2: Progression (Age Up, Pop Cap)")

	local function test_prog(label, fn_name)
		if not _check_fn(fn_name) then return end
		_cdbg_clear_rec()
		local ok, err = pcall(_G[fn_name])
		if not ok then _fail("progression/" .. label, "crash: " .. tostring(err)); return end
		if #_cdbg_rec.toasts > 0 then
			local tw = _cdbg_rec.toasts[1]
			_pass("progression/" .. label, "toast: " .. tostring(
				type(tw) == "table" and (tw.state_word or tw.prefix or "ok") or tw))
		else
			_pass("progression/" .. label, "called without crash")
		end
	end

	test_prog("age_up",  "DevMenu_DoAgeUp")
	test_prog("pop_cap", "DevMenu_DoPopCapMax")
	_cdbg_advance()
end

-----------------------------------------------------------------------
-- T3: Speed controls (Decrease / Default / Increase)
-----------------------------------------------------------------------
function _cdbg_t_speed()
	_cdbg_log("[TEST] T3: Speed (Decrease / Default / Increase)")
	local tests = {
		{ "speed/decrease", "DevMenu_SpeedDecrease" },
		{ "speed/default",  "DevMenu_SpeedDefault"  },
		{ "speed/increase", "DevMenu_SpeedIncrease" },
	}
	for _, t in ipairs(tests) do
		local label, fn_name = t[1], t[2]
		if type(_G[fn_name]) == "function" then
			local ok, err = pcall(_G[fn_name])
			if ok then _pass(label, "called without crash")
			else      _fail(label, "crash: " .. tostring(err)) end
		else
			_skip(label, fn_name .. " not available")
		end
	end
	-- Always restore default speed so subsequent tests are unaffected.
	if type(DevMenu_SpeedDefault) == "function" then pcall(DevMenu_SpeedDefault) end
	_cdbg_advance()
end

-----------------------------------------------------------------------
-- T4: World (FoW toggle, Explore All)
-----------------------------------------------------------------------
function _cdbg_t_world()
	_cdbg_log("[TEST] T4: World (FoW toggle, Explore All)")
	if type(DevMenu_DoFoW) == "function" then
		local ok, err = pcall(DevMenu_DoFoW)
		if ok then _pass("world/fow_toggle", "called without crash")
		else      _fail("world/fow_toggle", "crash: " .. tostring(err)) end
		-- Restore (FoW is a toggle; call again to revert)
		pcall(DevMenu_DoFoW)
	else
		_skip("world/fow_toggle", "DevMenu_DoFoW not available")
	end
	if type(DevMenu_DoExploreAll) == "function" then
		local ok, err = pcall(DevMenu_DoExploreAll)
		if ok then _pass("world/explore_all", "called without crash")
		else      _fail("world/explore_all", "crash: " .. tostring(err)) end
		-- Reset FoW render state after Explore All: cycle ON then OFF.
		if type(DevMenu_DoFoW) == "function" then
			pcall(DevMenu_DoFoW)  -- toggle ON (re-apply fog)
			pcall(DevMenu_DoFoW)  -- toggle OFF (restore non-fog state)
			_cdbg_log("  world: FoW reset cycle applied after Explore All (ON -> OFF)")
		end
	else
		_skip("world/explore_all", "DevMenu_DoExploreAll not available")
	end
	_cdbg_advance()
end

-----------------------------------------------------------------------
-- T5: Production (Instant Build toggle, verify state flip)
-----------------------------------------------------------------------
function _cdbg_t_production()
	_cdbg_log("[TEST] T5: Production (Instant Build toggle)")
	if type(DevMenu_DoInstantBuild) ~= "function" then
		_skip("production/instant_build", "DevMenu_DoInstantBuild not available")
		_cdbg_advance()
		return
	end
	local get_fn = (type(DevMenu_GetInstantBuildEnabled) == "function")
		and DevMenu_GetInstantBuildEnabled or nil
	local before = get_fn and get_fn() or nil
	_cdbg_log("  instant_build state before: " .. tostring(before))
	local ok, err = pcall(DevMenu_DoInstantBuild)
	if not ok then
		_fail("production/instant_build", "crash: " .. tostring(err))
		_cdbg_advance()
		return
	end
	local after = get_fn and get_fn() or nil
	_cdbg_log("  instant_build state after:  " .. tostring(after))
	if before ~= nil and after ~= nil then
		if after ~= before then
			_pass("production/instant_build", tostring(before) .. " \226\134\146 " .. tostring(after))
		else
			_fail("production/instant_build", "state unchanged: " .. tostring(before))
		end
	else
		_pass("production/instant_build", "called without crash (no state getter)")
	end
	-- Restore to original state
	if before ~= nil and after ~= nil and after ~= before then
		pcall(DevMenu_DoInstantBuild)
		_cdbg_log("  instant_build: restored")
	end
	_cdbg_advance()
end


-----------------------------------------------------------------------
-- UNIT PHASE (Phase 2) -- single selection, sequential 1s actions, Destroy last
-----------------------------------------------------------------------
-- All functions are named globals (required for Rule_AddOneShot).

-- Pre-flight selection guard used at the start of each action step (except the
-- final Destroy).  Re-captures the current screen selection into the named group
-- so the stored group always reflects what is actually selected at action time.
-- Returns true when the group is non-empty and the step can proceed.
-- Returns false after showing a "Selection Failed" re-prompt; the step should
-- return immediately.  When the user clicks READY, retry_fn fires again.
local function _cdbg_check_group_ready(group_type, skip_fn, retry_fn, step_label)
	local is_units   = (group_type == "units")
	local group_name = is_units and "sg_cdbg_units" or ("eg_cdbg_" .. group_type)
	local count      = 0
	if is_units then
		local sg = nil
		if type(SGroup_Exists) == "function" and SGroup_Exists(group_name) then
			sg = SGroup_FromName(group_name)
			if type(SGroup_Clear) == "function" then SGroup_Clear(sg) end
		elseif type(SGroup_Create) == "function" then
			sg = SGroup_Create(group_name)
		end
		if sg ~= nil and type(Misc_GetSelectedSquads) == "function" then
			Misc_GetSelectedSquads(sg, false)
		end
		count = (sg ~= nil and type(SGroup_CountSpawned) == "function")
			and SGroup_CountSpawned(sg) or 0
	else
		local eg = nil
		if type(EGroup_Exists) == "function" and EGroup_Exists(group_name) then
			eg = EGroup_FromName(group_name)
			if type(EGroup_Clear) == "function" then EGroup_Clear(eg) end
		elseif type(EGroup_Create) == "function" then
			eg = EGroup_Create(group_name)
		end
		if eg ~= nil and type(Misc_GetSelectedEntities) == "function" then
			Misc_GetSelectedEntities(eg, false)
		end
		count = (eg ~= nil and type(EGroup_CountSpawned) == "function")
			and EGroup_CountSpawned(eg) or 0
	end
	if count > 0 then return true end
	_cdbg_log("[SEL] " .. string.upper(group_type)
		.. ": empty before " .. step_label .. " -- re-prompting")
	_cdbg_pending_ready_fn = retry_fn
	_cdbg_pending_skip_fn  = skip_fn
	_cdbg_show_sel_prompt(
		"Re-select " .. step_label
		.. "\n(units deselected or entity destroyed)",
		true)
	return false
end

function _cdbg_t_unit_phase()
	_cdbg_log("[PHASE] UNITS: showing selection prompt")
	if type(DevMenu_ShowToast) == "function" then
		pcall(DevMenu_ShowToast, {
			prefix     = "UNIT PHASE: ",
			state_word = "Teleport \226\134\146 Convert \226\134\146 Invuln \226\134\146 Destroy",
			state_on   = true,
			suffix     = " (4 actions @ 1s)",
		})
	end
	_cdbg_pending_ready_fn = _cdbg_unit_phase_start
	_cdbg_pending_skip_fn  = _cdbg_skip_unit_phase
	_cdbg_show_sel_prompt("Select 1+ UNITS\nPress READY, or SKIP to skip.")
end

function _cdbg_skip_unit_phase()
	_skip("unit/teleport", "unit phase skipped by user")
	_skip("unit/convert",  "unit phase skipped by user")
	_skip("unit/invuln",   "unit phase skipped by user")
	_skip("unit/destroy",  "unit phase skipped by user")
	_cdbg_advance()
end

function _cdbg_unit_phase_start()
	local sg = nil
	if type(SGroup_Exists) == "function" and SGroup_Exists("sg_cdbg_units") then
		sg = SGroup_FromName("sg_cdbg_units")
		if type(SGroup_Clear) == "function" then SGroup_Clear(sg) end
	elseif type(SGroup_Create) == "function" then
		sg = SGroup_Create("sg_cdbg_units")
	end
	if sg ~= nil and type(Misc_GetSelectedSquads) == "function" then
		Misc_GetSelectedSquads(sg, false)
	end
	local count = (sg ~= nil and type(SGroup_CountSpawned) == "function")
		and SGroup_CountSpawned(sg) or 0
	_cdbg_log("[PHASE] UNITS: captured " .. count .. " squad(s)")
	if count == 0 then
		_cdbg_log("[SEL] UNITS: no squads at READY time -- retrying")
		_cdbg_pending_ready_fn = _cdbg_unit_phase_start
		_cdbg_pending_skip_fn  = _cdbg_skip_unit_phase
		_cdbg_show_sel_prompt("Select 1+ UNITS\nPress READY, or SKIP to skip.", true)
		return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_unit_step_teleport, 1.0)
	else _cdbg_unit_step_teleport() end
end

function _cdbg_unit_step_teleport()
	if not _cdbg_check_group_ready("units", _cdbg_skip_unit_phase, _cdbg_unit_step_teleport, "UNITS for Teleport") then return end
	_cdbg_log("[UNIT] 1/4 Teleport")
	_cdbg_clear_rec()
	local ok, err = pcall(DevMenu_DoTeleportSelected)
	if ok then
		if #_cdbg_rec.toasts > 0 then _pass("unit/teleport", "called; toast recorded")
		else                          _pass("unit/teleport", "called without crash") end
	else
		_fail("unit/teleport", "crash: " .. tostring(err))
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_unit_step_convert, 1.0)
	else _cdbg_unit_step_convert() end
end

function _cdbg_unit_step_convert()
	if not _cdbg_check_group_ready("units", _cdbg_skip_unit_phase, _cdbg_unit_step_convert, "UNITS for Convert") then return end
	_cdbg_log("[UNIT] 2/4 Convert")
	_cdbg_clear_rec()
	_cdbg_capture_owner = nil
	local sg = (type(SGroup_Exists) == "function" and SGroup_Exists("sg_cdbg_units"))
		and SGroup_FromName("sg_cdbg_units") or nil
	if sg ~= nil and type(SGroup_CountSpawned) == "function" and SGroup_CountSpawned(sg) > 0
		and type(SGroup_GetSpawnedSquadAt) == "function"
		and type(Squad_GetPlayerOwner) == "function" then
		local first = SGroup_GetSpawnedSquadAt(sg, 1)
		if first ~= nil then _cdbg_capture_owner = Squad_GetPlayerOwner(first) end
	end
	local ok, err = pcall(DevMenu_DoConvertSelected)
	if not ok then
		_fail("unit/convert", "crash: " .. tostring(err))
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_unit_step_invuln, 1.0)
		else _cdbg_unit_step_invuln() end
		return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_unit_convert_verify, 0.5)
	else _cdbg_unit_convert_verify() end
end

function _cdbg_unit_convert_verify()
	if _cdbg_capture_owner == nil then
		if #_cdbg_rec.toasts > 0 then _pass("unit/convert", "action fired; toast recorded")
		else                          _pass("unit/convert", "called without crash") end
	elseif type(Player_GetID) == "function" then
		local sg = (type(SGroup_Exists) == "function" and SGroup_Exists("sg_cdbg_units"))
			and SGroup_FromName("sg_cdbg_units") or nil
		local new_owner = nil
		if sg ~= nil and type(SGroup_CountSpawned) == "function" and SGroup_CountSpawned(sg) > 0
			and type(SGroup_GetSpawnedSquadAt) == "function"
			and type(Squad_GetPlayerOwner) == "function" then
			local first = SGroup_GetSpawnedSquadAt(sg, 1)
			if first ~= nil then new_owner = Squad_GetPlayerOwner(first) end
		end
		if new_owner ~= nil then
			local old_id = Player_GetID(_cdbg_capture_owner)
			local new_id = Player_GetID(new_owner)
			if new_id ~= old_id then
				_pass("unit/convert", "owner " .. old_id .. " -> " .. new_id)
			else
				_pass("unit/convert", "owner cycled (SP / 1-player); action completed")
			end
		else
			_pass("unit/convert", "called without crash (no owner re-check)")
		end
	else
		_pass("unit/convert", "called without crash (Player_GetID unavailable)")
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_unit_step_invuln, 0.5)
	else _cdbg_unit_step_invuln() end
end

function _cdbg_unit_step_invuln()
	if not _cdbg_check_group_ready("units", _cdbg_skip_unit_phase, _cdbg_unit_step_invuln, "UNITS for Invuln") then return end
	_cdbg_log("[UNIT] 3/4 Invuln Toggle")
	_cdbg_clear_rec()
	_cdbg_capture_sids      = {}
	_cdbg_invuln_before_cap = -1
	local sg = (type(SGroup_Exists) == "function" and SGroup_Exists("sg_cdbg_units"))
		and SGroup_FromName("sg_cdbg_units") or nil
	if sg ~= nil and type(SGroup_CountSpawned) == "function" and SGroup_CountSpawned(sg) > 0
		and type(SGroup_GetSpawnedSquadAt) == "function"
		and type(Squad_GetInvulnerableMinCap) == "function" then
		local first = SGroup_GetSpawnedSquadAt(sg, 1)
		if first ~= nil then
			_cdbg_capture_sids[1] = first
			local cap = Squad_GetInvulnerableMinCap(first)
			_cdbg_invuln_before_cap = (type(cap) == "number") and cap or 0
		end
	end
	_cdbg_log("  invuln min-cap before: " .. _cdbg_invuln_before_cap)
	local ok, err = pcall(DevMenu_DoInvulnSelectedUnits)
	if not ok then
		_fail("unit/invuln", "crash: " .. tostring(err))
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_unit_step_destroy, 1.0)
		else _cdbg_unit_step_destroy() end
		return
	end
	-- MP-tolerant verify delay: net dispatch + bsim lockstep needs ~1.2s in MP
	-- before invuln state mutation is observable on the local peer.
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_unit_invuln_verify, 1.2)
	else _cdbg_unit_invuln_verify() end
end

_cdbg_unit_invuln_retry = false
function _cdbg_unit_invuln_verify()
	local sq = _cdbg_capture_sids[1]
	if sq ~= nil and type(Squad_GetInvulnerableMinCap) == "function"
		and _cdbg_invuln_before_cap >= 0 then
		local after_cap = Squad_GetInvulnerableMinCap(sq)
		after_cap = (type(after_cap) == "number") and after_cap or 0
		_cdbg_log("  invuln min-cap after: " .. after_cap
			.. (_cdbg_unit_invuln_retry and " (retry)" or ""))
		if after_cap ~= _cdbg_invuln_before_cap then
			_pass("unit/invuln", "min-cap " .. _cdbg_invuln_before_cap .. " -> " .. after_cap
				.. (_cdbg_unit_invuln_retry and " (retry)" or ""))
		else
			-- One MP-tolerant retry at +0.6s before declaring failure.
			if not _cdbg_unit_invuln_retry and type(Rule_AddOneShot) == "function" then
				_cdbg_unit_invuln_retry = true
				_cdbg_log("  invuln verify: retry scheduled at +0.6s")
				Rule_AddOneShot(_cdbg_unit_invuln_verify, 0.6)
				return
			end
			if _cdbg_owner_is_blocked(sq) then
				_pass("unit/invuln", "min-cap unchanged at " .. after_cap
					.. " — owner has Block Actions ON; net handler correctly suppressed invuln")
			else
				_fail("unit/invuln", "min-cap unchanged at " .. after_cap .. " (after retry)")
			end
			_cdbg_unit_invuln_retry = false
		end
		_cdbg_unit_invuln_retry = false
		-- Restore: toggle off if we turned it ON, so Destroy can actually kill the units.
		if after_cap > 0 and _cdbg_invuln_before_cap == 0 then
			pcall(DevMenu_DoInvulnSelectedUnits)
			_cdbg_log("  invuln: restored (toggled off before destroy)")
		end
	else
		_pass("unit/invuln", "called without crash (no state verify)")
	end
	-- 0.7s gap so invuln restore settles before destroy fires (total ~1s from invuln step).
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_unit_step_destroy, 0.7)
	else _cdbg_unit_step_destroy() end
end

function _cdbg_unit_step_destroy()
	_cdbg_log("[UNIT] 4/4 Destroy (LAST)")
	_cdbg_clear_rec()
	_cdbg_capture_eids = {}
	local sg = (type(SGroup_Exists) == "function" and SGroup_Exists("sg_cdbg_units"))
		and SGroup_FromName("sg_cdbg_units") or nil
	if sg ~= nil and type(SGroup_CountSpawned) == "function" and SGroup_CountSpawned(sg) > 0
		and type(SGroup_ForEach) == "function" then
		SGroup_ForEach(sg, function(_, _, squad)
			if squad ~= nil and type(Squad_GetEntityAt) == "function" then
				local eid = Squad_GetEntityAt(squad, 1)
				if eid ~= nil then _cdbg_capture_eids[#_cdbg_capture_eids + 1] = eid end
			end
		end)
	end
	_cdbg_log("  captured " .. #_cdbg_capture_eids .. " entity ID(s) for verify")
	-- Phase 2b: when capture is empty, log why (sg presence, sg size, API availability)
	-- so the next run distinguishes "sg gone" from "Squad_GetEntityAt API missing".
	if #_cdbg_capture_eids == 0 then
		local _sg_exists = (type(SGroup_Exists) == "function" and SGroup_Exists("sg_cdbg_units")) or false
		local _sg_count  = (sg ~= nil and type(SGroup_CountSpawned) == "function")
			and SGroup_CountSpawned(sg) or -1
		_cdbg_log("  [DIAG] empty capture: sg_exists=" .. tostring(_sg_exists)
			.. " sg_count_spawned=" .. tostring(_sg_count)
			.. " SGroup_ForEach=" .. type(SGroup_ForEach)
			.. " Squad_GetEntityAt=" .. type(Squad_GetEntityAt)
			.. "  -- destroy verify will skip the per-entity check")
	end
	local ok, err = pcall(DevMenu_DoDestroySelected)
	if not ok then
		_fail("unit/destroy", "crash: " .. tostring(err))
		_cdbg_advance(); return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_unit_destroy_verify, 0.5)
	else _cdbg_unit_destroy_verify() end
end

function _cdbg_unit_destroy_verify()
	if #_cdbg_capture_eids == 0 then
		if #_cdbg_rec.toasts > 0 then _pass("unit/destroy", "action fired; toast recorded")
		else                          _pass("unit/destroy", "called without crash") end
		_cdbg_advance(); return
	end
	local dead, total = 0, #_cdbg_capture_eids
	for _, eid in ipairs(_cdbg_capture_eids) do
		if type(Entity_IsAlive) == "function" and not Entity_IsAlive(eid) then
			dead = dead + 1
		end
	end
	if dead > 0 then
		_pass("unit/destroy", dead .. "/" .. total .. " entities killed")
	elseif type(Entity_IsAlive) ~= "function" then
		_pass("unit/destroy", "called without crash (Entity_IsAlive unavailable)")
	else
		_fail("unit/destroy", "0/" .. total .. " killed -- selection may have been lost or units were still invulnerable")
	end
	_cdbg_advance()
end


-- Entity-type guard: returns true when eid is any keep / town-centre (type only, no
-- ownership check).  Used in BLDG1 to enforce that the user selects a keep-type building.
local function _cdbg_entity_is_keep_type(eid)
	if eid == nil then return false end
	if type(Entity_IsOfType) ~= "function" then return false end
	return Entity_IsOfType(eid, "town_center") or Entity_IsOfType(eid, "castle") or Entity_IsOfType(eid, "scar_keep")
end

-- Returns true when eid would be SKIPPED by DevMenu_DoDestroySelected /
-- DevMenu_DoConvertSelected -- i.e. a keep / town-centre owned by a human player.
-- Replicates _devmenu_is_human_player_keep (private to devmenu_actions.scar) so CDBG
-- can pre-validate BLDG2 selections before those actions would silently no-op.
local function _cdbg_entity_is_human_keep(eid)
	if eid == nil then return false end
	if type(Entity_IsOfType) ~= "function" then return false end
	if not (Entity_IsOfType(eid, "town_center") or Entity_IsOfType(eid, "castle") or Entity_IsOfType(eid, "scar_keep")) then
		return false
	end
	local owner = (type(Entity_GetPlayerOwner) == "function") and Entity_GetPlayerOwner(eid) or nil
	if owner == nil then return false end
	if type(Player_IsHuman) == "function" then
		return Player_IsHuman(owner) == true
	end
	-- Fallback: protect if owned by the local player (mirrors _devmenu_is_human_player_keep).
	if type(Game_GetLocalPlayer) == "function" and type(Player_GetID) == "function" then
		local ok, local_p = pcall(Game_GetLocalPlayer)
		if ok and local_p ~= nil then
			return Player_GetID(owner) == Player_GetID(local_p)
		end
	end
	return false
end

-----------------------------------------------------------------------
-- BUILDING PHASE 1 (Phase 3A) -- primary building (starter keep / main structure)
-----------------------------------------------------------------------

function _cdbg_t_bldg_phase_1()
	_cdbg_log("[PHASE] BLDG1: showing selection prompt")
	if type(DevMenu_ShowToast) == "function" then
		pcall(DevMenu_ShowToast, {
			prefix     = "BLDG1 PHASE: ",
			state_word = "Teleport \226\134\146 Convert \226\134\146 Invuln \226\134\146 Burn \226\134\146 Destroy",
			state_on   = true,
			suffix     = " (5 actions @ 1s)",
		})
	end
	_cdbg_pending_ready_fn = _cdbg_bldg1_start
	_cdbg_pending_skip_fn  = _cdbg_skip_bldg_phase_1
	_cdbg_show_sel_prompt("Select Starter Building (Keep)\nPress READY, or SKIP to skip.")
end

function _cdbg_skip_bldg_phase_1()
	_skip("bldg1/teleport", "building phase 1 skipped by user")
	_skip("bldg1/convert",  "building phase 1 skipped by user")
	_skip("bldg1/invuln",   "building phase 1 skipped by user")
	_skip("bldg1/burn",     "building phase 1 skipped by user")
	_skip("bldg1/destroy",  "building phase 1 skipped by user")
	_cdbg_advance()
end

function _cdbg_bldg1_start()
	local eg = nil
	if type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg1") then
		eg = EGroup_FromName("eg_cdbg_bldg1")
		if type(EGroup_Clear) == "function" then EGroup_Clear(eg) end
	elseif type(EGroup_Create) == "function" then
		eg = EGroup_Create("eg_cdbg_bldg1")
	end
	if eg ~= nil and type(Misc_GetSelectedEntities) == "function" then
		Misc_GetSelectedEntities(eg, false)
	end
	local count = (eg ~= nil and type(EGroup_CountSpawned) == "function")
		and EGroup_CountSpawned(eg) or 0
	_cdbg_log("[PHASE] BLDG1: captured " .. count .. " entity/ies")
	if count == 0 then
		_cdbg_log("[SEL] BLDG1: no entities at READY time -- retrying")
		_cdbg_pending_ready_fn = _cdbg_bldg1_start
		_cdbg_pending_skip_fn  = _cdbg_skip_bldg_phase_1
		_cdbg_show_sel_prompt("Select 1+ BUILDINGS (primary)\nPress READY, or SKIP to skip.", true)
		return
	end
	-- Validate: BLDG1 is the keep-actions phase; require at least one keep-type entity so
	-- the test exercises convert / destroy behaviour on the intended building type.
	do
		local n = (type(EGroup_CountSpawned) == "function") and EGroup_CountSpawned(eg) or 0
		_cdbg_log("[SEL] BLDG1: checking " .. n .. " entity/ies for keep-type"
			.. "  EGroup_ForEach=" .. type(EGroup_ForEach)
			.. "  EGroup_GetEntityAt=" .. type(EGroup_GetEntityAt)
			.. "  Entity_IsOfType=" .. type(Entity_IsOfType))
		local has_keep = false
		if type(EGroup_GetEntityAt) == "function" then
			for i = 1, n do
				local eid = EGroup_GetEntityAt(eg, i)
				local is_tc   = (type(Entity_IsOfType) == "function") and Entity_IsOfType(eid, "town_center") or nil
				local is_keep = (type(Entity_IsOfType) == "function") and (Entity_IsOfType(eid, "castle") or Entity_IsOfType(eid, "scar_keep")) or nil
				local is_bldg = (type(Entity_IsOfType) == "function") and Entity_IsOfType(eid, "building") or nil
				_cdbg_log("  BLDG1 entity[" .. i .. "]: town_center=" .. tostring(is_tc)
					.. " castle=" .. tostring(is_keep) .. " building=" .. tostring(is_bldg))
				if is_tc or is_keep then has_keep = true end
			end
		elseif type(EGroup_ForEach) == "function" then
			EGroup_ForEach(eg, function(_, _, eid)
				if _cdbg_entity_is_keep_type(eid) then has_keep = true end
			end)
		else
			_cdbg_log("[SEL] BLDG1: WARNING -- EGroup_GetEntityAt and EGroup_ForEach both unavailable; skipping type guard")
			has_keep = true  -- cannot validate; allow through rather than infinite-loop
		end
		if not has_keep then
			_cdbg_log("[SEL] BLDG1: no keep-type entity in selection -- re-prompting")
			_cdbg_pending_ready_fn = _cdbg_bldg1_start
			_cdbg_pending_skip_fn  = _cdbg_skip_bldg_phase_1
			_cdbg_show_sel_prompt(
				"Select a KEEP or Town Centre\n(no keep-type building in selection)", true)
			return
		end
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_step_teleport, 1.0)
	else _cdbg_bldg1_step_teleport() end
end

function _cdbg_bldg1_step_teleport()
	if not _cdbg_check_group_ready("bldg1", _cdbg_skip_bldg_phase_1, _cdbg_bldg1_step_teleport, "BUILDING for Teleport") then return end
	_cdbg_log("[BLDG1] 1/5 Teleport")
	_cdbg_clear_rec()
	local ok, err = pcall(DevMenu_DoTeleportSelected)
	if ok then
		-- Distinguish a real-no-op (selection has no squads -> action aborts pre-dispatch)
		-- from a real success (squads selected -> DEVMENU_TELEPORT queued).  The toast count
		-- alone cannot tell them apart because the abort path also shows a toast.
		local _queued = false
		for _, v in ipairs(_cdbg_rec.net_queues) do
			if type(v) == "string" and v:find("TELEPORT") then _queued = true; break end
		end
		if _queued then _pass("bldg1/teleport", "called; net-dispatch DEVMENU_TELEPORT queued")
		else            _pass("bldg1/teleport", "no squads in building selection — teleport correctly no-op (expected; teleport requires squads, not entities)")
		end
	else
		_fail("bldg1/teleport", "crash: " .. tostring(err))
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_step_convert, 1.0)
	else _cdbg_bldg1_step_convert() end
end

function _cdbg_bldg1_step_convert()
	if not _cdbg_check_group_ready("bldg1", _cdbg_skip_bldg_phase_1, _cdbg_bldg1_step_convert, "BUILDING for Convert") then return end
	_cdbg_log("[BLDG1] 2/5 Convert")
	_cdbg_clear_rec()
	_cdbg_capture_owner = nil
	local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg1"))
		and EGroup_FromName("eg_cdbg_bldg1") or nil
	if eg ~= nil and type(EGroup_ForEach) == "function" then
		EGroup_ForEach(eg, function(_, _, eid)
			if eid ~= nil and _cdbg_capture_owner == nil
				and type(Entity_GetPlayerOwner) == "function" then
				if type(World_OwnsEntity) ~= "function" or World_OwnsEntity(eid) then
					_cdbg_capture_owner = Entity_GetPlayerOwner(eid)
				end
			end
		end)
	end
	local ok, err = pcall(DevMenu_DoConvertSelected)
	if not ok then
		_fail("bldg1/convert", "crash: " .. tostring(err))
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_step_invuln, 1.0)
		else _cdbg_bldg1_step_invuln() end
		return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_convert_verify, 0.5)
	else _cdbg_bldg1_convert_verify() end
end

function _cdbg_bldg1_convert_verify()
	if _cdbg_capture_owner ~= nil and type(Player_GetID) == "function" then
		local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg1"))
			and EGroup_FromName("eg_cdbg_bldg1") or nil
		local new_owner = nil
		if eg ~= nil and type(EGroup_ForEach) == "function" then
			EGroup_ForEach(eg, function(_, _, eid)
				if eid ~= nil and new_owner == nil
					and type(Entity_GetPlayerOwner) == "function" then
					if type(World_OwnsEntity) ~= "function" or World_OwnsEntity(eid) then
						new_owner = Entity_GetPlayerOwner(eid)
					end
				end
			end)
		end
		if new_owner ~= nil then
			local old_id = Player_GetID(_cdbg_capture_owner)
			local new_id = Player_GetID(new_owner)
			if new_id ~= old_id then
				-- Convert changed ownership. Check if any entity in the group is a keep-type:
				-- DEVMENU_CONVERT keep guard should have blocked the transfer.
				-- Match the exact types in the handler guard: "castle" and "scar_keep" only.
				local keep_converted = false
				if eg ~= nil and type(EGroup_ForEach) == "function"
					and type(Entity_IsOfType) == "function" then
					EGroup_ForEach(eg, function(_, _, eid)
						if not keep_converted and eid ~= nil then
							if Entity_IsOfType(eid, "castle") or Entity_IsOfType(eid, "scar_keep") then
								keep_converted = true
							end
						end
					end)
				end
				if keep_converted then
					_fail("bldg1/convert", "keep converted — keep guard bypassed: owner "
						.. old_id .. " -> " .. new_id)
				else
					_pass("bldg1/convert", "owner " .. old_id .. " -> " .. new_id)
				end
			else
				_pass("bldg1/convert", "keep guard active: owner unchanged (expected)")
			end
		else
			_pass("bldg1/convert", "called without crash (no post-owner)")
		end
	else
		_pass("bldg1/convert", "called without crash")
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_step_invuln, 0.5)
	else _cdbg_bldg1_step_invuln() end
end

function _cdbg_bldg1_step_invuln()
	if not _cdbg_check_group_ready("bldg1", _cdbg_skip_bldg_phase_1, _cdbg_bldg1_step_invuln, "BUILDING for Invuln") then return end
	_cdbg_log("[BLDG1] 3/5 Invuln Toggle")
	_cdbg_clear_rec()
	_cdbg_capture_eids = {}
	local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg1"))
		and EGroup_FromName("eg_cdbg_bldg1") or nil
	if eg ~= nil and type(EGroup_ForEach) == "function" then
		EGroup_ForEach(eg, function(_, _, eid)
			if eid ~= nil then _cdbg_capture_eids[#_cdbg_capture_eids + 1] = eid end
		end)
	end
	local ok, err = pcall(DevMenu_DoInvulnSelectedUnits)
	if not ok then
		_fail("bldg1/invuln", "crash: " .. tostring(err))
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_step_burn, 1.0)
		else _cdbg_bldg1_step_burn() end
		return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_invuln_verify, 0.3)
	else _cdbg_bldg1_invuln_verify() end
end

function _cdbg_bldg1_invuln_verify()
	-- Building guard verification: invuln must never be applied to any building entity.
	-- Engine observation: Entity_GetSquad returns nil for ALL buildings; the squad path
	-- is unreachable. Check the entity HP-floor directly via Entity_GetInvulnerableMinCap,
	-- which is the same path DEVMENU_INVULN_SEL uses when it applies invuln.
	local bldg_invulned = false
	if type(Entity_GetInvulnerableMinCap) == "function" then
		for _, eid in ipairs(_cdbg_capture_eids) do
			if not bldg_invulned and eid ~= nil then
				local ok_c, cap = pcall(Entity_GetInvulnerableMinCap, eid)
				if ok_c and type(cap) == "number" and cap > 0 then
					bldg_invulned = true
				end
			end
		end
	end
	if bldg_invulned then
		_cdbg_keep_invuln_failed = true
		_fail("bldg1/invuln", "building invulned — building guard bypassed")
	else
		_pass("bldg1/invuln", "building guard active: no buildings invulned")
	end
	-- Restore: toggle invuln OFF so Burn and Destroy can fire correctly.
	pcall(DevMenu_DoInvulnSelectedUnits)
	_cdbg_log("  bldg1 invuln: restored before burn/destroy")
	-- 0.7s gap for restore to settle before burn fires.
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_step_burn, 0.7)
	else _cdbg_bldg1_step_burn() end
end

function _cdbg_bldg1_step_burn()
	if not _cdbg_check_group_ready("bldg1", _cdbg_skip_bldg_phase_1, _cdbg_bldg1_step_burn, "BUILDING for Burn") then return end
	_cdbg_log("[BLDG1] 4/5 Burn")
	_cdbg_clear_rec()
	_cdbg_capture_eids = {}
	local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg1"))
		and EGroup_FromName("eg_cdbg_bldg1") or nil
	if eg ~= nil and type(EGroup_CountSpawned) == "function" and EGroup_CountSpawned(eg) > 0
		and type(EGroup_ForEach) == "function" then
		EGroup_ForEach(eg, function(_, _, eid)
			if eid ~= nil then _cdbg_capture_eids[#_cdbg_capture_eids + 1] = eid end
		end)
	end
	local ok, err = pcall(DevMenu_DoBurnSelected)
	if not ok then
		_fail("bldg1/burn", "crash: " .. tostring(err))
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_step_destroy, 1.0)
		else _cdbg_bldg1_step_destroy() end
		return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_verify_burn, 0.5)
	else _cdbg_bldg1_verify_burn() end
end

function _cdbg_bldg1_verify_burn()
	local on_fire, checked = 0, 0
	for _, eid in ipairs(_cdbg_capture_eids) do
		if type(Entity_IsOnFire) == "function" then
			checked = checked + 1
			if Entity_IsOnFire(eid) then on_fire = on_fire + 1 end
		elseif type(Entity_IsBurning) == "function" then
			checked = checked + 1
			if Entity_IsBurning(eid) then on_fire = on_fire + 1 end
		end
	end
	-- Keep-guard bypass detection: burn should never ignite a human player's keep.
	-- Match the exact types checked in the DEVMENU_BURN net handler keep guard
	-- (devmenu_mp_gate.scar): "castle", "scar_keep", and "town_center".
	if on_fire > 0 and type(Entity_IsOfType) == "function" then
		for _, eid in ipairs(_cdbg_capture_eids) do
			local _is_burning = (type(Entity_IsOnFire) == "function" and Entity_IsOnFire(eid))
				or (type(Entity_IsBurning) == "function" and Entity_IsBurning(eid))
			if _is_burning then
				local is_keep = Entity_IsOfType(eid, "castle") or Entity_IsOfType(eid, "scar_keep") or Entity_IsOfType(eid, "town_center")
				if is_keep then
					_cdbg_keep_burn_failed = true
					_fail("bldg1/burn", "keep burned — keep guard bypassed: "
						.. on_fire .. "/" .. #_cdbg_capture_eids .. " on fire (includes keep)")
					if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_step_destroy, 0.5)
					else _cdbg_bldg1_step_destroy() end
					return
				end
			end
		end
	end
	if checked == 0 then
		_pass("bldg1/burn", "called without crash (burn detection unavailable)")
	elseif on_fire > 0 then
		_pass("bldg1/burn", on_fire .. "/" .. #_cdbg_capture_eids .. " entities on fire")
	elseif #_cdbg_rec.toasts > 0 then
		_pass("bldg1/burn", "toast fired; entity may be non-burnable type")
	else
		_fail("bldg1/burn", "0 on fire, no toast -- non-burnable selection?")
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_step_destroy, 0.5)
	else _cdbg_bldg1_step_destroy() end
end

function _cdbg_bldg1_step_destroy()
	_cdbg_log("[BLDG1] 5/5 Destroy (LAST)")
	_cdbg_clear_rec()
	local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg1"))
		and EGroup_FromName("eg_cdbg_bldg1") or nil
	_cdbg_capture_eids = {}
	if eg ~= nil and type(EGroup_CountSpawned) == "function" and EGroup_CountSpawned(eg) > 0
		and type(EGroup_ForEach) == "function" then
		EGroup_ForEach(eg, function(_, _, eid)
			if eid ~= nil then _cdbg_capture_eids[#_cdbg_capture_eids + 1] = eid end
		end)
	end
	local ok, err = pcall(DevMenu_DoDestroySelected)
	if not ok then
		_fail("bldg1/destroy", "crash: " .. tostring(err))
		_cdbg_advance(); return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg1_verify_destroy, 0.5)
	else _cdbg_bldg1_verify_destroy() end
end

function _cdbg_bldg1_verify_destroy()
	local dead, total = 0, #_cdbg_capture_eids
	for _, eid in ipairs(_cdbg_capture_eids) do
		if type(Entity_IsAlive) == "function" and not Entity_IsAlive(eid) then dead = dead + 1 end
	end
	if dead > 0 then
		_pass("bldg1/destroy", dead .. "/" .. total .. " entities killed")
	elseif total == 0 or type(Entity_IsAlive) ~= "function" then
		_pass("bldg1/destroy", "called without crash")
	else
		-- All entities still alive. Check if they are keep/TC types: destroy intentionally
		-- skips the human player's keep, so 0 kills is the correct outcome for BLDG1 phase.
		local all_keeps = true
		if type(Entity_IsOfType) == "function" then
			for _, eid in ipairs(_cdbg_capture_eids) do
				if type(Entity_IsAlive) == "function" and Entity_IsAlive(eid) then
					local is_keep = Entity_IsOfType(eid, "castle")
						or Entity_IsOfType(eid, "town_center")
						or Entity_IsOfType(eid, "scar_keep")
					if not is_keep then all_keeps = false; break end
				end
			end
		else
			all_keeps = false
		end
		if all_keeps then
			_pass("bldg1/destroy", "keep protection active: 0/" .. total .. " killed (expected)")
		else
			_fail("bldg1/destroy", "0/" .. total .. " killed (still alive)")
		end
	end
	_cdbg_advance()  -- proceeds to building phase 2
end


-----------------------------------------------------------------------
-- BUILDING PHASE 2 (Phase 3B) -- conditional / secondary building
-----------------------------------------------------------------------

function _cdbg_t_bldg_phase_2()
	_cdbg_log("[PHASE] BLDG2: showing selection prompt")
	if type(DevMenu_ShowToast) == "function" then
		pcall(DevMenu_ShowToast, {
			prefix     = "BLDG2 PHASE: ",
			state_word = "Teleport \226\134\146 Convert \226\134\146 Invuln \226\134\146 Burn \226\134\146 Destroy",
			state_on   = true,
			suffix     = " (5 actions @ 1s)",
		})
	end
	_cdbg_pending_ready_fn = _cdbg_bldg2_start
	_cdbg_pending_skip_fn  = _cdbg_skip_bldg_phase_2
	_cdbg_show_sel_prompt("Select any OTHER building\nPress READY, or SKIP to skip.")
end

function _cdbg_skip_bldg_phase_2()
	_skip("bldg2/teleport", "building phase 2 skipped by user")
	_skip("bldg2/convert",  "building phase 2 skipped by user")
	_skip("bldg2/invuln",   "building phase 2 skipped by user")
	_skip("bldg2/burn",     "building phase 2 skipped by user")
	_skip("bldg2/destroy",  "building phase 2 skipped by user")
	_cdbg_advance()
end

function _cdbg_bldg2_start()
	local eg = nil
	if type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg2") then
		eg = EGroup_FromName("eg_cdbg_bldg2")
		if type(EGroup_Clear) == "function" then EGroup_Clear(eg) end
	elseif type(EGroup_Create) == "function" then
		eg = EGroup_Create("eg_cdbg_bldg2")
	end
	if eg ~= nil and type(Misc_GetSelectedEntities) == "function" then
		Misc_GetSelectedEntities(eg, false)
	end
	local count = (eg ~= nil and type(EGroup_CountSpawned) == "function")
		and EGroup_CountSpawned(eg) or 0
	_cdbg_log("[PHASE] BLDG2: captured " .. count .. " entity/ies")
	if count == 0 then
		_cdbg_log("[SEL] BLDG2: no entities at READY time -- retrying")
		_cdbg_pending_ready_fn = _cdbg_bldg2_start
		_cdbg_pending_skip_fn  = _cdbg_skip_bldg_phase_2
		_cdbg_show_sel_prompt("Select any OTHER building\nPress READY, or SKIP to skip.", true)
		return
	end
	-- Validate: BLDG2 must not contain a human player's keep / town-centre.
	-- DevMenu_DoDestroySelected / DoConvertSelected skip exactly those entities
	-- (via _devmenu_is_human_player_keep), causing a false FAIL at the destroy step.
	-- AI-owned keeps are acceptable -- this guard mirrors the exact skip condition.
	do
		local n = (type(EGroup_CountSpawned) == "function") and EGroup_CountSpawned(eg) or 0
		_cdbg_log("[SEL] BLDG2: checking " .. n .. " entity/ies for human-keep"
			.. "  EGroup_ForEach=" .. type(EGroup_ForEach)
			.. "  EGroup_GetEntityAt=" .. type(EGroup_GetEntityAt)
			.. "  Entity_IsOfType=" .. type(Entity_IsOfType))
		local has_human_keep = false
		if type(EGroup_GetEntityAt) == "function" then
			for i = 1, n do
				local eid = EGroup_GetEntityAt(eg, i)
				local is_tc    = (type(Entity_IsOfType) == "function") and Entity_IsOfType(eid, "town_center") or nil
				local is_keep  = (type(Entity_IsOfType) == "function") and (Entity_IsOfType(eid, "castle") or Entity_IsOfType(eid, "scar_keep")) or nil
				local is_bldg  = (type(Entity_IsOfType) == "function") and Entity_IsOfType(eid, "building") or nil
				local owner    = (type(Entity_GetPlayerOwner) == "function") and Entity_GetPlayerOwner(eid) or nil
				local is_human = (owner ~= nil and type(Player_IsHuman) == "function") and Player_IsHuman(owner) or nil
				local pid      = (owner ~= nil and type(Player_GetID) == "function") and tostring(Player_GetID(owner)) or "?"
				_cdbg_log("  BLDG2 entity[" .. i .. "]: town_center=" .. tostring(is_tc)
					.. " castle=" .. tostring(is_keep) .. " building=" .. tostring(is_bldg)
					.. " human=" .. tostring(is_human) .. " pid=" .. pid)
				if (is_tc or is_keep) and is_human == true then
					has_human_keep = true
				end
			end
		elseif type(EGroup_ForEach) == "function" then
			EGroup_ForEach(eg, function(_, _, eid)
				if _cdbg_entity_is_human_keep(eid) then has_human_keep = true end
			end)
		else
			_cdbg_log("[SEL] BLDG2: WARNING -- EGroup_GetEntityAt and EGroup_ForEach both unavailable; skipping human-keep guard")
		end
		if has_human_keep then
			_cdbg_log("[SEL] BLDG2: human player's keep/TC in selection -- re-prompting")
			_cdbg_pending_ready_fn = _cdbg_bldg2_start
			_cdbg_pending_skip_fn  = _cdbg_skip_bldg_phase_2
			_cdbg_show_sel_prompt(
				"Select a building that is NOT your Keep\n(human keep/TC selected -- Destroy would skip it)", true)
			return
		end
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_teleport, 1.0)
	else _cdbg_bldg2_step_teleport() end
end

function _cdbg_bldg2_step_teleport()
	if not _cdbg_check_group_ready("bldg2", _cdbg_skip_bldg_phase_2, _cdbg_bldg2_step_teleport, "BUILDING for Teleport") then return end
	_cdbg_log("[BLDG2] 1/5 Teleport")
	_cdbg_clear_rec()
	local ok, err = pcall(DevMenu_DoTeleportSelected)
	if ok then
		-- See _cdbg_bldg1_step_teleport for rationale (Phase 2a).
		local _queued = false
		for _, v in ipairs(_cdbg_rec.net_queues) do
			if type(v) == "string" and v:find("TELEPORT") then _queued = true; break end
		end
		if _queued then _pass("bldg2/teleport", "called; net-dispatch DEVMENU_TELEPORT queued")
		else            _pass("bldg2/teleport", "no squads in building selection — teleport correctly no-op (expected; teleport requires squads, not entities)")
		end
	else
		_fail("bldg2/teleport", "crash: " .. tostring(err))
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_convert, 1.0)
	else _cdbg_bldg2_step_convert() end
end

function _cdbg_bldg2_step_convert()
	if not _cdbg_check_group_ready("bldg2", _cdbg_skip_bldg_phase_2, _cdbg_bldg2_step_convert, "BUILDING for Convert") then return end
	_cdbg_log("[BLDG2] 2/5 Convert")
	_cdbg_clear_rec()
	_cdbg_capture_owner = nil
	local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg2"))
		and EGroup_FromName("eg_cdbg_bldg2") or nil
	if eg ~= nil and type(EGroup_ForEach) == "function" then
		EGroup_ForEach(eg, function(_, _, eid)
			if eid ~= nil and _cdbg_capture_owner == nil
				and type(Entity_GetPlayerOwner) == "function" then
				if type(World_OwnsEntity) ~= "function" or World_OwnsEntity(eid) then
					_cdbg_capture_owner = Entity_GetPlayerOwner(eid)
				end
			end
		end)
	end
	local ok, err = pcall(DevMenu_DoConvertSelected)
	if not ok then
		_fail("bldg2/convert", "crash: " .. tostring(err))
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_invuln, 1.0)
		else _cdbg_bldg2_step_invuln() end
		return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_convert_verify, 0.5)
	else _cdbg_bldg2_convert_verify() end
end

function _cdbg_bldg2_convert_verify()
	if _cdbg_capture_owner ~= nil and type(Player_GetID) == "function" then
		local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg2"))
			and EGroup_FromName("eg_cdbg_bldg2") or nil
		local new_owner = nil
		if eg ~= nil and type(EGroup_ForEach) == "function" then
			EGroup_ForEach(eg, function(_, _, eid)
				if eid ~= nil and new_owner == nil
					and type(Entity_GetPlayerOwner) == "function" then
					if type(World_OwnsEntity) ~= "function" or World_OwnsEntity(eid) then
						new_owner = Entity_GetPlayerOwner(eid)
					end
				end
			end)
		end
		if new_owner ~= nil then
			local old_id = Player_GetID(_cdbg_capture_owner)
			local new_id = Player_GetID(new_owner)
			if new_id ~= old_id then
				_pass("bldg2/convert", "owner " .. old_id .. " -> " .. new_id)
			else
				_pass("bldg2/convert", "owner cycled (SP / 1-player); action completed")
			end
		else
			_pass("bldg2/convert", "called without crash (no post-owner)")
		end
	else
		_pass("bldg2/convert", "called without crash")
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_invuln, 0.5)
	else _cdbg_bldg2_step_invuln() end
end

function _cdbg_bldg2_step_invuln()
	if not _cdbg_check_group_ready("bldg2", _cdbg_skip_bldg_phase_2, _cdbg_bldg2_step_invuln, "BUILDING for Invuln") then return end
	_cdbg_log("[BLDG2] 3/5 Invuln Toggle")
	_cdbg_clear_rec()
	_cdbg_capture_eids = {}
	local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg2"))
		and EGroup_FromName("eg_cdbg_bldg2") or nil
	if eg ~= nil and type(EGroup_ForEach) == "function" then
		EGroup_ForEach(eg, function(_, _, eid)
			if eid ~= nil then _cdbg_capture_eids[#_cdbg_capture_eids + 1] = eid end
		end)
	end
	-- Tests game action path: DevMenu_DoInvulnSelectedUnits reads the live selection
	-- (not the named EGroup). The Convert step likely cleared the selection, so
	-- the game action is expected to find no entities — invuln will not be applied.
	local ok_inv, err_inv = pcall(DevMenu_DoInvulnSelectedUnits)
	if not ok_inv then
		_fail("bldg2/invuln", "crash: " .. tostring(err_inv))
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_burn, 1.0)
		else _cdbg_bldg2_step_burn() end
		return
	end
	-- MP-tolerant verify delay: invuln mutation needs ~1.2s after net dispatch.
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_invuln_verify, 1.2)
	else _cdbg_bldg2_invuln_verify() end
end

_cdbg_bldg2_invuln_retry = false
function _cdbg_bldg2_invuln_verify()
	-- Game action accuracy test: DevMenu_DoInvulnSelectedUnits was called in the step.
	-- The game action uses the live selection; if Convert cleared it, invuln is not applied.
	-- Detection uses Entity_GetInvulnerableMinCap (entity HP-floor) directly.
	-- Entity_GetSquad returns nil for ALL buildings; squad path is unreachable.
	if #_cdbg_capture_eids == 0 then
		_fail("bldg2/invuln", "no building entities captured — invuln not attempted")
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_burn, 0.7)
		else _cdbg_bldg2_step_burn() end
		return
	end
	local has_entity_api = type(Entity_SetInvulnerableMinCap) == "function"
	if not has_entity_api then
		_fail("bldg2/invuln", "invuln APIs unavailable — Entity_SetInvulnerableMinCap not present")
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_burn, 0.7)
		else _cdbg_bldg2_step_burn() end
		return
	end
	local bldg_invuln_path = nil
	for _, eid in ipairs(_cdbg_capture_eids) do
		if bldg_invuln_path == nil and eid ~= nil then
			local sq = (type(Entity_GetSquad) == "function") and Entity_GetSquad(eid) or nil
			if sq ~= nil then
				-- Squad path (rare: Entity_GetSquad returns nil for all buildings in practice)
				if type(Squad_GetInvulnerableMinCap) == "function" then
					local ok_c, cap = pcall(Squad_GetInvulnerableMinCap, sq)
					if ok_c and type(cap) == "number" and cap > 0 then
						bldg_invuln_path = "squad"
					end
				end
			else
				-- Entity HP-floor path (primary for buildings: Entity_GetSquad always nil)
				if type(Entity_GetInvulnerableMinCap) == "function" then
					local ok_c, cap = pcall(Entity_GetInvulnerableMinCap, eid)
					if ok_c and type(cap) == "number" and cap > 0 then
						bldg_invuln_path = "entity-HP-floor"
					end
				end
			end
		end
	end
	if bldg_invuln_path ~= nil then
		_pass("bldg2/invuln", "building invuln applied via " .. bldg_invuln_path .. " (action works)"
			.. (_cdbg_bldg2_invuln_retry and " (retry)" or ""))
		_cdbg_bldg2_invuln_retry = false
	else
		-- One MP-tolerant retry at +0.6s before declaring failure.
		if not _cdbg_bldg2_invuln_retry and type(Rule_AddOneShot) == "function" then
			_cdbg_bldg2_invuln_retry = true
			_cdbg_log("  bldg2 invuln verify: retry scheduled at +0.6s")
			Rule_AddOneShot(_cdbg_bldg2_invuln_verify, 0.6)
			return
		end
		-- Diagnostic dump: log min-cap and squad presence for every captured eid
		-- so we can distinguish a real bug (cap stays 0) from selection-cleared paths.
		for i, eid in ipairs(_cdbg_capture_eids) do
			local sq2  = (type(Entity_GetSquad) == "function") and Entity_GetSquad(eid) or nil
			local cap2 = (type(Entity_GetInvulnerableMinCap) == "function")
				and (select(2, pcall(Entity_GetInvulnerableMinCap, eid)) or "err") or "no-api"
			_cdbg_log("  diag eid[" .. i .. "]=" .. tostring(eid)
				.. " sq=" .. tostring(sq2) .. " entity-cap=" .. tostring(cap2))
		end
		local owner_blocked = false
		for _, eid in ipairs(_cdbg_capture_eids) do
			if _cdbg_owner_is_blocked(eid) then owner_blocked = true; break end
		end
		if owner_blocked then
			_pass("bldg2/invuln", "min-cap unchanged — owner has Block Actions ON; net handler correctly suppressed invuln")
		else
			_fail("bldg2/invuln", "invuln min-cap unchanged after net dispatch (after retry) — see diag above")
		end
		_cdbg_bldg2_invuln_retry = false
	end
	-- Restore: clear entity HP-floor so Burn/Destroy can fire correctly.
	-- Direct entity API used (game action finds no entities after Convert anyway).
	for _, eid in ipairs(_cdbg_capture_eids) do
		if eid ~= nil then
			local sq = (type(Entity_GetSquad) == "function") and Entity_GetSquad(eid) or nil
			if sq ~= nil then
				pcall(Squad_SetInvulnerableMinCap, sq, 0, -1)
			else
				pcall(Entity_SetInvulnerableMinCap, eid, 0, -1)
			end
		end
	end
	_cdbg_log("  bldg2 invuln: HP-floor cleared (0) before burn/destroy")
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_burn, 0.7)
	else _cdbg_bldg2_step_burn() end
end

function _cdbg_bldg2_step_burn()
	if not _cdbg_check_group_ready("bldg2", _cdbg_skip_bldg_phase_2, _cdbg_bldg2_step_burn, "BUILDING for Burn") then return end
	_cdbg_log("[BLDG2] 4/5 Burn")
	_cdbg_clear_rec()
	_cdbg_capture_eids = {}
	local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg2"))
		and EGroup_FromName("eg_cdbg_bldg2") or nil
	if eg ~= nil and type(EGroup_CountSpawned) == "function" and EGroup_CountSpawned(eg) > 0
		and type(EGroup_ForEach) == "function" then
		EGroup_ForEach(eg, function(_, _, eid)
			if eid ~= nil then _cdbg_capture_eids[#_cdbg_capture_eids + 1] = eid end
		end)
	end
	local ok, err = pcall(DevMenu_DoBurnSelected)
	if not ok then
		_fail("bldg2/burn", "crash: " .. tostring(err))
		if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_destroy, 1.0)
		else _cdbg_bldg2_step_destroy() end
		return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_verify_burn, 0.5)
	else _cdbg_bldg2_verify_burn() end
end

function _cdbg_bldg2_verify_burn()
	local on_fire, checked = 0, 0
	for _, eid in ipairs(_cdbg_capture_eids) do
		if type(Entity_IsOnFire) == "function" then
			checked = checked + 1
			if Entity_IsOnFire(eid) then on_fire = on_fire + 1 end
		elseif type(Entity_IsBurning) == "function" then
			checked = checked + 1
			if Entity_IsBurning(eid) then on_fire = on_fire + 1 end
		end
	end
	if checked == 0 then
		_pass("bldg2/burn", "called without crash (burn detection unavailable)")
	elseif on_fire > 0 then
		_pass("bldg2/burn", on_fire .. "/" .. #_cdbg_capture_eids .. " entities on fire")
	elseif #_cdbg_rec.toasts > 0 then
		_pass("bldg2/burn", "toast fired; entity may be non-burnable type")
	else
		_fail("bldg2/burn", "0 on fire, no toast -- non-burnable selection?")
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_step_destroy, 0.5)
	else _cdbg_bldg2_step_destroy() end
end

function _cdbg_bldg2_step_destroy()
	_cdbg_log("[BLDG2] 5/5 Destroy (LAST)")
	_cdbg_clear_rec()
	local eg = (type(EGroup_Exists) == "function" and EGroup_Exists("eg_cdbg_bldg2"))
		and EGroup_FromName("eg_cdbg_bldg2") or nil
	_cdbg_capture_eids = {}
	if eg ~= nil and type(EGroup_CountSpawned) == "function" and EGroup_CountSpawned(eg) > 0
		and type(EGroup_ForEach) == "function" then
		EGroup_ForEach(eg, function(_, _, eid)
			if eid ~= nil then _cdbg_capture_eids[#_cdbg_capture_eids + 1] = eid end
		end)
	end
	local ok, err = pcall(DevMenu_DoDestroySelected)
	if not ok then
		_fail("bldg2/destroy", "crash: " .. tostring(err))
		_cdbg_advance(); return
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bldg2_verify_destroy, 0.5)
	else _cdbg_bldg2_verify_destroy() end
end

function _cdbg_bldg2_verify_destroy()
	local dead, total = 0, #_cdbg_capture_eids
	for _, eid in ipairs(_cdbg_capture_eids) do
		if type(Entity_IsAlive) == "function" and not Entity_IsAlive(eid) then dead = dead + 1 end
	end
	if dead > 0 then
		_pass("bldg2/destroy", dead .. "/" .. total .. " entities killed")
	elseif total == 0 or type(Entity_IsAlive) ~= "function" then
		_pass("bldg2/destroy", "called without crash")
	else
		local owner_blocked = false
		for _, eid in ipairs(_cdbg_capture_eids) do
			if _cdbg_owner_is_blocked(eid) then owner_blocked = true; break end
		end
		if owner_blocked then
			_pass("bldg2/destroy", "0/" .. total .. " killed — owner has Block Actions ON; net handler correctly suppressed destroy")
		else
			_fail("bldg2/destroy", "0/" .. total .. " killed (still alive)")
		end
	end
	_cdbg_advance()
end

-----------------------------------------------------------------------
-- Toggle Reset: restore initial toggle states after selection stages (T6-T8).
-- Inserted in queue between _cdbg_t_bldg_phase_2 and _cdbg_t_notifications.
-----------------------------------------------------------------------
function _cdbg_t_reset_toggles()
	_cdbg_log("[TEST] Toggle Reset: restoring initial toggle states after selection stages")
	if type(DevMenu_GetInstantBuildEnabled) == "function" and type(DevMenu_DoInstantBuild) == "function" then
		local cur = DevMenu_GetInstantBuildEnabled()
		if (cur == true) ~= _cdbg_init_instant_build then
			pcall(DevMenu_DoInstantBuild)
			_cdbg_log("  reset: instant_build restored to " .. tostring(_cdbg_init_instant_build))
		else
			_cdbg_log("  reset: instant_build already " .. tostring(cur) .. " (no change)")
		end
	end
	if type(DevMenu_SpeedDefault) == "function" then
		pcall(DevMenu_SpeedDefault)
		_cdbg_log("  reset: speed set to default")
	end
	if type(DevMenu_GetBlockActionsEnabled) == "function" and type(DevMenu_DoToggleBlockActions) == "function" then
		local cur = DevMenu_GetBlockActionsEnabled()
		if (cur == true) ~= _cdbg_init_block_enabled then
			pcall(DevMenu_DoToggleBlockActions)
			_cdbg_log("  reset: block_actions restored to " .. tostring(_cdbg_init_block_enabled))
		else
			_cdbg_log("  reset: block_actions already " .. tostring(cur) .. " (no change)")
		end
	end
	_DEVMENU_VICTIM_PROMPT_ENABLED = true
	_cdbg_log("  reset: _DEVMENU_VICTIM_PROMPT_ENABLED = true")
	_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 0
	_cdbg_log("  reset: _DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 0")
	_cdbg_advance()
end

-----------------------------------------------------------------------
-- T11: Notifications — 7-step interactive VictimPrompt + BlockNotify test
-----------------------------------------------------------------------
-- S1  Toast               → notify/toast
-- S2  VP shown            → notify/victim_prompt, notify/block_notify
--                           Gate: "Close VP with [X], then READY"
-- S3  30s delay           → notify/vp_reshow_delay
-- S4  VP reshown          → notify/vp_reshown
--                           Gate: "Click 'Disable Notifications' on VP, then READY"
-- S5  Validate disable    → notify/disable_flow
-- S5b No-reappear check   → notify/disable_gate  (1s automated)
-- S6  Re-enable gate      → notify/reenable_flow
--                           Gate: "READY to re-enable, SKIP to leave disabled"
-- S7  Finish              → notify/sequence
-----------------------------------------------------------------------

-- Configurable delay before VP re-show.
-- 0.5s: minimal async hop avoids same-tick sequencing issues during debugger runs.
local _CDBG_NOTIFY_RESHOW_DELAY = 0.5   -- seconds between VP close and re-show

-- Pre-disable VP hook count (used in S5b no-reappear check).
local _cdbg_notify_vp_pre_disable = 0

-- Cancel _devmenu_victim_prompt_autohide rule if it is currently scheduled.
-- Called twice per ShowVictimPrompt: once before (stale) and once after (new).
-- Returns true when the rule was found and removed.
local function _cdbg_cancel_vp_autohide()
	if type(Rule_Exists) == "function" and type(Rule_Remove) == "function"
		and type(_devmenu_victim_prompt_autohide) ~= "nil"
		and Rule_Exists(_devmenu_victim_prompt_autohide) then
		pcall(Rule_Remove, _devmenu_victim_prompt_autohide)
		return true
	end
	return false
end

function _cdbg_t_notifications()
	_cdbg_log("[TEST] T11: Notifications (7-step VP/BlockNotify test)")
	_cdbg_clear_rec()
	_cdbg_log("  T11 apis: ShowToast=" .. type(DevMenu_ShowToast)
		.. " ShowVictimPrompt=" .. type(DevMenu_ShowVictimPrompt)
		.. " ShowBlockNotify=" .. type(DevMenu_ShowBlockNotify))
	-- Precondition: VP notifications must be enabled at T11 entry.
	-- ShowVictimPrompt is called directly (bypasses _DEVMENU_VICTIM_PROMPT_ENABLED gate),
	-- so VP fires even when disabled -- flag state is recorded as context, not a hard abort.
	if _DEVMENU_VICTIM_PROMPT_ENABLED == false then
		_fail("notify/victim_prompt_enabled",
			"_DEVMENU_VICTIM_PROMPT_ENABLED is false at T11 entry -- VP notifications disabled; "
			.. "direct ShowVictimPrompt calls still fire (bypass)")
	end

	-- S1: Toast (immediate)
	if type(DevMenu_ShowToast) == "function" then
		local ok, err = pcall(DevMenu_ShowToast, {
			prefix     = "CDBG notify test — ",
			state_word = "toast OK",
			state_on   = true,
			suffix     = " (S1/7)",
		})
		if ok and #_cdbg_rec.toasts > 0 then _pass("notify/toast", "fired and recorded")
		elseif ok then                         _pass("notify/toast", "called without crash")
		else _fail("notify/toast", "crash: " .. tostring(err)) end
	else
		_skip("notify/toast", "DevMenu_ShowToast not available")
	end

	-- S2 deferred 1s.
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_notify_s2_show_vp, 1.0)
	else _cdbg_notify_s2_show_vp() end
end

-- S2: Show VictimPrompt with autohide cancelled.  BlockNotify guides user to close it.
function _cdbg_notify_s2_show_vp()
	_cdbg_log("[TEST] T11 S2: VictimPrompt shown (no auto-close enforced)")
	_cdbg_cancel_vp_autohide()   -- cancel any stale autohide from a previous VP
	if type(DevMenu_ShowVictimPrompt) == "function" then
		local ok, err = pcall(DevMenu_ShowVictimPrompt, "CDBG-TestAttacker", "debug_attack")
		local autohide_ok = _cdbg_cancel_vp_autohide()   -- cancel the newly installed rule
		if ok then
			local detail = autohide_ok
				and "shown; autohide cancelled (no auto-close)"
				or  "shown (autohide cancellation unavailable; may auto-close in 10s)"
			_pass("notify/victim_prompt",
				detail .. "; hook count=" .. #_cdbg_rec.victim_prompts)
		else
			_fail("notify/victim_prompt", "crash: " .. tostring(err))
		end
	else
		_skip("notify/victim_prompt", "DevMenu_ShowVictimPrompt not available")
	end
	-- BlockNotify: guidance for user (S2).
	if type(DevMenu_ShowBlockNotify) == "function" then
		local ok, err = pcall(DevMenu_ShowBlockNotify, "CDBG-Guide")
		if ok then
			_pass("notify/block_notify",
				"called without crash; hook count=" .. #_cdbg_rec.block_notifies)
		else
			_fail("notify/block_notify", "crash: " .. tostring(err))
		end
	else
		_skip("notify/block_notify", "DevMenu_ShowBlockNotify not available")
	end
	-- Arm the VP Close hook to auto-advance to S3.
	-- _cdbg_pending_ready_fn kept as manual fallback (e.g. mock/no-Rule environments).
	_cdbg_notify_expecting_close = true
	_cdbg_notify_close_detected  = false
	_cdbg_pending_ready_fn = _cdbg_notify_s3_delay_start
	_cdbg_pending_skip_fn  = _cdbg_notify_skip_vp_tests
	_cdbg_show_sel_prompt(
		"[S2] VictimPrompt is now visible (auto-close disabled).\n"
		.. "Close it with the [X] button (auto-advances).\n"
		.. "Press SKIP to skip all remaining VP tests.")
end

-- SKIP handler for S2–S7 (user chose to bypass all VP tests).
function _cdbg_notify_skip_vp_tests()
	_cdbg_log("[TEST] T11: user skipped VP tests at S2")
	_cdbg_notify_expecting_close = false
	if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
	_skip("notify/vp_close_verify",      "VP tests skipped at S2")
	_skip("notify/close_gate_active",    "VP tests skipped at S2")
	_skip("notify/vp_reshow_delay",      "VP tests skipped at S2")
	_skip("notify/reshow_timing",        "VP tests skipped at S2")
	_skip("notify/vp_reshown",           "VP tests skipped at S2")
	_skip("notify/disable_flow",         "VP tests skipped at S2")
	_skip("notify/disable_flag_mismatch","VP tests skipped at S2")
	_skip("notify/disable_vp_visible",   "VP tests skipped at S2")
	_skip("notify/disable_gate",         "VP tests skipped at S2")
	_skip("notify/disable_gate_active",  "VP tests skipped at S2")
	_skip("notify/reenable_flow",        "VP tests skipped at S2")
	_skip("notify/reenable_gate_active", "VP tests skipped at S2")
	_pass("notify/sequence", "partial sequence (VP tests skipped at S2)")
	_cdbg_advance()
end

-- S3: VP closed (via hook auto-advance or manual READY).  Assert hidden, then re-show after delay.
function _cdbg_notify_s3_delay_start()
	local source = _cdbg_notify_close_detected and "hook" or "READY/manual"
	_cdbg_log("[TEST] T11 S3: VP closed (" .. source .. "); starting "
		.. _CDBG_NOTIFY_RESHOW_DELAY .. "s delay")
	-- Ensure VP is actually hidden (may have been hidden by the Close hook already).
	if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
	-- Assert VP is now hidden.
	if _cdbg_vp_is_visible() then
		_fail("notify/vp_close_verify",
			"VP still visible after Close (source=" .. source .. ") -- HideVictimPrompt did not hide it")
	else
		_pass("notify/vp_close_verify",
			"VP confirmed hidden after Close (source=" .. source .. ")")
	end
	_pass("notify/vp_reshow_delay",
		string.format("%.1fs delay started before re-show", _CDBG_NOTIFY_RESHOW_DELAY))
	-- Assert the close timer was actually set by VictimPromptClose.  Catches the case
	-- where VP is hidden but CLOSE_UNTIL was never armed (cooldown broken).
	local _cu_check = _DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL or 0
	local _gt_check = (type(World_GetGameTime) == "function") and World_GetGameTime() or 0
	if _cu_check > _gt_check then
		_pass("notify/close_timer_set",
			"CLOSE_UNTIL=" .. tostring(_cu_check) .. " gametime=" .. tostring(_gt_check)
			.. " gap=" .. string.format("%.1fs", _cu_check - _gt_check))
	else
		_fail("notify/close_timer_set",
			"CLOSE_UNTIL not set after VictimPromptClose -- close timer broken"
			.. "  (CLOSE_UNTIL=" .. tostring(_cu_check) .. " gametime=" .. tostring(_gt_check) .. ")")
	end
	-- Active close-cooldown gate test: verify _DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL blocks VP.
	-- This mirrors the S5b disable_gate_active check but for the 30s Close cooldown path.
	if type(DevMenu_TestVictimPromptGate) == "function" then
		local pre = #_cdbg_rec.victim_prompts
		pcall(DevMenu_TestVictimPromptGate, "CDBG-CloseGateTest", "close_gate_check")
		local post = #_cdbg_rec.victim_prompts
		if post > pre then
			_fail("notify/close_gate_active",
				"_devmenu_maybe_show_victim_prompt showed VP while Close cooldown active "
				.. "(delta=" .. (post - pre) .. ") -- CLOSE_UNTIL not honoured")
			if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
		else
			_pass("notify/close_gate_active",
				"gate suppressed VP during 30s Close cooldown (DevMenu_TestVictimPromptGate)")
		end
	else
		_skip("notify/close_gate_active",
			"DevMenu_TestVictimPromptGate not available (devmenu_mp_gate.scar not updated)")
	end
	if type(DevMenu_ShowToast) == "function" then
		pcall(DevMenu_ShowToast, {
			prefix     = "CDBG T11 — ",
			state_word = "VP closed",
			state_on   = false,
			suffix     = string.format(" re-showing in %.1fs", _CDBG_NOTIFY_RESHOW_DELAY),
		})
	end
	if type(Rule_AddOneShot) == "function" then
		Rule_AddOneShot(_cdbg_notify_s4_reshow, _CDBG_NOTIFY_RESHOW_DELAY)
	else
		_cdbg_notify_s4_reshow()
	end
end

-- S4: Re-show VP after delay.  BlockNotify guides user to click Disable Notifications.
function _cdbg_notify_s4_reshow()
	_cdbg_log("[TEST] T11 S4: VP re-shown after delay; awaiting Disable button click")
	-- Timing assertion: verify the re-show delay was respected.
	if _cdbg_vp_last_hide_time ~= nil and type(World_GetGameTime) == "function" then
		local elapsed = World_GetGameTime() - _cdbg_vp_last_hide_time
		if elapsed >= _CDBG_NOTIFY_RESHOW_DELAY * 0.8 then
			_pass("notify/reshow_timing",
				string.format("re-shown after %.2fs (expected >=%.1fs)", elapsed, _CDBG_NOTIFY_RESHOW_DELAY))
		else
			_fail("notify/reshow_timing",
				string.format("re-shown too early: %.2fs < expected %.1fs", elapsed, _CDBG_NOTIFY_RESHOW_DELAY))
		end
	else
		_skip("notify/reshow_timing", "hide timestamp or World_GetGameTime unavailable")
	end
	_cdbg_cancel_vp_autohide()   -- cancel any stale autohide
	if type(DevMenu_ShowVictimPrompt) == "function" then
		local ok, err = pcall(DevMenu_ShowVictimPrompt, "CDBG-TestAttacker", "debug_reshow")
		local autohide_ok = _cdbg_cancel_vp_autohide()   -- cancel the newly installed rule
		if ok then
			local detail = autohide_ok
				and string.format("re-shown after %.1fs delay; autohide cancelled", _CDBG_NOTIFY_RESHOW_DELAY)
				or  string.format("re-shown after %.1fs delay (autohide cancellation unavailable)", _CDBG_NOTIFY_RESHOW_DELAY)
			_pass("notify/vp_reshown",
				detail .. "; hook count=" .. #_cdbg_rec.victim_prompts)
		else
			_fail("notify/vp_reshown", "crash on re-show: " .. tostring(err))
		end
	else
		_skip("notify/vp_reshown", "DevMenu_ShowVictimPrompt not available")
	end
	-- BlockNotify: guide user to click Disable Notifications on the VP.
	if type(DevMenu_ShowBlockNotify) == "function" then
		pcall(DevMenu_ShowBlockNotify, "CDBG-Guide")
	end
	-- Arm the VictimPromptDisable hook to auto-advance to S5.
	-- _cdbg_pending_ready_fn kept as manual fallback.
	_cdbg_notify_expecting_disable = true
	_cdbg_notify_disable_detected  = false
	_cdbg_pending_ready_fn = _cdbg_notify_s5_validate_disable
	_cdbg_pending_skip_fn  = _cdbg_notify_skip_disable
	_cdbg_show_sel_prompt(
		"[S4] VP re-shown (auto-close disabled).\n"
		.. "Click the 'Disable Notifications' button on the VP (auto-advances).\n"
		.. "Press SKIP to skip the disable and re-enable tests.")
end

-- SKIP handler for S4–S6 (user chose to skip the disable/re-enable tests).
function _cdbg_notify_skip_disable()
	_cdbg_log("[TEST] T11: user skipped disable tests at S4")
	_cdbg_notify_expecting_disable = false
	if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
	_skip("notify/disable_flow",          "disable tests skipped at S4")
	_skip("notify/disable_flag_mismatch", "disable tests skipped at S4")
	_skip("notify/disable_vp_visible",    "disable tests skipped at S4")
	_skip("notify/disable_gate",          "disable tests skipped at S4")
	_skip("notify/disable_gate_active",   "disable tests skipped at S4")
	_skip("notify/reenable_flow",         "disable tests skipped at S4")
	_skip("notify/reenable_gate_active",  "disable tests skipped at S4")
	_cdbg_notify_s7_finish("partial sequence (disable tests skipped at S4)")
end

-- S5: Validate that the Disable button was actually clicked (hook fired).
-- May be reached via hook auto-advance (Disable button) or manual READY fallback.
function _cdbg_notify_s5_validate_disable()
	_cdbg_log("[TEST] T11 S5: validating Disable button click; detected="
		.. tostring(_cdbg_notify_disable_detected)
		.. " flag=" .. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED)
		.. " vp_visible=" .. tostring(_cdbg_vp_is_visible()))
	_cdbg_notify_expecting_disable = false
	if _cdbg_notify_disable_detected then
		_pass("notify/disable_flow",
			"VP disabled via 'Disable Notifications' button (hook fired)")
		-- Verify the original function actually set the flag.
		if _DEVMENU_VICTIM_PROMPT_ENABLED ~= false then
			_fail("notify/disable_flag_mismatch",
				"VictimPromptDisable was called but _DEVMENU_VICTIM_PROMPT_ENABLED is still "
				.. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED) .. " (expected false)")
		else
			_pass("notify/disable_flag_mismatch",
				"flag correctly false after Disable click")
		end
		-- Verify VP is now hidden.
		if _cdbg_vp_is_visible() then
			_fail("notify/disable_vp_visible",
				"VP is still visible after Disable Notifications was clicked")
		else
			_pass("notify/disable_vp_visible",
				"VP confirmed hidden after Disable click")
		end
	else
		_fail("notify/disable_flow",
			"VictimPromptDisable was not called (READY pressed without clicking Disable) — "
			.. "click the 'Disable Notifications' button on the VP")
		_skip("notify/disable_flag_mismatch", "disable_flow not detected")
		_skip("notify/disable_vp_visible",    "disable_flow not detected")
		-- Force flag false so S5b can still exercise the gate check.
		_DEVMENU_VICTIM_PROMPT_ENABLED = false
		_cdbg_log("  S5: forced flag=false for S5b gate test")
	end
	-- S5b: record VP count and wait 1s to check for reappear.
	_cdbg_notify_vp_pre_disable = #_cdbg_rec.victim_prompts
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_notify_s5b_verify, 1.0)
	else _cdbg_notify_s5b_verify() end
end

-- S5b: No-reappear check (automated, 1s wait already elapsed).
function _cdbg_notify_s5b_verify()
	local vp_after  = #_cdbg_rec.victim_prompts
	local vp_before = _cdbg_notify_vp_pre_disable
	local delta = vp_after - vp_before
	_cdbg_log("  T11 S5b: vp_before=" .. vp_before .. " vp_after=" .. vp_after
		.. " delta=" .. delta .. " flag=" .. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED))
	-- Passive: verify no VP appeared during the 1s wait.
	if delta == 0 then
		_pass("notify/disable_gate",
			"VP did not fire while flag=false (1s passive check)")
	else
		_fail("notify/disable_gate",
			"VP appeared while flag=false: delta=" .. delta
			.. " (vp_before=" .. vp_before .. " vp_after=" .. vp_after .. ")")
	end
	-- Active: call the gated VP path and verify suppression.
	-- DevMenu_TestVictimPromptGate wraps _devmenu_maybe_show_victim_prompt (the real gate).
	-- If the function is unavailable (devmenu_mp_gate.scar not updated), skip gracefully.
	if type(DevMenu_TestVictimPromptGate) == "function" then
		local pre = #_cdbg_rec.victim_prompts
		pcall(DevMenu_TestVictimPromptGate, "CDBG-SuppressTest", "suppress_check")
		local post = #_cdbg_rec.victim_prompts
		if post > pre then
			_fail("notify/disable_gate_active",
				"_devmenu_maybe_show_victim_prompt showed VP while flag=false "
				.. "(delta=" .. (post - pre) .. ")")
			-- VP was unexpectedly shown — hide it before continuing.
			if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
		else
			_pass("notify/disable_gate_active",
				"gated VP call suppressed while flag=false (DevMenu_TestVictimPromptGate)")
		end
	else
		_skip("notify/disable_gate_active",
			"DevMenu_TestVictimPromptGate not available (devmenu_mp_gate.scar not updated)")
	end
	-- Final visibility check: VP must still be hidden after S5b.
	if _cdbg_vp_is_visible() then
		_fail("notify/disable_gate",
			"VP became visible during S5b passive wait (post-check)")
	end
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_notify_s6_reenable_gate, 0.3)
	else _cdbg_notify_s6_reenable_gate() end
end

-- S6: Re-enable gate -- user chooses to restore notifications before T12.
function _cdbg_notify_s6_reenable_gate()
	_cdbg_log("[TEST] T11 S6: re-enable gate")
	-- Show contextual toast (VP is disabled so BlockNotify would be misleading here).
	if type(DevMenu_ShowToast) == "function" then
		DevMenu_ShowToast({ prefix = "Notifications ", state_word = "DISABLED",
			state_on = false, suffix = " — press READY to re-enable" })
	end
	_cdbg_pending_ready_fn = _cdbg_notify_s6_reenable_ready
	_cdbg_pending_skip_fn  = _cdbg_notify_s6_reenable_skip
	_cdbg_show_sel_prompt(
		"[S6] Notifications are currently DISABLED.\n"
		.. "Press READY to re-enable for the rest of CDBG (recommended).\n"
		.. "Press SKIP to leave them disabled.")
end

function _cdbg_notify_s6_reenable_ready()
	_cdbg_log("  T11 S6: re-enabling VP notifications")
	-- Use DevMenu_VictimPromptEnable if available; else set flag directly (backward compat).
	if type(DevMenu_VictimPromptEnable) == "function" then
		pcall(DevMenu_VictimPromptEnable)
	else
		_DEVMENU_VICTIM_PROMPT_ENABLED = true
	end
	if _DEVMENU_VICTIM_PROMPT_ENABLED ~= false then
		_pass("notify/reenable_flow", "notifications re-enabled (DevMenu_VictimPromptEnable used)")
	else
		_fail("notify/reenable_flow", "re-enable failed — flag still false after enable call")
	end
	-- Active gate test: verify the gate fires a VP event after re-enable.
	-- This answers whether the underlying function is intact after a Disable cycle.
	-- Mirrors S5b notify/disable_gate_active (pass/fail logic inverted).
	if type(DevMenu_TestVictimPromptGate) == "function" then
		-- Reset CLOSE_UNTIL so the T11 S3 close cooldown (30s) doesn't suppress this
		-- gate test.  Same rationale as _cdbg_bsim_begin: CDBG S3 fired
		-- VictimPromptClose which sets CLOSE_UNTIL = World_GetGameTime() + 30.0;
		-- S6 runs only ~3 sim-seconds later, so the cooldown would still be active.
		_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 0
		local pre = #_cdbg_rec.victim_prompts
		pcall(DevMenu_TestVictimPromptGate, "CDBG-ReenableTest", "reenable_gate_check")
		local post = #_cdbg_rec.victim_prompts
		if post > pre then
			_pass("notify/reenable_gate_active",
				"gate fires VP after re-enable (DataContext intact; delta=" .. (post - pre) .. ")")
			if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
		else
			_fail("notify/reenable_gate_active",
				"gate did not fire VP after re-enable — DataContext may be nil or stale")
		end
	else
		_skip("notify/reenable_gate_active",
			"DevMenu_TestVictimPromptGate not available (devmenu_mp_gate.scar not updated)")
	end
	_cdbg_notify_s7_finish("7-step notification sequence complete")
end

function _cdbg_notify_s6_reenable_skip()
	_cdbg_log("  T11 S6: user left notifications disabled")
	_skip("notify/reenable_flow",        "user chose not to re-enable notifications")
	_skip("notify/reenable_gate_active", "user chose not to re-enable notifications")
	_cdbg_notify_s7_finish("7-step notification sequence complete (notifications left disabled)")
end

-- S7: Log summary and advance to T12.
function _cdbg_notify_s7_finish(seq_detail)
	_cdbg_log("  T11 output:  toasts=" .. #_cdbg_rec.toasts
		.. "  victim_prompts=" .. #_cdbg_rec.victim_prompts
		.. "  block_notifies=" .. #_cdbg_rec.block_notifies)
	_cdbg_log("  Expected: >=2 VP calls; >=2 BlockNotify; >=1 toast")
	_pass("notify/sequence", seq_detail or "7-step notification sequence complete")
	if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
	_cdbg_advance()
end



-----------------------------------------------------------------------
-- T12: Block Actions -- 3-stage AI-attacker block simulation (unit/bldg/keep)
-----------------------------------------------------------------------
-- Local player (victim) sees every eligible block toast for each entity type.
-- AI player used as simulated attacker. Actions fire every 1s; VictimPrompt visible for 10s.
-- Single gate prompt only if block is disabled; auto-starts if already enabled.
-- Restores initial block state at end. Final confirmation never auto-closes.

local _CDBG_BSIM_INTERVAL = 1.0    -- seconds between block sim actions
local _CDBG_BSIM_VP_DWELL = 10.0   -- seconds VictimPrompt stays visible after each action

-- Finds the first non-human player; returns their display name via Player_GetDisplayName.
-- Same source as the owner name used in the convert verify steps.
local function _bsim_get_attacker()
	if type(World_GetPlayerCount) ~= "function"
		or type(World_GetPlayerAt) ~= "function" then
		return "AI_Opponent", nil
	end
	-- Shared: resolve display name and civ flag icon for a player object.
	local function _resolve(p)
		local name = "Player"
		if type(Player_GetDisplayName) == "function" then
			-- Player_GetDisplayName returns a utf8_mt table {LocString=<string>}.
			-- Access .LocString for the readable name (mirrors _devmenu_player_info).
			-- Concatenation ("" .. utf8_mt) and tostring() both give "utf8_mt: 0x..."
			-- because utf8_mt defines __tostring but not __concat, so neither works.
			local ok_n, ln = pcall(Player_GetDisplayName, p)
			if ok_n and ln ~= nil then
				if type(ln) == "table" and ln.LocString ~= nil then
					name = tostring(ln.LocString)
				else
					name = tostring(ln)
				end
			end
		end
		-- If tostring still gave a raw pointer string, fall back to "Player <ID>".
		if (name == "" or name == "Player" or name:sub(1, 7) == "utf8_mt")
			and type(Player_GetID) == "function" then
			local ok_id, pid = pcall(Player_GetID, p)
			if ok_id and pid ~= nil then name = "Player " .. tostring(pid) end
		end
		local flag = nil
		if type(Player_GetRaceName) == "function" then
			local ok_r, race = pcall(Player_GetRaceName, p)
			if ok_r and race ~= nil and race ~= "" then
				if type(_PlayerUI_RaceImage) == "table" and _PlayerUI_RaceImage[race] ~= nil then
					flag = _PlayerUI_RaceImage[race]
				elseif type(_DEVMENU_RACE_FLAG_BASE) == "string" then
					local key = (type(_DEVMENU_RACE_FLAG_OVERRIDES) == "table"
						and _DEVMENU_RACE_FLAG_OVERRIDES[race]) or race
					flag = _DEVMENU_RACE_FLAG_BASE .. tostring(key) .. ".png"
				end
			end
		end
		return name, flag
	end
	-- Tier 1: prefer a non-human (AI) opponent.
	if type(Player_IsHuman) == "function" then
		for i = 1, World_GetPlayerCount() do
			local p = World_GetPlayerAt(i)
			if p ~= nil and not Player_IsHuman(p) then
				return _resolve(p)
			end
		end
	end
	-- Tier 2: fall back to any non-local player (human peer in MP, or solo debug mode).
	for i = 1, World_GetPlayerCount() do
		local p = World_GetPlayerAt(i)
		if p ~= nil then
			local is_local = type(Misc_IsLocalPlayer) == "function" and Misc_IsLocalPlayer(p)
			if not is_local then
				return _resolve(p)
			end
		end
	end
	return "AI_Opponent", nil
end

local _BSIM_SEQ_UNITS = { "teleport", "convert", "invuln", "destroy" }
local _BSIM_SEQ_BLDG  = { "teleport", "convert", "invuln", "burn", "destroy" }
local _BSIM_STAGE_LABEL = { [1] = "UNIT", [2] = "BUILDING", [3] = "KEEP" }

function _cdbg_t_block_actions()
	_cdbg_log("[TEST] T12: Block Actions -- 3-stage AI-attacker block simulation")
	if type(DevMenu_DoToggleBlockActions) ~= "function" then
		_skip("block_actions/toggle", "DevMenu_DoToggleBlockActions not available")
		_cdbg_advance(); return
	end
	-- Capture initial state so it can be restored exactly at the end.
	local get_fn = (type(DevMenu_GetBlockActionsEnabled) == "function")
		and DevMenu_GetBlockActionsEnabled or nil
	local before = get_fn and get_fn() or nil
	_cdbg_bsim_was_enabled = (before == true)
	_cdbg_log("  block enabled before sim: " .. tostring(_cdbg_bsim_was_enabled))
	if _cdbg_bsim_was_enabled then
		-- Already on: begin immediately, no prompt needed.
		_pass("block_actions/toggle_on", "block already enabled -- simulation starting")
		_cdbg_bsim_begin()
	else
		-- Not enabled: show single gate prompt (only gating point in this phase).
		if type(DevMenu_ShowToast) == "function" then
			pcall(DevMenu_ShowToast, {
				prefix     = "BLOCK SIM: ",
				state_word = "Block Actions is DISABLED",
				state_on   = false,
				suffix     = " -- press READY to enable",
			})
		end
		_cdbg_pending_ready_fn = _cdbg_bsim_pre_enable
		_cdbg_pending_skip_fn  = _cdbg_bsim_pre_skip
		_cdbg_show_sel_prompt("Enable Block Actions to start simulation.")
	end
end

function _cdbg_bsim_pre_enable()
	local ok, err = pcall(DevMenu_DoToggleBlockActions)
	if not ok then
		_fail("block_actions/toggle_on", "crash: " .. tostring(err))
		_cdbg_advance(); return
	end
	local get_fn = (type(DevMenu_GetBlockActionsEnabled) == "function")
		and DevMenu_GetBlockActionsEnabled or nil
	local after = get_fn and get_fn() or nil
	if after == true then
		_pass("block_actions/toggle_on", "enabled by user (false -> true)")
	else
		_pass("block_actions/toggle_on", "called without crash (no state getter)")
	end
	_cdbg_bsim_begin()
end

function _cdbg_bsim_pre_skip()
	_skip("block_actions/sim_sequence", "block settings check skipped by user")
	_cdbg_advance()
end

function _cdbg_bsim_gate_reshow()
	-- READY restarts gate flow; SKIP advances past T12.
	_cdbg_log("[TEST] T12: re-showing gate prompt")
	_cdbg_pending_ready_fn = _cdbg_bsim_pre_enable
	_cdbg_pending_skip_fn  = _cdbg_bsim_pre_skip
	_cdbg_show_sel_prompt("Enable Block Actions to start simulation.")
end

-- Mid-bsim VP-disable handler: restores the VP flag after DevMenu_VictimPromptDisable
-- has run (which sets _DEVMENU_VICTIM_PROMPT_ENABLED = false).  T12 continues
-- uninterrupted because bsim calls ShowVictimPrompt directly, bypassing that gate.
function _cdbg_bsim_restore_vp_flag()
	-- No-op: bsim now uses DevMenu_TestVictimPromptGate (gate path), so the
	-- _DEVMENU_VICTIM_PROMPT_ENABLED flag is intentionally left at whatever the
	-- user set it to -- subsequent bsim actions are gated accordingly, replicating
	-- live gameplay behaviour.  Function kept to avoid errors if somehow called.
end

function _cdbg_bsim_hide_vp()
	if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
	-- Assert VP is actually hidden after the dwell period ends.
	if _cdbg_vp_is_visible() then
		_fail("block_actions/vp_hide_failed",
			"VP still visible after dwell hide in stage=" .. tostring(_cdbg_bsim_stage)
			.. " action=" .. tostring(_cdbg_bsim_action))
	end
end

function _cdbg_bsim_begin()
	_cdbg_bsim_aborted = false
	_cdbg_bsim_vp_disabled_count = 0
	_cdbg_bsim_vp_shown          = 0
	_cdbg_bsim_vp_gated          = 0
	_cdbg_bsim_vp_enabled_count  = 0
	_cdbg_bsim_verb_gated        = {}
	_cdbg_bsim_verb_shown        = {}
	-- Drop any rec entries from T11 or the gate-phase toast so T12 counts are exact.
	_cdbg_clear_rec()
	_cdbg_bsim_stage         = 0
	_cdbg_bsim_action        = 0
	-- Reset VP gate state so T11's Close cooldown (30s from T11 S3) and any leftover
	-- Disable flag do not suppress bsim gate calls.  bsim uses DevMenu_TestVictimPromptGate
	-- (the real gate path), so an active CLOSE_UNTIL would suppress all 14 VP calls if
	-- not cleared here.
	_DEVMENU_VICTIM_PROMPT_ENABLED     = true
	_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 0
	_cdbg_log("  bsim: VP flags reset (ENABLED=true, CLOSE_UNTIL=0)")
	_cdbg_bsim_attacker, _cdbg_bsim_attacker_flag = _bsim_get_attacker()
	_cdbg_log("[BSIM] attacker: " .. _cdbg_bsim_attacker)
	_cdbg_bsim_next_stage()
end

function _cdbg_bsim_next_stage()
	if _cdbg_bsim_aborted then return end
	_cdbg_bsim_stage  = _cdbg_bsim_stage + 1
	_cdbg_bsim_action = 0
	if _cdbg_bsim_stage > 3 then
		_cdbg_bsim_done()
		return
	end
	-- Per-stage CLOSE_UNTIL reset (Phase 1b leak fix, 2026-05-25):
	-- bsim_begin clears CLOSE_UNTIL once, but stage 1 (UNIT) actions can fire
	-- VictimPromptClose internally (via DevMenu_HideVictimPrompt callbacks or
	-- auto-hide timers) which re-arms CLOSE_UNTIL=gametime+30.  By stage 2
	-- (BUILDING) the cooldown is still active and gates every VP for the rest
	-- of the sim -- exactly the regression observed in the 2026-05-25 MP run
	-- (4 shown / 10 gated; BUILDING+KEEP all suppressed).  Reset here so each
	-- stage starts with a clean gate; ENABLED is left at user-chosen state.
	if (_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL or 0) > 0 then
		_cdbg_log("[BSIM] Stage " .. _cdbg_bsim_stage .. " entry: clearing stale CLOSE_UNTIL="
			.. tostring(_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL)
			.. " (gametime=" .. (type(World_GetGameTime) == "function"
				and tostring(World_GetGameTime()) or "?") .. ")")
	end
	_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 0
	local stage = _cdbg_bsim_stage
	local label = _BSIM_STAGE_LABEL[stage]
	local seq   = (stage == 1) and _BSIM_SEQ_UNITS or _BSIM_SEQ_BLDG
	_cdbg_log("[BSIM] Stage " .. stage .. " (" .. label .. ") -- " .. #seq .. " actions")
	-- Stage announce toast: visual header replacing the removed per-stage prompt.
	if type(DevMenu_ShowToast) == "function" then
		pcall(DevMenu_ShowToast, {
			prefix     = "Block Sim: ",
			state_word = label .. " STAGE",
			state_on   = true,
			suffix     = " -- " .. #seq .. " actions @ " .._CDBG_BSIM_INTERVAL  .. "s each",
		})
	end
	-- Auto-start: no per-stage READY/SKIP prompt. First action fires after 1s.
	if type(Rule_AddOneShot) == "function" then Rule_AddOneShot(_cdbg_bsim_run_action, 1.0)
	else _cdbg_bsim_run_action() end
end

function _cdbg_bsim_run_action()
	if _cdbg_bsim_aborted then return end
	_cdbg_bsim_action = _cdbg_bsim_action + 1
	local stage  = _cdbg_bsim_stage
	local label  = _BSIM_STAGE_LABEL[stage] or "?"
	local seq    = (stage == 1) and _BSIM_SEQ_UNITS or _BSIM_SEQ_BLDG
	local action = seq[_cdbg_bsim_action]
	if action == nil then
		_cdbg_bsim_next_stage()
		return
	end
	local n, total = _cdbg_bsim_action, #seq
	_cdbg_log("[BSIM] Stage=" .. label .. " " .. n .. "/" .. total .. ": " .. action)
	-- Blocked-action toast: player name+flag follows the convert toast pattern.
	if type(DevMenu_ShowToast) == "function" then
		pcall(DevMenu_ShowToast, {
			prefix     = "blocked: ",
			state_word = string.upper(action),
			state_on   = false,
			suffix     = " on " .. label .. " (" .. n .. "/" .. total .. ")",
			flag       = _cdbg_bsim_attacker_flag,
			name       = _cdbg_bsim_attacker,
		})
		_pass("block_actions/sim_" .. string.lower(label) .. "/" .. action,
			_cdbg_bsim_attacker .. " blocked " .. action .. " on " .. label)
	end
	-- VictimPrompt: cancel pending auto-hide rules before showing next prompt.
	-- (a) Cancel CDBG's own dwell timer from the previous action.
	if type(Rule_Exists) == "function" and Rule_Exists(_cdbg_bsim_hide_vp)
		and type(Rule_Remove) == "function" then
		pcall(Rule_Remove, _cdbg_bsim_hide_vp)
	end
	-- (b) Cancel the internal 10s auto-hide rule that DevMenu_ShowVictimPrompt adds.
	--     With 14 actions at 1s intervals those pile up and start firing mid-bsim,
	--     hiding the VP while the next action's prompt should still be visible.
	if type(Rule_Exists) == "function" and type(_devmenu_victim_prompt_autohide) ~= "nil"
		and Rule_Exists(_devmenu_victim_prompt_autohide)
		and type(Rule_Remove) == "function" then
		pcall(Rule_Remove, _devmenu_victim_prompt_autohide)
	end
	-- Use the gate path to replicate live gameplay: Disable and Close-cooldown suppression
	-- are honoured, exactly as real attack handlers do via _devmenu_maybe_show_victim_prompt.
	if type(DevMenu_TestVictimPromptGate) == "function" then
		local pre_vp = #_cdbg_rec.victim_prompts
		pcall(DevMenu_TestVictimPromptGate, _cdbg_bsim_attacker, action)
		if #_cdbg_rec.victim_prompts > pre_vp then
			_cdbg_bsim_vp_shown = _cdbg_bsim_vp_shown + 1
			_cdbg_bsim_verb_shown[action] = (_cdbg_bsim_verb_shown[action] or 0) + 1
			-- VP was shown; assert it is actually visible.
			if not _cdbg_vp_is_visible() then
				_fail("block_actions/sim_vp_invisible",
					"VP not visible after gate call: stage=" .. label
					.. " action=" .. action .. " (" .. n .. "/" .. total .. ")")
			end
		else
			_cdbg_bsim_vp_gated = _cdbg_bsim_vp_gated + 1
			_cdbg_bsim_verb_gated[action] = (_cdbg_bsim_verb_gated[action] or 0) + 1
			local _diag = "enabled=" .. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED)
				.. "  close_until=" .. tostring(_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL or 0)
				.. "  gametime=" .. (type(World_GetGameTime) == "function"
					and tostring(World_GetGameTime()) or "?")
			_cdbg_log("[BSIM] VP gated: stage=" .. label .. " " .. n .. "/" .. total
				.. " action=" .. action .. "  (" .. _diag .. ")")
		end
	elseif type(DevMenu_ShowVictimPrompt) == "function" then
		-- Fallback: gate wrapper unavailable; call ShowVictimPrompt directly (legacy path).
		pcall(DevMenu_ShowVictimPrompt, _cdbg_bsim_attacker, action)
		_cdbg_bsim_vp_shown = _cdbg_bsim_vp_shown + 1
		if not _cdbg_vp_is_visible() then
			_fail("block_actions/sim_vp_invisible",
				"VP not visible after ShowVictimPrompt (fallback): stage=" .. label
				.. " action=" .. action .. " (" .. n .. "/" .. total .. ")")
		end
	end
	if type(Rule_AddOneShot) == "function" then
		Rule_AddOneShot(_cdbg_bsim_hide_vp, _CDBG_BSIM_VP_DWELL)
	end
	-- Schedule next action every 1 second.
	if type(Rule_AddOneShot) == "function" then
		Rule_AddOneShot(_cdbg_bsim_run_action, _CDBG_BSIM_INTERVAL)
	else
		_cdbg_bsim_run_action()
	end
end

function _cdbg_bsim_done()
	_cdbg_log("[BSIM] All 3 stages complete -- restoring initial block state")
	-- Only toggle OFF if block was disabled before the sim started (preserve user state).
	local get_fn = (type(DevMenu_GetBlockActionsEnabled) == "function")
		and DevMenu_GetBlockActionsEnabled or nil
	local cur = get_fn and get_fn() or nil
	if cur == true and not _cdbg_bsim_was_enabled
		and type(DevMenu_DoToggleBlockActions) == "function" then
		local ok, err = pcall(DevMenu_DoToggleBlockActions)
		if ok then
			_pass("block_actions/toggle_off", "restored OFF (was OFF before sim)")
		else
			_fail("block_actions/toggle_off", "crash on restore: " .. tostring(err))
		end
	else
		_pass("block_actions/toggle_off",
			"state preserved; was_enabled=" .. tostring(_cdbg_bsim_was_enabled))
	end
	_cdbg_log("  T12 output:  toasts=" .. #_cdbg_rec.toasts
		.. "  vp_shown=" .. _cdbg_bsim_vp_shown .. "  vp_gated=" .. _cdbg_bsim_vp_gated)
	_cdbg_log("  Expected:  17 toasts (14 action + 3 stage-announce); shown+gated=14")
	if _cdbg_bsim_vp_disabled_count > 0 then
		_cdbg_log("  Note: " .. _cdbg_bsim_vp_disabled_count
			.. " Disable click(s) mid-bsim; " .. _cdbg_bsim_vp_gated .. " VP(s) gated (live-gameplay behaviour)")
	end
	if _cdbg_bsim_vp_enabled_count > 0 then
		_cdbg_log("  Note: " .. _cdbg_bsim_vp_enabled_count
			.. " Enable click(s) mid-bsim; CLOSE_UNTIL was reset each time (VP resumes after each Enable)")
	end
	if _cdbg_bsim_vp_disabled_count > 0 and _cdbg_bsim_vp_enabled_count == 0 then
		_cdbg_log("  NOTICE: Disable was clicked mid-bsim but Enable was NOT pressed during this bsim run"
			.. " — " .. _cdbg_bsim_vp_gated .. " VP(s) were gated and not recovered"
			.. " (press Enable BEFORE the last bsim action to test in-bsim recovery)")
	end
	-- Gate integrity: every bsim action must account for exactly one gate call (shown or gated).
	-- Gated calls are expected when the user clicks Disable or Close during the sim;
	-- this now replicates live gameplay suppression rather than overriding it.
	local gate_total = _cdbg_bsim_vp_shown + _cdbg_bsim_vp_gated
	if gate_total == 14 then
		_pass("block_actions/bsim_gate_integrity",
			gate_total .. "/14 gate calls accounted for ("
			.. _cdbg_bsim_vp_shown .. " shown, " .. _cdbg_bsim_vp_gated .. " gated)")
	else
		_fail("block_actions/bsim_gate_integrity",
			"expected 14 gate calls (shown+gated), got " .. gate_total
			.. " (shown=" .. _cdbg_bsim_vp_shown .. " gated=" .. _cdbg_bsim_vp_gated .. ")")
	end
	-- Per-verb coverage: gate_integrity passes even when only ONE verb ever showed VP
	-- (others all gated).  Build verb set from recorded entries and assert each of the
	-- 5 expected verbs fired VP at least once.  SKIP entire block if no VP was shown.
	do
		local _expected_verbs = { "teleport", "convert", "invuln", "burn", "destroy" }
		if _cdbg_bsim_vp_shown == 0 then
			for _, v in ipairs(_expected_verbs) do
				_skip("block_actions/vp_verb/" .. v,
					"no VP shown during bsim (all gated) -- per-verb coverage indeterminate")
			end
		else
			local _verbs_seen = {}
			for _, entry in ipairs(_cdbg_rec.victim_prompts) do
				if type(entry) == "table" and entry.verb ~= nil then
					_verbs_seen[tostring(entry.verb)] = (_verbs_seen[tostring(entry.verb)] or 0) + 1
				end
			end
			for _, v in ipairs(_expected_verbs) do
				local _shown_n = _verbs_seen[v] or 0
				local _gated_n = _cdbg_bsim_verb_gated[v] or 0
				if _shown_n >= 1 then
					_pass("block_actions/vp_verb/" .. v,
						"verb '" .. v .. "' fired VP " .. tostring(_shown_n) .. " time(s)"
						.. " (gated " .. tostring(_gated_n) .. ")")
				elseif _gated_n > 0 then
					-- All N opportunities were gated. Gating is the correct, intended behaviour
					-- (CLOSE_UNTIL/Disable suppressed every chance), so the verb path was tested
					-- via the gate and proven to suppress correctly. Round 4: PASS instead of SKIP.
					_pass("block_actions/vp_verb/" .. v,
						"verb '" .. v .. "' had " .. tostring(_gated_n)
						.. " opportunit" .. ((_gated_n == 1) and "y" or "ies")
						.. " — all correctly gated by CLOSE_UNTIL/Disable (suppression verified)")
				else
					_fail("block_actions/vp_verb/" .. v,
						"verb '" .. v .. "' never reached the gate (0 shown, 0 gated) -- "
						.. "sequence may be missing this action type")
				end
			end
		end
	end
	_pass("block_actions/sim_sequence",
		"3-stage block sim (14 actions @ " .. _CDBG_BSIM_INTERVAL .. "s,"
		.. " attacker=\"" .. _cdbg_bsim_attacker .. "\") complete")
	-- -----------------------------------------------------------------------
	-- Deterministic VP Disable→Enable cycle gate test (T12 post-bsim).
	-- Independent of user button presses; always runs; cannot produce a false
	-- PASS from gated actions that were never recovered.
	-- Stage is reset to 0 first so the Disable hook's non-bsim guard doesn't
	-- fire a spurious FAIL; CLOSE_UNTIL is cleared manually since the Enable
	-- hook only auto-clears it when _cdbg_bsim_stage > 0.
	-- -----------------------------------------------------------------------
	_cdbg_bsim_stage = 0   -- reset here (moved up from end of function)
	_cdbg_log("  [vp_cycle] Disable→gate(expect gated)→Enable→gate(expect shown)")
	if type(DevMenu_VictimPromptEnable) == "function"
			and type(DevMenu_TestVictimPromptGate) == "function" then
		-- Baseline: clean VP state.
		_DEVMENU_VICTIM_PROMPT_ENABLED     = true
		_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 0
		if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
		-- Step 1: simulate Disable via direct flag (avoids Disable hook's non-bsim FAIL guard).
		_DEVMENU_VICTIM_PROMPT_ENABLED = false
		local _cyc_pre1 = #_cdbg_rec.victim_prompts
		pcall(DevMenu_TestVictimPromptGate, _cdbg_bsim_attacker, "vp_cycle_disabled")
		if #_cdbg_rec.victim_prompts == _cyc_pre1 then
			_pass("block_actions/vp_cycle_disable",
				"VP correctly gated when ENABLED=false (delta=0)")
		else
			_fail("block_actions/vp_cycle_disable",
				"VP fired while ENABLED=false (expected gated; delta="
				.. (#_cdbg_rec.victim_prompts - _cyc_pre1) .. ")")
		end
		-- Step 2: re-enable via the real function.
		-- Enable now clears CLOSE_UNTIL directly; explicit reset below is belt-and-suspenders only.
		pcall(DevMenu_VictimPromptEnable)      -- sets ENABLED=true; clears CLOSE_UNTIL
		_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 0 -- redundant safety net (Enable already cleared it)
		local _cyc_pre2 = #_cdbg_rec.victim_prompts
		pcall(DevMenu_TestVictimPromptGate, _cdbg_bsim_attacker, "vp_cycle_reenabled")
		if #_cdbg_rec.victim_prompts == _cyc_pre2 + 1 then
			_pass("block_actions/vp_cycle_reenable",
				"VP shown after Enable+CLOSE_UNTIL reset (delta=1)")
		else
			_fail("block_actions/vp_cycle_reenable",
				"VP still gated after Enable (expected delta=1; got "
				.. (#_cdbg_rec.victim_prompts - _cyc_pre2) .. ")"
				.. "  enabled=" .. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED)
				.. "  close_until=" .. tostring(_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL or 0))
		end
		-- Step 3: Enable must CLEAR an active Close cooldown (design 2026-05-25).
		-- A stale CLOSE_UNTIL would silently suppress VP after Enable, making the toggle
		-- appear broken to users.  Verify Enable resets CLOSE_UNTIL=0 and VP fires.
		if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
		_DEVMENU_VICTIM_PROMPT_ENABLED     = false
		_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 999999   -- far-future: active cooldown
		pcall(DevMenu_VictimPromptEnable)              -- sets ENABLED=true; MUST clear CLOSE_UNTIL
		local _cu_after_enable = _DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL or -1
		local _cyc_pre3 = #_cdbg_rec.victim_prompts
		pcall(DevMenu_TestVictimPromptGate, _cdbg_bsim_attacker, "vp_cycle_close_cleared")
		if _cu_after_enable == 0 and #_cdbg_rec.victim_prompts == _cyc_pre3 + 1 then
			_pass("block_actions/vp_cycle_close_cleared",
				"Enable cleared CLOSE_UNTIL (was 999999, now 0); VP shown (delta=1)")
		elseif _cu_after_enable ~= 0 then
			_fail("block_actions/vp_cycle_close_cleared",
				"Enable did not clear CLOSE_UNTIL (still " .. tostring(_cu_after_enable)
				.. ") -- design 2026-05-25 requires Enable to reset cooldown")
		else
			_fail("block_actions/vp_cycle_close_cleared",
				"Enable cleared CLOSE_UNTIL but VP still not shown (delta="
				.. (#_cdbg_rec.victim_prompts - _cyc_pre3) .. ")"
				.. "  enabled=" .. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED))
		end
		-- Restore clean state for T13.
		_DEVMENU_VICTIM_PROMPT_ENABLED     = true
		_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL = 0
	else
		_skip("block_actions/vp_cycle_disable",
			"DevMenu_VictimPromptEnable or TestVictimPromptGate unavailable")
		_skip("block_actions/vp_cycle_reenable",      "prerequisite functions unavailable")
		_skip("block_actions/vp_cycle_close_cleared", "prerequisite functions unavailable")
	end
	-- -----------------------------------------------------------------------
	-- Deterministic VictimNotify Disable/cooldown gate tests (S_VN, T12 post-bsim).
	-- Mirrors VP cycle pattern; exercises _DEVMENU_BLOCK_VICTIM_NOTIFY_ENABLED
	-- and the 10s cooldown via DevMenu_TestVictimNotifyGate.
	-- CDBG degrades to SKIP when the export is absent.
	-- -----------------------------------------------------------------------
	do
		local _vn_ok = type(DevMenu_TestVictimNotifyGate) == "function"
		local _vn_att = (_cdbg_bsim_attacker or "cdbg_vn") .. "_vn"
		if not _vn_ok then
			for _, id in ipairs({"s_vn_1","s_vn_2","s_vn_3","s_vn_4","s_vn_5"}) do
				_skip("block_actions/" .. id, "DevMenu_TestVictimNotifyGate absent")
			end
		else
			-- Baseline: clean VN state.
			_DEVMENU_BLOCK_VICTIM_NOTIFY_ENABLED = true
			_DEVMENU_BLOCK_VICTIM_NOTIFY_LAST_TIME[_vn_att] = nil

			-- S_VN_1: toast fires when enabled and no cooldown.
			local _vn1_pre = #_cdbg_rec.toasts
			pcall(DevMenu_TestVictimNotifyGate, _vn_att, "destroy", "destroyed", 2, 0)
			if #_cdbg_rec.toasts == _vn1_pre + 1 then
				_pass("block_actions/s_vn_1", "VN toast fired when ENABLED=true (delta=1)")
			else
				_fail("block_actions/s_vn_1", "VN toast did not fire when ENABLED=true (delta=" .. (#_cdbg_rec.toasts - _vn1_pre) .. ")")
			end

			-- S_VN_2: toast gated when flag is false.
			_DEVMENU_BLOCK_VICTIM_NOTIFY_ENABLED = false
			_DEVMENU_BLOCK_VICTIM_NOTIFY_LAST_TIME[_vn_att] = nil
			local _vn2_pre = #_cdbg_rec.toasts
			pcall(DevMenu_TestVictimNotifyGate, _vn_att, "destroy", "destroyed", 2, 0)
			if #_cdbg_rec.toasts == _vn2_pre then
				_pass("block_actions/s_vn_2", "VN correctly gated when ENABLED=false (delta=0)")
			else
				_fail("block_actions/s_vn_2", "VN fired while ENABLED=false (delta=" .. (#_cdbg_rec.toasts - _vn2_pre) .. ")")
			end
			_DEVMENU_BLOCK_VICTIM_NOTIFY_ENABLED = true

			-- S_VN_3: 10s cooldown gates back-to-back calls (first fires, second gated).
			_DEVMENU_BLOCK_VICTIM_NOTIFY_LAST_TIME[_vn_att] = nil
			local _vn3_pre = #_cdbg_rec.toasts
			pcall(DevMenu_TestVictimNotifyGate, _vn_att, "destroy", "destroyed", 1, 0)
			pcall(DevMenu_TestVictimNotifyGate, _vn_att, "destroy", "destroyed", 1, 0)
			local _vn3_delta = #_cdbg_rec.toasts - _vn3_pre
			if _vn3_delta == 1 then
				_pass("block_actions/s_vn_3", "10s cooldown gated second VN call (delta=1 from 2 calls)")
			else
				_fail("block_actions/s_vn_3", "expected delta=1 from 2 back-to-back VN calls, got " .. _vn3_delta)
			end

			-- S_VN_4: no-op when allowed=0 AND blocked=0.
			_DEVMENU_BLOCK_VICTIM_NOTIFY_LAST_TIME[_vn_att] = nil
			local _vn4_pre = #_cdbg_rec.toasts
			pcall(DevMenu_TestVictimNotifyGate, _vn_att, "destroy", "destroyed", 0, 0)
			if #_cdbg_rec.toasts == _vn4_pre then
				_pass("block_actions/s_vn_4", "VN correctly no-op when allowed=0 blocked=0 (delta=0)")
			else
				_fail("block_actions/s_vn_4", "VN fired with allowed=0 blocked=0 (delta=" .. (#_cdbg_rec.toasts - _vn4_pre) .. ")")
			end

			-- S_VN_5: mixed toast fires (allowed>0 AND blocked>0).
			_DEVMENU_BLOCK_VICTIM_NOTIFY_LAST_TIME[_vn_att] = nil
			local _vn5_pre = #_cdbg_rec.toasts
			pcall(DevMenu_TestVictimNotifyGate, _vn_att, "destroy", "destroyed", 1, 2)
			if #_cdbg_rec.toasts == _vn5_pre + 1 then
				_pass("block_actions/s_vn_5", "VN mixed toast fired (allowed=1 blocked=2, delta=1)")
			else
				_fail("block_actions/s_vn_5", "VN mixed toast did not fire (allowed=1 blocked=2, delta=" .. (#_cdbg_rec.toasts - _vn5_pre) .. ")")
			end

			-- Restore clean VN state.
			_DEVMENU_BLOCK_VICTIM_NOTIFY_ENABLED = true
			_DEVMENU_BLOCK_VICTIM_NOTIFY_LAST_TIME[_vn_att] = nil
		end
	end
	if type(DevMenu_ShowToast) == "function" then
		pcall(DevMenu_ShowToast, {
			prefix     = "BLOCK SIM: ",
			state_word = "complete",
			state_on   = true,
			suffix     = " -- 3 stages / 14 actions",
			flag       = _cdbg_bsim_attacker_flag,
			name       = _cdbg_bsim_attacker,
		})
	end
	if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
	-- _cdbg_bsim_stage already reset to 0 above
	_cdbg_advance()
end

-----------------------------------------------------------------------
-- T13: Block Handling Validation (NEW) -- ENABLE BLOCK / SKIP prompt if not enabled
-----------------------------------------------------------------------

function _cdbg_t_block_validation()
	_cdbg_log("[TEST] T13: Block Handling Validation")
	if type(DevMenu_GetBlockActionsEnabled) ~= "function" then
		_skip("block_validation", "DevMenu_GetBlockActionsEnabled not available")
		_cdbg_advance(); return
	end
	local enabled = DevMenu_GetBlockActionsEnabled()
	_cdbg_log("  block actions currently enabled: " .. tostring(enabled))
	if enabled == true then
		_pass("block_validation/state", "block handling is active")
	else
		_pass("block_validation/state", "block handling OFF (will be restored at finish)")
	end
	_cdbg_advance()
end

-----------------------------------------------------------------------
-- T14: Attribution Helpers (read-only) -- verify single_owner / resolve_by_pid
-- These helpers gate cross-player toast attribution for destroy/burn/teleport
-- (convert uses a different code path with explicit target_player).  If they
-- are missing or buggy, toasts silently fall back to no-attribution.
-- All checks are pure-function / read-only, so this test is MP-safe.
-----------------------------------------------------------------------

function _cdbg_t_attribution_helpers()
	_cdbg_log("[TEST] T14: Attribution Helpers (single_owner / resolve_by_pid / player_info)")

	-- C1: helper availability
	local _so_ok = type(_devmenu_single_owner) == "function"
	local _rb_ok = type(_devmenu_resolve_player_info_by_pid) == "function"
	local _pi_ok = type(_devmenu_player_info) == "function"
	if _so_ok then
		_pass("attribution/single_owner_available", "_devmenu_single_owner is defined")
	else
		_fail("attribution/single_owner_available",
			"_devmenu_single_owner missing -- destroy/burn/teleport toasts will not attribute owner")
	end
	if _rb_ok then
		_pass("attribution/resolve_by_pid_available", "_devmenu_resolve_player_info_by_pid is defined")
	else
		_fail("attribution/resolve_by_pid_available",
			"_devmenu_resolve_player_info_by_pid missing -- toasts cannot resolve PID -> player")
	end
	if _pi_ok then
		_pass("attribution/player_info_available", "_devmenu_player_info is defined")
	else
		_fail("attribution/player_info_available",
			"_devmenu_player_info missing -- convert toast will not attribute target")
	end

	-- C2: _devmenu_single_owner unit tests (pure function, no side effects)
	if _so_ok then
		local ok1, a1, b1 = pcall(_devmenu_single_owner, { [1] = 3 })
		if ok1 and a1 == 1 and b1 == 3 then
			_pass("attribution/single_owner_single",
				"{[1]=3} -> (1, 3) as expected")
		else
			_fail("attribution/single_owner_single",
				"{[1]=3} expected (1, 3); got (" .. tostring(a1) .. ", " .. tostring(b1) .. ")"
				.. "  pcall_ok=" .. tostring(ok1))
		end
		local ok2, a2, b2 = pcall(_devmenu_single_owner, { [1] = 2, [2] = 1 })
		if ok2 and a2 == nil and b2 == 3 then
			_pass("attribution/single_owner_mixed",
				"{[1]=2,[2]=1} -> (nil, 3) as expected (mixed-owner selection)")
		else
			_fail("attribution/single_owner_mixed",
				"{[1]=2,[2]=1} expected (nil, 3); got (" .. tostring(a2) .. ", " .. tostring(b2) .. ")")
		end
		local ok3, a3, b3 = pcall(_devmenu_single_owner, {})
		if ok3 and a3 == nil and b3 == 0 then
			_pass("attribution/single_owner_empty",
				"{} -> (nil, 0) as expected (empty selection)")
		else
			_fail("attribution/single_owner_empty",
				"{} expected (nil, 0); got (" .. tostring(a3) .. ", " .. tostring(b3) .. ")")
		end
		-- Phase 3c edge cases (2026-05-25): non-1-based / zero-count / many-owners.
		-- Sparse keys: 2 distinct owners (pids 5, 7), total 5 entities. Expect (nil, 5).
		local ok4, a4, b4 = pcall(_devmenu_single_owner, { [5] = 3, [7] = 2 })
		if ok4 and a4 == nil and b4 == 5 then
			_pass("attribution/single_owner_sparse_mixed",
				"{[5]=3,[7]=2} -> (nil, 5) as expected")
		else
			_fail("attribution/single_owner_sparse_mixed",
				"{[5]=3,[7]=2} expected (nil, 5); got (" .. tostring(a4) .. ", " .. tostring(b4) .. ")")
		end
		-- Zero-count single owner: documents whether 0-count is treated as "present" or not.
		-- Helper iterates table pairs; pid 1 has count 0 -> single owner with zero entities.
		local ok5, a5, b5 = pcall(_devmenu_single_owner, { [1] = 0 })
		if ok5 and a5 == 1 and b5 == 0 then
			_pass("attribution/single_owner_zero_count",
				"{[1]=0} -> (1, 0) as expected (single owner, zero entities)")
		else
			_fail("attribution/single_owner_zero_count",
				"{[1]=0} expected (1, 0); got (" .. tostring(a5) .. ", " .. tostring(b5)
				.. ") -- helper may filter zero-count keys; review _devmenu_single_owner")
		end
		-- Three owners with mixed large counts: regression check for sum overflow / loop limits.
		local ok6, a6, b6 = pcall(_devmenu_single_owner, { [1] = 100, [2] = 50, [3] = 25 })
		if ok6 and a6 == nil and b6 == 175 then
			_pass("attribution/single_owner_three_owners",
				"{[1]=100,[2]=50,[3]=25} -> (nil, 175) as expected")
		else
			_fail("attribution/single_owner_three_owners",
				"{[1]=100,[2]=50,[3]=25} expected (nil, 175); got ("
				.. tostring(a6) .. ", " .. tostring(b6) .. ")")
		end
	else
		_skip("attribution/single_owner_single", "_devmenu_single_owner unavailable")
		_skip("attribution/single_owner_mixed",  "_devmenu_single_owner unavailable")
		_skip("attribution/single_owner_empty",  "_devmenu_single_owner unavailable")
		_skip("attribution/single_owner_sparse_mixed",  "_devmenu_single_owner unavailable")
		_skip("attribution/single_owner_zero_count",    "_devmenu_single_owner unavailable")
		_skip("attribution/single_owner_three_owners",  "_devmenu_single_owner unavailable")
	end

	-- C3: _devmenu_resolve_player_info_by_pid smoke test (no state mutation)
	if _rb_ok then
		-- Find local player's PID.  Phase 3a (2026-05-25 MP fix): the original
		-- iteration `for i = 1, World_GetPlayerCount() do` SKIPs in MP because
		-- the loop fails to identify the local player even when Misc_IsLocalPlayer
		-- and Player_GetID ARE available (confirmed via convert toast: pid=1001
		-- self=true).  Try Game_GetLocalPlayer() first (single API), then fall
		-- back to a pcall-wrapped loop iterating 0..N (some APIs are 0-indexed).
		-- Diagnostic logged on failure so the next run pinpoints the gap.
		local _local_pid = nil
		local _pid_source = "none"
		if type(Game_GetLocalPlayer) == "function" and type(Player_GetID) == "function" then
			local ok_g, p = pcall(Game_GetLocalPlayer)
			if ok_g and p ~= nil then
				local ok_i, pid = pcall(Player_GetID, p)
				if ok_i and pid ~= nil then
					_local_pid  = pid
					_pid_source = "Game_GetLocalPlayer"
				end
			end
		end
		if _local_pid == nil and type(World_GetPlayerCount) == "function"
				and type(World_GetPlayerAt) == "function"
				and type(Misc_IsLocalPlayer) == "function"
				and type(Player_GetID) == "function" then
			local _count = World_GetPlayerCount() or 0
			local _dbg = ""
			-- Iterate 0..N to cover both 0-indexed and 1-indexed conventions.
			for i = 0, _count do
				local ok_p, p = pcall(World_GetPlayerAt, i)
				if ok_p and p ~= nil then
					local ok_l, is_l = pcall(Misc_IsLocalPlayer, p)
					local ok_i, pid  = pcall(Player_GetID, p)
					_dbg = _dbg .. "[" .. i .. ":pid=" .. tostring(ok_i and pid or "?")
						.. ",local=" .. tostring(ok_l and is_l or "?") .. "]"
					if ok_l and is_l == true and ok_i and pid ~= nil then
						_local_pid  = pid
						_pid_source = "World_GetPlayerAt[" .. i .. "]"
						break
					end
				end
			end
			if _local_pid == nil then
				_cdbg_log("  [T14] local PID lookup failed: count=" .. _count .. " " .. _dbg)
			end
		end
		if _local_pid ~= nil then
			local ok, info = pcall(_devmenu_resolve_player_info_by_pid, _local_pid)
			if ok and type(info) == "table" and type(info.display_name) == "string" and info.is_self == true then
				_pass("attribution/resolve_local_player",
					"local PID " .. tostring(_local_pid) .. " (via " .. _pid_source
					.. ") -> '" .. info.display_name .. "' is_self=true")
			else
				_fail("attribution/resolve_local_player",
					"local PID " .. tostring(_local_pid) .. " did not resolve with is_self=true"
					.. "  (ok=" .. tostring(ok) .. " info_type=" .. type(info)
					.. " display_name=" .. tostring(type(info) == "table" and info.display_name)
					.. " is_self=" .. tostring(type(info) == "table" and info.is_self) .. ")")
			end
		else
			_skip("attribution/resolve_local_player",
				"could not determine local PID via Game_GetLocalPlayer or World_GetPlayerAt loop "
				.. "(see [T14] diag line above)")
		end
		-- Invalid PID -> fallback table
		local ok_f, info_f = pcall(_devmenu_resolve_player_info_by_pid, -99)
		if ok_f and type(info_f) == "table" and info_f.display_name == "Player -99" then
			_pass("attribution/resolve_fallback",
				"invalid PID -99 -> fallback table 'Player -99'")
		else
			_fail("attribution/resolve_fallback",
				"invalid PID -99 expected fallback 'Player -99'; got '"
				.. tostring(type(info_f) == "table" and info_f.display_name) .. "'")
		end
	else
		_skip("attribution/resolve_local_player", "_devmenu_resolve_player_info_by_pid unavailable")
		_skip("attribution/resolve_fallback",     "_devmenu_resolve_player_info_by_pid unavailable")
	end

	_cdbg_advance()
end

-----------------------------------------------------------------------
-- MP read-only diagnostic
-- Called instead of the full test suite when DevMenu_RunCheatsDebugger
-- detects multiplayer.  Verifies the VP gate fires for each of the 5
-- action verbs and runs the attribution helper checks (T14).  No sim
-- state is mutated; gate calls go through DevMenu_TestVictimPromptGate
-- which only invokes the UI overlay path (no Entity/Squad mutations).
-----------------------------------------------------------------------

function _cdbg_run_mp_vp_diagnostic()
	print("[DEVMENU-CDBG-MP] === MP read-only diagnostic START ===")
	_cdbg_log("=== CDBG MP DIAGNOSTIC (read-only) ===")
	_cdbg_pass = 0
	_cdbg_fail = 0
	_cdbg_skip = 0
	_cdbg_ensure_ui()
	_cdbg_clear_rec()
	_cdbg_install_hooks()

	-- Per-verb VP gate check
	if type(DevMenu_TestVictimPromptGate) == "function" then
		local _verbs = { "teleport", "convert", "invuln", "burn", "destroy" }
		for _, v in ipairs(_verbs) do
			local pre = #_cdbg_rec.victim_prompts
			pcall(DevMenu_TestVictimPromptGate, "[MP-DIAG]", v)
			local post = #_cdbg_rec.victim_prompts
			if post > pre then
				_pass("mp_vp/" .. v,
					"gate fired VP for verb '" .. v .. "' (delta=" .. (post - pre) .. ")")
			else
				_fail("mp_vp/" .. v,
					"gate suppressed VP for verb '" .. v .. "' -- check ENABLED/CLOSE_UNTIL"
					.. "  (ENABLED=" .. tostring(_DEVMENU_VICTIM_PROMPT_ENABLED)
					.. " CLOSE_UNTIL=" .. tostring(_DEVMENU_VICTIM_PROMPT_CLOSE_UNTIL or 0) .. ")")
			end
			if type(DevMenu_HideVictimPrompt) == "function" then pcall(DevMenu_HideVictimPrompt) end
		end
	else
		_skip("mp_vp/all_verbs", "DevMenu_TestVictimPromptGate not available")
	end

	-- Inline attribution helper checks (same as T14, no side effects)
	_cdbg_t_attribution_helpers_inline()

	_cdbg_restore_hooks()
	local _summary = "MP DIAG complete: " .. _cdbg_pass .. " pass / " .. _cdbg_fail
		.. " fail / " .. _cdbg_skip .. " skip"
	print("[DEVMENU-CDBG-MP] " .. _summary)
	_cdbg_log("=== " .. _summary .. " ===")
	if type(DevMenu_ShowToast) == "function" then
		DevMenu_ShowToast({
			prefix     = "DEVMENU_DIAG: ",
			state_word = "MP read-only diag complete",
			state_on   = (_cdbg_fail == 0),
			suffix     = string.format(" -- %d pass / %d fail (check scarlog)",
				_cdbg_pass, _cdbg_fail),
		})
	end
end

-- Inline variant of T14 that does not call _cdbg_advance (used by MP diag
-- which does not run a queue).  Body is intentionally a near-duplicate of
-- _cdbg_t_attribution_helpers minus the queue advancement; kept separate
-- to avoid threading a queue-mode flag through the test.
function _cdbg_t_attribution_helpers_inline()
	local _saved_advance = _cdbg_advance
	_cdbg_advance = function() end   -- no-op shim for the duration of the test
	local ok, err = pcall(_cdbg_t_attribution_helpers)
	_cdbg_advance = _saved_advance
	if not ok then
		_fail("attribution/inline_runner", "crash during inline attribution test: " .. tostring(err))
	end
end

-----------------------------------------------------------------------
-- Entry point
-----------------------------------------------------------------------

function DevMenu_RunCheatsDebugger()
	-- All cheat actions are classified MED in _DEVMENU_MP_RISK (routed via
	-- DevMenu_NetworkDispatch / GE_BroadcastMessage to all peers), so the full
	-- suite is safe in multiplayer.  Log MP mode for scarlog diff only.
	if type(_devmenu_is_multiplayer) == "function" and _devmenu_is_multiplayer() then
		print("[DEVMENU-CDBG] Multiplayer detected -- full suite runs (all actions MED-routed; gate active)")
	end
	if _cdbg_running then
		_cdbg_log("Already running -- ignoring re-entry")
		return
	end
	_cdbg_running = true
	_CDBG_SESSION_ACTIVE = true   -- cross-file bridge: devmenu.scar reads this in DevMenu_VictimPromptEnable
	_cdbg_pass = 0
	_cdbg_fail = 0
	_cdbg_skip = 0
	_cdbg_log("=== CDBG START (DevMenu Cheat Action Debugger) ===")
	_cdbg_log("Build tag: " .. tostring(_CDBG_BUILD_TAG))
	_cdbg_log("Sim time: " .. tostring(
		type(World_GetGameTime) == "function" and World_GetGameTime() or "N/A"))
	-- Capture initial toggle states for final cleanup in _cdbg_finish_run.
	_cdbg_init_instant_build = (type(DevMenu_GetInstantBuildEnabled) == "function")
		and (DevMenu_GetInstantBuildEnabled() == true) or false
	_cdbg_init_block_enabled = (type(DevMenu_GetBlockActionsEnabled) == "function")
		and (DevMenu_GetBlockActionsEnabled() == true) or false
	_cdbg_log("  init: instant_build=" .. tostring(_cdbg_init_instant_build)
		.. " block_enabled=" .. tostring(_cdbg_init_block_enabled))
	_cdbg_ensure_ui()
	_cdbg_install_hooks()
	_cdbg_queue = {
		_cdbg_t_resources,        -- T1:  no selection required
		_cdbg_t_progression,      -- T2:  no selection required
		_cdbg_t_speed,            -- T3:  no selection required
		_cdbg_t_world,            -- T4:  no selection (FoW cycle reset applied after Explore All)
		_cdbg_t_production,       -- T5:  no selection required
		_cdbg_t_unit_phase,       -- T6:  UNIT selection -> Teleport/Convert/Invuln/Destroy (LAST)
		_cdbg_t_bldg_phase_1,     -- T7:  BUILDING 1 (starter keep) -> Burn/Destroy (LAST)
		_cdbg_t_bldg_phase_2,     -- T8:  BUILDING 2 (secondary) -> Burn/Destroy (LAST)
		_cdbg_t_reset_toggles,    -- T9:  reset toggles (instant_build/speed/block/VP) to initial state
		_cdbg_t_notifications,    -- T10: 7-step VP/BlockNotify test (show→close→30s→reshow→disable→gate→reenable)
		_cdbg_t_block_actions,    -- T11: 3-stage block sim (unit/bldg/keep), AI attacker, 1s intervals
		_cdbg_t_block_validation, -- T12: NEW check block enabled; ENABLE BLOCK/SKIP prompt
		_cdbg_t_attribution_helpers, -- T14: attribution helpers (read-only; verifies cross-player toast path)
	}
	_cdbg_idx = 0
	_cdbg_advance()
end
