		return string.format("verbosity=%d, patrol_ownership_capture=%s",
			_AI_DEBUG_VERBOSITY or 0,
			tostring(_AI_DEBUG_CAPTURE_PATROL_OWNERSHIP == true))
	end)
end

function DevMenu_GetTraceLoggingEnabled()
