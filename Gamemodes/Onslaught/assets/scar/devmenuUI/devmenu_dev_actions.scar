-- Frame-bracket probe: fires the Invuln toggle wrapped in timing markers.
-- Useful for multi-peer scarlog diff to confirm lockstep tick alignment.
function DevMenu_DiagFrameInvuln()
	if type(_devmenu_frame_bracket) == "function" then
		local player = type(Game_GetLocalPlayer) == "function" and Game_GetLocalPlayer() or nil
		if player ~= nil and type(DevMenu_DoInvulnerableCheat) == "function" then
			_devmenu_frame_bracket("invuln_toggle", DevMenu_DoInvulnerableCheat, player)
		else
			print("[DEVMENU-DIAG] DiagFrameInvuln: no local player or no action handler")
		end
	else
		print("[DEVMENU-DIAG] DiagFrameInvuln: _devmenu_frame_bracket not loaded")
	end
end

-- Cheat Action Debugger (DEVMENU_DIAG): sim-mutating, SP-only.
-- devmenu_cheat_debugger.scar overrides this fallback when loaded successfully.
-- NOT added to _DEVMENU_DEV_MP_SAFE (sim-mutating; blocked by the MP gate).
function DevMenu_RunCheatsDebugger()
	print("[DEVMENU] DevMenu_RunCheatsDebugger: devmenu_cheat_debugger.scar not loaded")
end
