function DevMenu_GetSiegeVerboseLoggingEnabled()
	return _devmenu_is_siege_verbose_logging_enabled()
end

function DevMenu_ToggleSiegeVerboseLogging()
	_devmenu_toggle_logging_control("Siege verbose logging", _devmenu_is_siege_verbose_logging_enabled, _devmenu_set_siege_verbose_logging_enabled, function()
		local mode = (_cba_debug and (_cba_debug.siege_log_mode or _cba_debug.siegeLogMode)) or "standard"
		return "mode=" .. tostring(mode)
	end)
end

