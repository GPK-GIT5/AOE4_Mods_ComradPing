-----------------------------------------------------------------------
-- Debugger Tools
-- Self-diagnostics, replication probes, and frame-timing brackets.
-- All entries here are either read-only or gated through the MP-safe
-- allowlist; none fire sim mutations directly.
-----------------------------------------------------------------------

-- Full DevMenu self-diagnostic pass (API + action probes). Defined in devmenu_diag.scar.
function DevMenu_DiagRunAll()
	if type(_G.DevMenu_DiagRunAll_impl) == "function" then
		_G.DevMenu_DiagRunAll_impl()
	elseif type(_G.DevMenu_DiagRunAll) == "function" then
		-- devmenu_diag.scar defines DevMenu_DiagRunAll directly; call it via pcall
		-- to catch any engine errors and print them to scarlog.
		local ok, err = pcall(_G.DevMenu_DiagRunAll)
		if not ok then print("[DEVMENU] DevMenu_DiagRunAll ERROR: " .. tostring(err)) end
		return
	end
	print("[DEVMENU] DevMenu_DiagRunAll: devmenu_diag.scar not loaded")
end

-- Per-state replication probes: read-only, MP-safe (no sim writes).
function DevMenu_DiagReplInvuln()
	if type(_devmenu_is_multiplayer) == "function" and type(DevMenu_DiagReplicationProbe) == "function"
			and type(gInvulnerableCheat) == "table" then
		DevMenu_DiagReplicationProbe("invuln", function(p)
			return type(Player_GetID) == "function" and gInvulnerableCheat[Player_GetID(p)]
		end)
	else
		print("[DEVMENU-DIAG] DiagReplInvuln: gInvulnerableCheat not available")
	end
end

