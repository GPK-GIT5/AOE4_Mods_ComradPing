	_devmenu_toggle_logging_control("PlayerUI runtime logging", _devmenu_is_playerui_logging_enabled, _devmenu_set_playerui_logging_enabled)
end

function DevMenu_GetPlayerUIDiagnosticLoggingEnabled()
	return _devmenu_is_playerui_diagnostic_logging_enabled()
end

function DevMenu_TogglePlayerUIDiagnosticLogging()
	_devmenu_toggle_logging_control("PlayerUI diagnostics", _devmenu_is_playerui_diagnostic_logging_enabled, _devmenu_set_playerui_diagnostic_logging_enabled)
