	local shared_reward_civs = {
		"english", "chinese", "french", "hre", "mongol", "rus", "sultanate", "abbasid", "malian", "ottoman",
		"abbasid_ha_01", "french_ha_01", "chinese_ha_01", "hre_ha_01", "japanese", "byzantine",
		"mongol_ha_gol", "lancaster", "templar", "japanese_ha_sen", "byzantine_ha_mac", "sultanate_ha_tug",
		"jin_dynasty",
	}
	for _, civ_name in ipairs(shared_reward_civs) do
		CBA_Rewards_Onslaught_ApplySharedThresholds(civ_name)
	end

	-- DLC variant civs: alias to parent reward tables (driven by AGS_CIV_FACTION_MAP)
	if AGS_CIV_FACTION_MAP ~= nil then
		for variant, parent in pairs(AGS_CIV_FACTION_MAP) do
			if _CBA.rewards[parent] ~= nil and _CBA.rewards[variant] == nil then
				_CBA.rewards[variant] = _CBA.rewards[parent]
			end
		end
	end
end