---------------------------------------------------------------------------------------------------
-- Onslaught Reward Trees
-- Per-civilization kill threshold reward data for Onslaught mode (300s spawner)
-- 23 civs: 12 base + 4 Knights DLC + 6 Dynasties DLC + 1 Yue Fei's Legacy DLC (all explicit tables)
-- Split from rewards.scar for maintainability
---------------------------------------------------------------------------------------------------

function CBA_Rewards_List_Onslaught()
	
	_CBA.rewards["english"]={} 
	_CBA.rewards["chinese"]={} 
	_CBA.rewards["french"]={} 
	_CBA.rewards["hre"]={} 
	_CBA.rewards["mongol"]={} 
	_CBA.rewards["rus"]={} 
	_CBA.rewards["sultanate"]={} 
	_CBA.rewards["abbasid"]={} 
	_CBA.rewards["malian"]={} 
	_CBA.rewards["ottoman"]={} 
	-- Expansion
	_CBA.rewards["abbasid_ha_01"]={} 
	_CBA.rewards["french_ha_01"]={} 
	_CBA.rewards["chinese_ha_01"]={} 
	_CBA.rewards["hre_ha_01"]={} 
	_CBA.rewards["japanese"]={}
	_CBA.rewards["byzantine"]={} 
	-- Dynasties DLC
	_CBA.rewards["mongol_ha_gol"]={}
	_CBA.rewards["lancaster"]={}
	_CBA.rewards["templar"]={}
	_CBA.rewards["japanese_ha_sen"]={}
	_CBA.rewards["byzantine_ha_mac"]={}
	_CBA.rewards["sultanate_ha_tug"]={}
	-- Yue Fei's Legacy DLC
	_CBA.rewards["jin_dynasty"]={}


	---------------
	--- SHARED  ---
	---------------


	local function CBA_Rewards_Onslaught_ApplySharedThresholds(civ_name)
		local rewards = _CBA.rewards[civ_name]
		if rewards == nil then
			return
		end

		rewards[100] = { title = "$1000893", upgrade = AGS_UP_SIEGE_ENGINEERS }
		rewards[450] = { title = "$11143393", upgrade = AGS_UP_SIEGE_ROLLER_TRIGGER }
		if AGS_GLOBAL_SETTINGS.Option_Reward_Age then
			rewards[500] = { title = "$11149424", age = 2 }
		end
		rewards[600] = { title = "$11166508", upgrade = AGS_UP_D_RANGED_I }
		rewards[700] = { title = "$11166450", upgrade = AGS_UP_D_MELEE_II }
		rewards[800] = { title = "$11166532", upgrade = AGS_UP_A_RANGED_I }
		rewards[900] = { title = "$11166393", upgrade = AGS_UP_A_MELEE_II }
		if AGS_GLOBAL_SETTINGS.Option_Reward_Age then
			rewards[1000] = { title = "$11149425", age = 3 }
		end
		rewards[1200] = { title = "$11166509", upgrade = AGS_UP_D_RANGED_II }
		rewards[1300] = { title = "$11168127", upgrade = AGS_UP_SPEARMAN_ELITE }
		rewards[1400] = { title = "$11166451", upgrade = AGS_UP_D_MELEE_III }
		rewards[1600] = { title = "$11166539", upgrade = AGS_UP_A_RANGED_II }
		rewards[1700] = { title = "$11168132", upgrade = AGS_UP_MANATARMS_ELITE }
		rewards[1800] = { title = "$11166402", upgrade = AGS_UP_A_MELEE_III }
		rewards[1900] = { title = "$11144582", upgrade = AGS_UP_SIEGE_ADJUSTABLE_CROSSBAR }
		if AGS_GLOBAL_SETTINGS.Option_Reward_Age then
			rewards[2000] = { title = "$11149426", age = 4 }
		end
		rewards[2200] = { title = "$11166540", upgrade = AGS_UP_A_RANGED_III }
		rewards[2400] = { title = "$11155932", upgrade = AGS_UP_BIOLOGY }
		rewards[3000] = { title = "$11143350", upgrade = AGS_UP_GRAPERED_LANCE }
		rewards[3100] = { title = "$11143381", upgrade = AGS_UP_RANGED_INCENDIARY }
		rewards[3250] = { title = "$11143314", upgrade = AGS_UP_MILITARY_ACADEMY }
		rewards[4250] = { title = "$11155725", upgrade = AGS_UP_ARCHITECTURE }
		rewards[4500] = { title = "$11143390", upgrade = AGS_UP_CHEMISTRY }
		rewards[5000] = { title = "$11155930", upgrade = AGS_UP_SIEGE_WORKS }
		rewards[5250] = { title = "$11168900", upgrade = AGS_UP_SIEGE_SPEED }
		rewards[7500] = { title = "$11119564", restriction = AGS_BP_HOUSE }
		rewards[10000] = { title = "$11144562", restriction = AGS_BP_WONDER }
	end

